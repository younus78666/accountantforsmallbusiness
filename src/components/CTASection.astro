---
interface Props {
  heading: string;
  subtext?: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  variant?: 'navy' | 'gold';
}

const {
  heading, subtext, primaryLabel, primaryHref,
  secondaryLabel, secondaryHref, variant = 'navy'
} = Astro.props;

const isGold = variant === 'gold';
---

<section class={`relative overflow-hidden py-20 lg:py-24 ${isGold ? 'bg-gold-btn' : 'bg-navy'}`}>

  {!isGold && (
    /* Subtle pattern for navy variant */
    <div class="absolute inset-0 opacity-[0.04]">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="cta-dots" width="24" height="24" patternUnits="userSpaceOnUse">
            <circle cx="12" cy="12" r="1.5" fill="#DAA035"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#cta-dots)" />
      </svg>
    </div>
  )}

  {isGold && (
    /* Decorative circles for gold variant */
    <>
      <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-white/10 blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-20 -left-20 w-60 h-60 rounded-full bg-navy/10 blur-3xl pointer-events-none"></div>
    </>
  )}

  <div class="relative z-10 section-inner text-center">
    <h2 class={`text-3xl lg:text-5xl font-extrabold mb-4 tracking-tight ${isGold ? 'text-navy' : 'text-white'}`}>
      {heading}
    </h2>
    {subtext && (
      <p class={`text-lg max-w-xl mx-auto mb-10 font-normal leading-relaxed ${isGold ? 'text-navy/75' : 'text-white/65'}`}>
        {subtext}
      </p>
    )}
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href={primaryHref}
        class={`inline-flex items-center gap-2 px-8 py-4 text-base font-bold rounded-xl transition-all duration-200 hover:-translate-y-0.5
          ${isGold
            ? 'bg-navy text-gold-btn hover:bg-navy-deep hover:shadow-xl hover:shadow-navy/30'
            : 'bg-gold-btn text-navy hover:bg-gold-hover hover:shadow-xl hover:shadow-gold/25'}`}
      >
        {primaryLabel}
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      {secondaryLabel && secondaryHref && (
        <a
          href={secondaryHref}
          class={`inline-flex items-center gap-2 px-8 py-4 text-base font-semibold rounded-xl border-2 transition-all duration-200 hover:-translate-y-0.5
            ${isGold
              ? 'border-navy/30 text-navy hover:border-navy hover:bg-navy/5'
              : 'border-white/25 text-white hover:border-gold hover:text-gold-btn'}`}
        >
          {secondaryLabel}
        </a>
      )}
    </div>
  </div>
</section>
