---
/* Contact form + Singapore map, used inline on homepage */
---

<section class="bg-navy py-20 lg:py-28" id="contact">
  <div class="section-inner">

    <!-- Header -->
    <div class="text-center mb-14">
      <div class="eyebrow-dark mb-5">Get in Touch</div>
      <h2 class="text-3xl lg:text-5xl text-white mb-4">Book a free consultation</h2>
      <p class="text-white/55 text-lg max-w-xl mx-auto font-normal">
        Tell us about your business. We'll assess your needs and send a fixed quote within one business day.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">

      <!-- Form -->
      <div class="bg-navy-panel rounded-2xl p-8 lg:p-10 border border-white/8">
        <h3 class="text-xl font-bold text-white mb-6">Send us a message</h3>
        <form
          name="contact"
          method="POST"
          data-netlify="true"
          action="/thank-you/"
          class="flex flex-col gap-5"
        >
          <input type="hidden" name="form-name" value="contact" />

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-xs font-bold uppercase tracking-wider text-white/45 mb-2">Full Name *</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Your full name"
                class="w-full px-4 py-3 rounded-xl border border-white/10 text-sm font-medium text-white placeholder-white/25 bg-white/5 focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold transition-all duration-200"
              />
            </div>
            <div>
              <label for="email" class="block text-xs font-bold uppercase tracking-wider text-white/45 mb-2">Email Address *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="you@company.com"
                class="w-full px-4 py-3 rounded-xl border border-white/10 text-sm font-medium text-white placeholder-white/25 bg-white/5 focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold transition-all duration-200"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="company" class="block text-xs font-bold uppercase tracking-wider text-white/45 mb-2">Company Name</label>
              <input
                type="text"
                id="company"
                name="company"
                placeholder="Your company"
                class="w-full px-4 py-3 rounded-xl border border-white/10 text-sm font-medium text-white placeholder-white/25 bg-white/5 focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold transition-all duration-200"
              />
            </div>
            <div>
              <label for="phone" class="block text-xs font-bold uppercase tracking-wider text-white/45 mb-2">Phone / WhatsApp</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="+65 XXXX XXXX"
                class="w-full px-4 py-3 rounded-xl border border-white/10 text-sm font-medium text-white placeholder-white/25 bg-white/5 focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold transition-all duration-200"
              />
            </div>
          </div>

          <div>
            <label for="service" class="block text-xs font-bold uppercase tracking-wider text-white/45 mb-2">Service Needed</label>
            <select
              id="service"
              name="service"
              class="w-full px-4 py-3 rounded-xl border border-white/10 text-sm font-medium text-white bg-white/5 focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold transition-all duration-200 appearance-none"
            >
              <option value="" disabled selected>Select a service</option>
              <option value="bookkeeping">Bookkeeping</option>
              <option value="accounting">Accounting Services</option>
              <option value="payroll">Payroll & CPF</option>
              <option value="financial-statements">Financial Statements</option>
              <option value="outsourced-accounting">Outsourced Accounting</option>
              <option value="not-sure">Not sure, need advice</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-xs font-bold uppercase tracking-wider text-white/45 mb-2">Tell us about your business</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="How many transactions per month? Any staff? GST registered? (Optional, helps us quote accurately)"
              class="w-full px-4 py-3 rounded-xl border border-white/10 text-sm font-medium text-white placeholder-white/25 bg-white/5 focus:outline-none focus:ring-2 focus:ring-gold/40 focus:border-gold transition-all duration-200 resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full inline-flex items-center justify-center gap-2 px-6 py-4 bg-gold-btn text-navy text-base font-bold rounded-xl hover:bg-gold-hover transition-all duration-200 hover:shadow-lg hover:shadow-gold/20 hover:-translate-y-0.5"
          >
            Send Message, Get a Free Quote
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </button>

          <p class="text-center text-xs text-white/30 font-normal">We respond within 1 business day. No spam, ever.</p>
        </form>
      </div>

      <!-- Info + Map -->
      <div class="flex flex-col gap-6">

        <!-- Contact details -->
        <div class="bg-navy rounded-2xl p-8">
          <h3 class="text-lg font-bold text-white mb-6">Contact details</h3>
          <div class="flex flex-col gap-5">

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-gold/15 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gold-btn" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="text-white/40 text-xs font-semibold uppercase tracking-wider mb-1">Email</p>
                <!-- CONFIRM email -->
                <a href="mailto:hello@accountantforsmallbusiness.com" class="text-white text-sm font-medium hover:text-gold-btn transition-colors break-all">
                  hello@accountantforsmallbusiness.com
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-gold/15 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gold-btn" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="text-white/40 text-xs font-semibold uppercase tracking-wider mb-1">Response time</p>
                <p class="text-white text-sm font-medium">Within 1 business day</p>
                <p class="text-white/40 text-xs mt-0.5">Mon&ndash;Fri, Singapore time (GMT+8)</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-gold/15 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gold-btn" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="text-white/40 text-xs font-semibold uppercase tracking-wider mb-1">Service area</p>
                <p class="text-white text-sm font-medium">Singapore &mdash; remote delivery</p>
                <p class="text-white/40 text-xs mt-0.5">All services delivered via Xero & video call</p>
              </div>
            </div>

          </div>
        </div>

        <!-- Singapore Map -->
        <div class="rounded-2xl overflow-hidden" style="box-shadow: 0 4px 32px rgba(0,15,34,0.10);">
          <div class="bg-navy-panel px-5 py-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-gold-btn" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="text-white/70 text-xs font-semibold">Singapore, serving SMEs remotely</span>
          </div>
          <iframe
            title="Singapore map"
            src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d127641.37!2d103.8198!3d1.3521!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sen!2ssg!4v1699000000000!5m2!1sen!2ssg"
            width="100%"
            height="280"
            style="border:0; display:block;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
