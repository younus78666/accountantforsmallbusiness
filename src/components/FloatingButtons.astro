---
/* WhatsApp float (left) + Scroll-to-top (right) */
const waNumber = '923332999777';
const waMessage = encodeURIComponent("Hi Mehdi, I'm looking for accounting services for my Singapore small business. Can we get a free quote?");
const waUrl = `https://wa.me/${waNumber}?text=${waMessage}`;
---

<!-- WhatsApp, bottom left -->
<a
  href={waUrl}
  target="_blank"
  rel="noopener noreferrer"
  id="wa-btn"
  aria-label="Chat on WhatsApp"
  class="fixed bottom-6 left-5 z-50 flex items-center gap-2.5 bg-[#DCA33C] hover:bg-[#C8912F] text-[#000F22] font-semibold text-sm px-4 py-3 rounded-full shadow-lg hover:shadow-xl transition-all duration-200 hover:-translate-y-0.5 group"
  style="box-shadow: 0 4px 20px rgba(220,163,60,0.35);"
>
  <!-- Mehdi photo avatar -->
  <img
    src="/mehdi-javed.jpg"
    alt="Mehdi Javed"
    class="w-8 h-8 rounded-full object-cover object-top shrink-0 ring-2 ring-[#000F22]/30"
  />
  <span class="whitespace-nowrap">Chat with Mehdi</span>
</a>

<!-- Scroll to top, bottom right -->
<button
  id="scroll-top-btn"
  aria-label="Scroll to top"
  onclick="window.scrollTo({top:0,behavior:'smooth'})"
  class="fixed bottom-6 right-5 z-50 w-12 h-12 bg-[#DCA33C] hover:bg-[#C8912F] text-[#000F22] rounded-full shadow-lg hover:shadow-xl transition-all duration-200 hover:-translate-y-0.5 flex items-center justify-center opacity-0 pointer-events-none"
  style="box-shadow: 0 4px 20px rgba(220,163,60,0.35);"
>
  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
  </svg>
</button>

<script>
  const btn = document.getElementById('scroll-top-btn');
  if (btn) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        btn.style.opacity = '1';
        btn.style.pointerEvents = 'auto';
      } else {
        btn.style.opacity = '0';
        btn.style.pointerEvents = 'none';
      }
    }, { passive: true });
  }
</script>
