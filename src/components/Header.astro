---
const pathname = Astro.url.pathname;

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about/' },
  {
    label: 'Services',
    href: '/accounting-services-singapore/',
    children: [
      { label: 'Accounting Services', href: '/accounting-services-singapore/' },
      { label: 'Bookkeeping', href: '/bookkeeping-services-singapore/' },
      { label: 'Outsource Accounting', href: '/outsource-accounting-services-singapore/' },
      { label: 'Payroll', href: '/payroll-services-singapore/' },
      { label: 'Financial Statements', href: '/financial-statements-singapore/' },
    ],
  },
  { label: 'Pricing', href: '/pricing/' },
  {
    label: 'Blog',
    href: '/blog/',
    children: [
      { label: 'Bookkeeping vs Accounting', href: '/blog/bookkeeping-vs-accounting/' },
      { label: 'How to Choose an Accountant', href: '/blog/how-to-choose-accountant-sme/' },
      { label: 'Year-End Checklist', href: '/blog/year-end-accounting-checklist/' },
      { label: 'Accountant Cost', href: '/blog/accountant-cost-singapore/' },
      { label: 'Best Accounting Software', href: '/blog/best-accounting-software-singapore/' },
      { label: 'Xero vs QuickBooks', href: '/blog/xero-vs-quickbooks-singapore/' },
    ],
  },
  { label: 'Contact', href: '/contact/' },
];
---

<header class="sticky top-0 z-50 bg-navy border-b border-white/10">
  <div class="max-w-[1200px] mx-auto px-6 flex items-center justify-between h-16 lg:h-18">

    <!-- Logo -->
    <a href="/" class="flex-shrink-0" aria-label="Accountant for Small Business home">
      <img src="/favicon.png" alt="Accountant for Small Business" class="h-9 w-9 object-contain" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
      {navLinks.map((link) => (
        link.children ? (
          <div class="relative group">
            <button
              class={`flex items-center gap-1 px-3 py-2 text-sm font-medium transition-colors rounded-md
                ${pathname.startsWith(link.href) ? 'text-gold' : 'text-off-white hover:text-gold'}`}
              aria-expanded="false"
              aria-haspopup="true"
            >
              {link.label}
              <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <!-- Dropdown -->
            <div class="absolute top-full left-0 mt-1 w-56 bg-navy-panel border border-white/10 rounded-lg shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
              {link.children.map((child) => (
                <a
                  href={child.href}
                  class={`block px-4 py-2.5 text-sm transition-colors first:rounded-t-lg last:rounded-b-lg
                    ${pathname === child.href ? 'text-gold bg-white/5' : 'text-muted hover:text-gold hover:bg-white/5'}`}
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class={`px-3 py-2 text-sm font-medium transition-colors rounded-md
              ${pathname === link.href ? 'text-gold' : 'text-off-white hover:text-gold'}`}
          >
            {link.label}
          </a>
        )
      ))}
    </nav>

    <!-- Desktop CTA -->
    <div class="hidden lg:block">
      <a
        href="/contact/"
        class="inline-flex items-center px-5 py-2.5 bg-gold-btn text-navy text-sm font-semibold rounded-lg hover:bg-gold-hover transition-colors"
      >
        Get Started
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-toggle"
      class="lg:hidden flex items-center justify-center w-10 h-10 text-off-white hover:text-gold transition-colors"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden bg-navy-panel border-t border-white/10"
    aria-label="Mobile navigation"
  >
    <div class="max-w-[1200px] mx-auto px-6 py-4 flex flex-col gap-1">
      {navLinks.map((link) => (
        link.children ? (
          <div>
            <div class="px-3 py-2 text-xs font-semibold uppercase tracking-wider text-muted">{link.label}</div>
            <div class="pl-4 flex flex-col gap-1">
              {link.children.map((child) => (
                <a
                  href={child.href}
                  class={`px-3 py-2 text-sm rounded-md transition-colors
                    ${pathname === child.href ? 'text-gold' : 'text-off-white hover:text-gold'}`}
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class={`px-3 py-2.5 text-sm font-medium rounded-md transition-colors
              ${pathname === link.href ? 'text-gold' : 'text-off-white hover:text-gold'}`}
          >
            {link.label}
          </a>
        )
      ))}
      <div class="pt-4 pb-2">
        <a
          href="/contact/"
          class="block text-center px-5 py-3 bg-gold-btn text-navy text-sm font-semibold rounded-lg hover:bg-gold-hover transition-colors"
        >
          Get Started
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    hamburger?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
