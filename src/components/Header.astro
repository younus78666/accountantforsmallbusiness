---
const pathname = Astro.url.pathname;

const services = [
  { label: 'Accounting Services', href: '/accounting-services-singapore/' },
  { label: 'Bookkeeping', href: '/bookkeeping-services-singapore/' },
  { label: 'Outsource Accounting', href: '/outsource-accounting-services-singapore/' },
  { label: 'Payroll & CPF', href: '/payroll-services-singapore/' },
  { label: 'Financial Statements', href: '/financial-statements-singapore/' },
];

const blogs = [
  { label: 'IR8A Form Guide 2026', href: '/blog/ir8a-form-singapore-employer-guide/' },
  { label: 'CPF Contribution Rates 2026', href: '/blog/cpf-contribution-rates-2026-singapore/' },
  { label: 'Bookkeeping vs Accounting', href: '/blog/bookkeeping-vs-accounting/' },
  { label: 'How to Choose an Accountant', href: '/blog/how-to-choose-accountant-sme/' },
  { label: 'Year-End Checklist', href: '/blog/year-end-accounting-checklist/' },
  { label: 'Accountant Cost', href: '/blog/accountant-cost-singapore/' },
];

const tools = [
  { label: 'CPF Calculator 2026', href: '/cpf-calculator-singapore/', tag: 'Free' },
  { label: 'Employee Cost Calculator', href: '/employee-cost-calculator-singapore/', tag: 'Free' },
  { label: 'Corporate Tax Estimator', href: '/corporate-tax-calculator-singapore/', tag: 'Free' },
  { label: 'Break-Even Calculator', href: '/break-even-calculator-singapore/', tag: 'Free' },
  { label: 'Cash Flow Runway', href: '/cash-flow-runway-calculator/', tag: 'Free' },
  { label: 'Bookkeeping Cost Estimator', href: '/bookkeeping-cost-calculator-singapore/', tag: 'Free' },
  { label: 'GST Registration Calculator', href: '/gst-registration-calculator-singapore/', tag: 'Free' },
];

const toolPaths = tools.map(t => t.href);
const servicePaths = services.map(s => s.href);
---

<!-- ── STICKY HEADER (no fixed children inside) ── -->
<header class="sticky top-0 z-50 bg-[#000F22]/95 backdrop-blur-md border-b border-gray-900/80">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between py-[5px]">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group cursor-pointer select-none" aria-label="Home">
        <img src="/favicon.png" alt="Accountant for Small Business" class="h-[54px] w-[54px] object-contain shrink-0" />
        <div>
          <span class="font-serif text-sm sm:text-lg lg:text-xl font-bold tracking-tight text-[#FEFFFF] block transition-colors group-hover:text-[#DAA035] whitespace-nowrap">
            Accountant <span class="text-[#DAA035] italic">for Small Business</span>
          </span>
          <span class="hidden sm:block text-[10px] font-mono tracking-wider text-[#CBCFD8] uppercase -mt-0.5">
            Singapore &bull; Remote Excellence
          </span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1 xl:gap-2" aria-label="Main navigation">

        <a href="/" class={`px-3 py-2 text-sm font-medium rounded-md transition-colors ${pathname === '/' ? 'text-[#DAA035]' : 'text-[#CBCFD8] hover:text-[#FEFFFF]'}`}>Home</a>
        <a href="/about/" class={`px-3 py-2 text-sm font-medium rounded-md transition-colors ${pathname.startsWith('/about') ? 'text-[#DAA035]' : 'text-[#CBCFD8] hover:text-[#FEFFFF]'}`}>About</a>

        <!-- Services dropdown -->
        <div class="relative group">
          <button class={`px-3 py-2 text-sm font-medium rounded-md transition-colors flex items-center gap-1 ${servicePaths.includes(pathname) ? 'text-[#DAA035]' : 'text-[#CBCFD8] hover:text-[#FEFFFF]'}`}>
            Services
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute left-0 mt-1 w-60 bg-[#0A1628] border border-gray-900 rounded-lg shadow-xl py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            {services.map((s) => (
              <a href={s.href} class={`block px-4 py-2.5 text-sm transition-colors hover:bg-[#000F22] hover:text-[#DAA035] ${pathname === s.href ? 'text-[#DAA035] border-l-2 border-[#DAA035]' : 'text-[#CBCFD8]'}`}>{s.label}</a>
            ))}
            <div class="border-t border-gray-800 mt-1 pt-1">
              <a href="/services/" class="block px-4 py-2 text-xs text-[#DAA035] hover:bg-[#000F22] font-semibold">All Services &rarr;</a>
            </div>
          </div>
        </div>

        <a href="/pricing/" class={`px-3 py-2 text-sm font-medium rounded-md transition-colors ${pathname.startsWith('/pricing') ? 'text-[#DAA035]' : 'text-[#CBCFD8] hover:text-[#FEFFFF]'}`}>Pricing</a>

        <!-- Blog dropdown -->
        <div class="relative group">
          <button class={`px-3 py-2 text-sm font-medium rounded-md transition-colors flex items-center gap-1 ${pathname.startsWith('/blog') ? 'text-[#DAA035]' : 'text-[#CBCFD8] hover:text-[#FEFFFF]'}`}>
            Blog
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute right-0 mt-1 w-64 bg-[#0A1628] border border-gray-900 rounded-lg shadow-xl py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <a href="/blog/" class="block px-4 py-2.5 text-sm font-semibold border-b border-gray-800 text-[#DAA035] bg-[#000F22]/30 hover:bg-[#000F22]">All Articles &rarr;</a>
            {blogs.map((b) => (
              <a href={b.href} class={`block px-4 py-2 text-xs transition-colors hover:bg-[#000F22] hover:text-[#DAA035] ${pathname === b.href ? 'text-[#DAA035] font-semibold' : 'text-[#CBCFD8]'}`}>{b.label}</a>
            ))}
          </div>
        </div>

        <!-- Tools dropdown -->
        <div class="relative group">
          <button class={`px-3 py-2 text-sm font-medium rounded-md transition-colors flex items-center gap-1 ${toolPaths.includes(pathname) ? 'text-[#DAA035]' : 'text-[#CBCFD8] hover:text-[#FEFFFF]'}`}>
            Tools
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute right-0 mt-1 w-68 bg-[#0A1628] border border-gray-900 rounded-xl shadow-2xl py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <div class="px-4 py-2 border-b border-gray-800 mb-1">
              <span class="text-[10px] font-mono text-[#DAA035] uppercase tracking-widest font-bold">Free Calculators</span>
            </div>
            {tools.map((t) => (
              <a href={t.href} class={`flex items-center justify-between px-4 py-2.5 text-sm transition-colors hover:bg-[#000F22] ${pathname === t.href ? 'text-[#DAA035]' : 'text-[#CBCFD8] hover:text-[#DAA035]'}`}>
                <span>{t.label}</span>
                <span class="text-[9px] font-mono font-bold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-1.5 py-0.5 rounded ml-2">{t.tag}</span>
              </a>
            ))}
          </div>
        </div>

        <a href="/contact/" class={`px-3 py-2 text-sm font-medium rounded-md transition-colors ${pathname.startsWith('/contact') ? 'text-[#DAA035]' : 'text-[#CBCFD8] hover:text-[#FEFFFF]'}`}>Contact</a>
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden lg:block">
        <button
          data-popup="quote"
          class="bg-[#DCA33C] hover:bg-[#C8912F] text-[#000F22] font-semibold px-5 py-2.5 rounded-lg text-sm transition-all hover:scale-[1.02] flex items-center gap-1.5 shadow-md cursor-pointer"
          style="box-shadow: 0 4px 12px rgba(220,163,60,0.15);"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
          Get a Quote
        </button>
      </div>

      <!-- Mobile hamburger -->
      <button id="mobile-toggle" class="lg:hidden p-2 text-[#CBCFD8] hover:text-white rounded-md focus:outline-none" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg id="icon-menu" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>
</header>

<!-- ══ MOBILE MENU — outside header to avoid stacking context trap ══ -->
<div id="mobile-backdrop" class="lg:hidden hidden fixed inset-0 bg-[#000F22]/70 backdrop-blur-sm" style="z-index:998;"></div>

<div
  id="mobile-menu"
  class="lg:hidden hidden fixed bottom-0 left-0 right-0 bg-[#0A1628] border-t border-gray-800 rounded-t-2xl shadow-2xl"
  style="z-index:999; max-height:88vh; overflow-y:auto;"
  role="dialog"
  aria-label="Mobile navigation"
>
  <!-- Drag handle -->
  <div class="flex justify-center pt-3 pb-1 shrink-0">
    <div class="w-10 h-1 rounded-full bg-gray-700"></div>
  </div>

  <div class="px-4 pt-1 pb-10">
    <!-- Header row -->
    <div class="flex items-center justify-between mb-2 px-2 py-2">
      <span class="text-[10px] font-mono text-gray-500 uppercase tracking-widest">Navigation</span>
      <button id="mobile-menu-close" class="text-gray-500 hover:text-white transition-colors p-1.5 rounded-lg hover:bg-white/5">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Home -->
    <a href="/" class="flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-semibold text-[#FEFFFF] hover:bg-[#000F22] hover:text-[#DAA035] transition-colors">
      <svg class="w-4 h-4 text-[#DAA035] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      Home
    </a>

    <!-- About -->
    <a href="/about/" class="flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-semibold text-[#FEFFFF] hover:bg-[#000F22] hover:text-[#DAA035] transition-colors">
      <svg class="w-4 h-4 text-[#DAA035] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      About
    </a>

    <!-- Services accordion -->
    <div class="mt-1">
      <button
        class="mobile-accordion-btn w-full flex items-center justify-between px-3 py-3 rounded-xl text-sm font-semibold text-[#FEFFFF] hover:bg-[#000F22] hover:text-[#DAA035] transition-colors"
        aria-expanded="false"
        data-target="acc-services"
      >
        <span class="flex items-center gap-3">
          <svg class="w-4 h-4 text-[#DAA035] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          Services
        </span>
        <svg class="acc-chevron w-4 h-4 text-gray-500 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div id="acc-services" class="hidden px-3 pb-2 space-y-1">
        <a href="/services/" class="block px-3 py-2 text-xs font-bold text-[#DAA035] hover:bg-[#000F22] rounded-lg transition-colors">All Services &rarr;</a>
        {services.map((s) => (
          <a href={s.href} class="block px-3 py-2 text-xs text-[#CBCFD8] hover:text-[#DAA035] hover:bg-[#000F22] rounded-lg transition-colors">{s.label}</a>
        ))}
      </div>
    </div>

    <!-- Pricing direct -->
    <a href="/pricing/" class="flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-semibold text-[#FEFFFF] hover:bg-[#000F22] hover:text-[#DAA035] transition-colors">
      <svg class="w-4 h-4 text-[#DAA035] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      Pricing
    </a>

    <!-- Blog accordion -->
    <div>
      <button
        class="mobile-accordion-btn w-full flex items-center justify-between px-3 py-3 rounded-xl text-sm font-semibold text-[#FEFFFF] hover:bg-[#000F22] hover:text-[#DAA035] transition-colors"
        aria-expanded="false"
        data-target="acc-blog"
      >
        <span class="flex items-center gap-3">
          <svg class="w-4 h-4 text-[#DAA035] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          Blog
        </span>
        <svg class="acc-chevron w-4 h-4 text-gray-500 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div id="acc-blog" class="hidden px-3 pb-2 space-y-1">
        <a href="/blog/" class="block px-3 py-2 text-xs font-bold text-[#DAA035] hover:bg-[#000F22] rounded-lg transition-colors">All Articles &rarr;</a>
        {blogs.map((b) => (
          <a href={b.href} class="block px-3 py-2 text-xs text-[#CBCFD8] hover:text-[#DAA035] hover:bg-[#000F22] rounded-lg transition-colors">{b.label}</a>
        ))}
      </div>
    </div>

    <!-- Tools accordion -->
    <div>
      <button
        class="mobile-accordion-btn w-full flex items-center justify-between px-3 py-3 rounded-xl text-sm font-semibold text-[#FEFFFF] hover:bg-[#000F22] hover:text-[#DAA035] transition-colors"
        aria-expanded="false"
        data-target="acc-tools"
      >
        <span class="flex items-center gap-3">
          <svg class="w-4 h-4 text-[#DAA035] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          Free Tools
        </span>
        <svg class="acc-chevron w-4 h-4 text-gray-500 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div id="acc-tools" class="hidden px-3 pb-2 space-y-1">
        {tools.map((t) => (
          <a href={t.href} class="flex items-center justify-between px-3 py-2 rounded-lg text-xs text-[#CBCFD8] hover:text-[#DAA035] hover:bg-[#000F22] transition-colors">
            <span>{t.label}</span>
            <span class="text-[9px] font-mono font-bold text-emerald-400 bg-emerald-500/10 border border-emerald-500/20 px-1.5 py-0.5 rounded">{t.tag}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Contact direct -->
    <a href="/contact/" class="flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-semibold text-[#FEFFFF] hover:bg-[#000F22] hover:text-[#DAA035] transition-colors">
      <svg class="w-4 h-4 text-[#DAA035] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      Contact
    </a>

    <!-- CTA -->
    <div class="pt-3 border-t border-gray-800/60 mt-3">
      <button data-popup="quote" class="w-full flex items-center justify-center gap-2 bg-[#DCA33C] text-[#000F22] hover:bg-[#C8912F] font-bold py-4 px-4 rounded-xl text-sm transition-all">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
        Get a Free Quote
      </button>
    </div>
  </div>
</div>

<script>
  // ── Hamburger open/close ──────────────────────────────────────────
  const toggle   = document.getElementById('mobile-toggle');
  const menu     = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('mobile-backdrop');
  const closeBtn = document.getElementById('mobile-menu-close');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose= document.getElementById('icon-close');

  function openMenu() {
    menu?.classList.remove('hidden');
    backdrop?.classList.remove('hidden');
    menu?.classList.add('mobile-menu-open');
    iconMenu?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    backdrop?.classList.add('hidden');
    menu?.classList.remove('mobile-menu-open');
    iconMenu?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', () => {
    menu?.classList.contains('hidden') ? openMenu() : closeMenu();
  });
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  // Close on direct nav links (not accordion buttons)
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

  // ── Accordion sub-menus ───────────────────────────────────────────
  document.querySelectorAll('.mobile-accordion-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const targetId = btn.getAttribute('data-target')!;
      const panel    = document.getElementById(targetId);
      const chevron  = btn.querySelector('.acc-chevron') as HTMLElement;
      const isOpen   = !panel?.classList.contains('hidden');

      // Close all other panels first
      document.querySelectorAll('.mobile-accordion-btn').forEach(other => {
        if (other === btn) return;
        const otherId  = other.getAttribute('data-target')!;
        const otherPanel = document.getElementById(otherId);
        const otherChev  = other.querySelector('.acc-chevron') as HTMLElement;
        otherPanel?.classList.add('hidden');
        other.setAttribute('aria-expanded', 'false');
        if (otherChev) otherChev.style.transform = '';
      });

      // Toggle this panel
      if (isOpen) {
        panel?.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        if (chevron) chevron.style.transform = '';
      } else {
        panel?.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        if (chevron) chevron.style.transform = 'rotate(180deg)';
      }
    });
  });
</script>
