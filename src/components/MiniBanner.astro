---
interface Props {
  text: string;
  ctaLabel: string;
  ctaHref: string;
  variant?: 'navy' | 'light';
}

const { text, ctaLabel, ctaHref, variant = 'navy' } = Astro.props;
const dark = variant === 'navy';
---

<div class={`${dark ? 'bg-navy-panel' : 'bg-light-bg border-y border-ink/6'} py-5`}>
  <div class="section-inner flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class={`text-sm font-600 ${dark ? 'text-white/80' : 'text-ink/70'}`}>{text}</p>
    <a
      href={ctaHref}
      class={`flex-shrink-0 inline-flex items-center gap-2 px-5 py-2.5 text-sm font-700 rounded-lg transition-all duration-200
        ${dark
          ? 'bg-gold-btn text-navy hover:bg-gold-hover'
          : 'bg-navy text-white hover:bg-navy-deep'}`}
    >
      {ctaLabel}
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</div>
