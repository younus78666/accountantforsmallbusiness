---
interface Props {
  text: string;
  ctaLabel: string;
  ctaHref: string;
  variant?: 'navy' | 'light';
}

const { text, ctaLabel, ctaHref, variant = 'navy' } = Astro.props;
const dark = variant === 'navy';
---

<div class={`relative overflow-hidden ${dark ? 'bg-navy-deep' : 'bg-white border-y border-ink/6'}`}>
  <!-- Background accent line -->
  <div class={`absolute inset-0 ${dark ? 'opacity-30' : 'opacity-10'}`}>
    <div class="absolute inset-0" style="background: linear-gradient(90deg, transparent 0%, rgba(220,163,60,0.15) 50%, transparent 100%);"></div>
  </div>

  <div class="relative section-inner py-4 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <!-- Dot indicator -->
      <div class={`w-2 h-2 rounded-full flex-shrink-0 ${dark ? 'bg-gold-btn' : 'bg-navy'}`}
           style={dark ? 'box-shadow: 0 0 8px rgba(220,163,60,0.5);' : ''}
      ></div>
      <p class={`text-sm font-500 ${dark ? 'text-white/75' : 'text-ink/65'}`}>{text}</p>
    </div>
    <a
      href={ctaHref}
      class={`flex-shrink-0 inline-flex items-center gap-2 px-5 py-2.5 text-sm font-700 rounded-xl transition-all duration-200 hover:-translate-y-0.5
        ${dark
          ? 'bg-gold-btn text-navy hover:bg-gold-hover hover:shadow-md hover:shadow-gold/20'
          : 'bg-navy text-white hover:bg-navy-deep hover:shadow-md hover:shadow-navy/20'}`}
    >
      {ctaLabel}
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</div>
