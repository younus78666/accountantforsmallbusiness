---
interface Props {
  title: string;
  blurb: string;
  href: string;
  dark?: boolean;
  iconPath?: string;   /* SVG path d= */
}

const { title, blurb, href, dark = false, iconPath } = Astro.props;
---

<a
  href={href}
  class={`group block rounded-2xl p-7 border transition-all duration-200 hover:-translate-y-1.5
    ${dark
      ? 'bg-navy-panel border-white/6 hover:border-gold/25'
      : 'bg-white border-ink/6 hover:border-gold/30 card-shadow hover:card-shadow-lg'
    }`}
>
  <!-- Icon box -->
  <div class="relative mb-6">
    <div
      class="icon-box w-14 h-14 rounded-xl transition-all duration-300 group-hover:scale-110"
      style="animation: float 3.5s ease-in-out infinite;"
    >
      {iconPath ? (
        <svg class="w-7 h-7 text-gold-btn" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
        </svg>
      ) : (
        <svg class="w-7 h-7 text-gold-btn" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
        </svg>
      )}
    </div>
    <!-- Glow behind icon -->
    <div class="absolute top-1 left-1 w-12 h-12 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"
         style="background: rgba(220,163,60,0.18); filter: blur(12px);"></div>
  </div>

  <h3 class={`text-base font-700 mb-2 transition-colors duration-200 group-hover:text-gold-btn
    ${dark ? 'text-white' : 'text-ink'}`}>
    {title}
  </h3>
  <p class={`text-sm leading-relaxed mb-5 font-400 ${dark ? 'text-white/45' : 'text-ink/50'}`}>
    {blurb}
  </p>
  <span class={`inline-flex items-center gap-1.5 text-xs font-700 uppercase tracking-widest transition-all duration-200
    ${dark ? 'text-white/25 group-hover:text-gold-btn' : 'text-ink/25 group-hover:text-gold-btn'}`}>
    Learn more
    <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </span>
</a>
