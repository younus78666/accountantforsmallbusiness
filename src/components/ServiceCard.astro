---
interface Props {
  title: string;
  blurb: string;
  href: string;
  dark?: boolean;
}

const { title, blurb, href, dark = false } = Astro.props;
---

<a
  href={href}
  class={`group block rounded-2xl p-7 border transition-all duration-200 hover:-translate-y-1
    ${dark
      ? 'bg-navy-panel border-white/8 hover:border-gold/30 hover:bg-navy-panel'
      : 'bg-white border-ink/6 hover:border-gold/30 card-shadow hover:card-shadow-lg'
    }`}
>
  <!-- Gold accent bar -->
  <div class="gold-bar mb-5 transition-all duration-200 group-hover:w-12"></div>

  <h3 class={`text-base font-700 mb-2 transition-colors duration-200 group-hover:text-gold-btn
    ${dark ? 'text-white' : 'text-ink'}`}>
    {title}
  </h3>
  <p class={`text-sm leading-relaxed mb-5 ${dark ? 'text-white/50' : 'text-ink/55'}`}>
    {blurb}
  </p>
  <span class={`inline-flex items-center gap-1.5 text-xs font-700 uppercase tracking-wider transition-colors duration-200
    ${dark ? 'text-white/30 group-hover:text-gold-btn' : 'text-ink/30 group-hover:text-gold-btn'}`}>
    Learn more
    <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </span>
</a>
