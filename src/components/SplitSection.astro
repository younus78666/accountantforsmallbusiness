---
interface Props {
  eyebrow?: string;
  heading: string;
  imageAlt: string;
  imageSrc?: string;
  placeholderLabel?: string;
  placeholderIconPath?: string;   /* SVG path d= attribute */
  flip?: boolean;
  variant?: 'white' | 'light' | 'navy' | 'gold';
}

const {
  eyebrow, heading, imageAlt, imageSrc,
  placeholderLabel = 'Image placeholder',
  placeholderIconPath,
  flip = false,
  variant = 'white',
} = Astro.props;

const bgMap = { white: 'bg-white', light: 'bg-light-bg', navy: 'bg-navy', gold: 'bg-gold-btn' };
const bg = bgMap[variant];
const dark = variant === 'navy';
const goldBg = variant === 'gold';

const headingColor = dark ? 'text-white' : goldBg ? 'text-navy' : 'text-ink';
const bodyColor    = dark ? 'text-white/60' : goldBg ? 'text-navy/75' : 'text-ink/65';
---

<section class={`${bg} py-20 lg:py-28 overflow-hidden`}>
  <div class="section-inner">
    <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center
      ${flip ? 'lg:[&>*:first-child]:order-2 lg:[&>*:last-child]:order-1' : ''}`}>

      <!-- Text column -->
      <div>
        {eyebrow && (
          <div class={`mb-5 ${dark ? 'eyebrow-dark' : 'eyebrow-light'}`}>{eyebrow}</div>
        )}
        <h2 class={`text-3xl lg:text-[2.6rem] mb-6 ${headingColor}`}>
          {heading}
        </h2>
        <div class={`space-y-4 text-base leading-relaxed ${bodyColor}`}>
          <slot />
        </div>
      </div>

      <!-- Image / Placeholder column -->
      <div class="relative">
        {imageSrc ? (
          <img
            src={imageSrc}
            alt={imageAlt}
            class="w-full h-[440px] lg:h-[520px] object-cover rounded-3xl"
            loading="lazy"
            style="box-shadow: 0 32px 80px rgba(0,15,34,0.20);"
          />
        ) : (
          /* ── Branded placeholder panel ── */
          <div
            class="relative w-full h-[400px] lg:h-[480px] rounded-3xl overflow-hidden bg-navy-panel"
            style="box-shadow: 0 32px 80px rgba(0,15,34,0.22);"
          >
            <!-- Mesh grid -->
            <svg class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg" style="opacity:0.07;">
              <defs>
                <pattern id={`g-${heading.slice(0,6).replace(/\s/g,'')}`} width="48" height="48" patternUnits="userSpaceOnUse">
                  <circle cx="24" cy="24" r="1" fill="#DAA035"/>
                  <path d="M 48 0 L 0 0 0 48" fill="none" stroke="#DAA035" stroke-width="0.5"/>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill={`url(#g-${heading.slice(0,6).replace(/\s/g,'')})`} />
            </svg>

            <!-- Radial glow -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-64 h-64 rounded-full" style="background: radial-gradient(circle, rgba(220,163,60,0.12) 0%, transparent 70%); animation: pulse-glow 4s ease-in-out infinite;"></div>
            </div>

            <!-- Corner marks -->
            {['top-4 left-4 border-t-2 border-l-2', 'top-4 right-4 border-t-2 border-r-2', 'bottom-4 left-4 border-b-2 border-l-2', 'bottom-4 right-4 border-b-2 border-r-2'].map(cls => (
              <span class={`absolute w-6 h-6 ${cls} border-gold/40`}></span>
            ))}

            <!-- Icon + label -->
            <div class="relative flex flex-col items-center justify-center h-full gap-5 px-12">
              {placeholderIconPath && (
                <div class="icon-box w-20 h-20 rounded-2xl" style="animation: float 3.5s ease-in-out infinite;">
                  <svg class="w-10 h-10 text-gold-btn" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={placeholderIconPath} />
                  </svg>
                </div>
              )}
              <div class="text-center">
                <p class="text-gold/50 text-[0.6rem] uppercase tracking-widest font-700 mb-1.5">Image Placeholder</p>
                <p class="text-white/25 text-xs leading-relaxed max-w-[200px] mx-auto">{placeholderLabel}</p>
              </div>
            </div>
          </div>
        )}

        <!-- Floating glow blob -->
        <div class="absolute -bottom-12 -right-12 w-48 h-48 rounded-full pointer-events-none"
             style="background: radial-gradient(circle, rgba(220,163,60,0.12) 0%, transparent 70%); filter: blur(24px);"></div>
      </div>
    </div>
  </div>
</section>
