---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
  dark?: boolean;
}

const { stats, dark = false } = Astro.props;
---

<div
  class={`py-12 lg:py-16 ${dark ? 'bg-navy-deep' : 'bg-light-bg'}`}
>
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
      {stats.map((stat) => (
        <div>
          <div
            class="text-4xl lg:text-5xl font-bold mb-1 gold-gradient"
            style="font-family: var(--font-serif);"
          >
            {stat.value}
          </div>
          <div class={`text-sm ${dark ? 'text-muted' : 'text-ink/60'}`}>{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</div>
