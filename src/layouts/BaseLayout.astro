---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingButtons from '../components/FloatingButtons.astro';
import FormPopup from '../islands/FormPopup';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schemaJsonLd?: string;
  preloadHero?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = '/hero-bg.png',
  schemaJsonLd,
  preloadHero = true,
} = Astro.props;

const siteUrl = 'https://accountantforsmallbusiness.com';
const canonicalUrl = canonical ?? siteUrl + Astro.url.pathname;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : siteUrl + ogImage;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2NQ4N3KMXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-2NQ4N3KMXX');
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- DNS prefetch for external services -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="dns-prefetch" href="https://formsubmit.co" />

    <!-- Google Fonts: preconnect then load with display=swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Geist:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Geist:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Geist:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" /></noscript>

    <!-- LCP: preload hero background image on pages that use it -->
    {preloadHero && <link rel="preload" as="image" href="/hero-bg.png" fetchpriority="high" />}

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#000F22" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Accountant for Small Business" />
    <meta property="og:locale" content="en_SG" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Accountant for Small Business, Singapore SME accounting services" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Global site-wide schema (Organization + Person) -->
    <script type="application/ld+json">{"@context":"https://schema.org","@graph":[{"@type":"Organization","@id":"https://accountantforsmallbusiness.com/#org","name":"accountantforsmallbusiness.com","url":"https://accountantforsmallbusiness.com/","founder":{"@id":"https://accountantforsmallbusiness.com/#mehdi"},"areaServed":{"@type":"Country","name":"Singapore"},"knowsAbout":["Bookkeeping","Payroll","Financial statements","Management reporting","Xero","QuickBooks Online"]},{"@type":"Person","@id":"https://accountantforsmallbusiness.com/#mehdi","name":"Mehdi Javed","jobTitle":"Financial Controller","worksFor":{"@id":"https://accountantforsmallbusiness.com/#org"},"sameAs":["https://www.linkedin.com/in/mehdij/"]}]}</script>

    <!-- Per-page JSON-LD Schema -->
    {schemaJsonLd && <Fragment set:html={schemaJsonLd} />}
  </head>
  <body class="bg-[#000F22] text-[#CBCFD8] antialiased selection:bg-[#DAA035]/30 selection:text-[#DAA035]">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <FloatingButtons />
    <FormPopup client:idle />
  </body>
</html>
