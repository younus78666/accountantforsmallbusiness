---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  schemaJsonLd?: string;
  headline: string;
  intro: string;
  date?: string;           // human-readable display date
  datePublished?: string;  // ISO 8601 for schema
  dateModified?: string;   // ISO 8601 for schema
  readTime?: string;
  ctaLabel: string;
  ctaHref: string;
  relatedPosts?: { title: string; href: string; tag: string }[];
}

const {
  title, description, schemaJsonLd,
  headline, intro,
  date = 'May 2026',
  datePublished = '2026-05-31',
  dateModified = '2026-05-31',
  readTime = '4 min read',
  ctaLabel, ctaHref,
  relatedPosts = [],
} = Astro.props;

const siteUrl = 'https://accountantforsmallbusiness.com';
const canonicalUrl = siteUrl + Astro.url.pathname;
const ogImage = `${siteUrl}/hero-bg.png`;
---

<BaseLayout {title} {description} schemaJsonLd={schemaJsonLd}>
  <!-- Override og:type to article for blog posts -->
  <meta property="og:type" content="article" slot="head" />
  <meta property="article:published_time" content={datePublished} slot="head" />
  <meta property="article:modified_time" content={dateModified} slot="head" />
  <meta property="article:author" content="https://www.linkedin.com/in/mehdij/" slot="head" />
  <meta property="article:section" content="Accounting" slot="head" />

  <!-- ════ ARTICLE HERO ════ -->
  <section class="relative overflow-hidden bg-gradient-to-b from-[#000F22] to-[#0A1628] pt-20 pb-14 border-b border-gray-900">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(220,163,60,0.02)_0%,transparent_70%)] pointer-events-none"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-gray-500 font-mono mb-6 flex-wrap">
        <a href="/" class="hover:text-[#DAA035] transition-colors">Home</a>
        <span>/</span>
        <a href="/blog/" class="hover:text-[#DAA035] transition-colors">Blog</a>
        <span>/</span>
        <span class="text-[#DAA035]">{headline}</span>
      </nav>

      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex items-center gap-1.5 text-xs font-mono font-bold text-amber-600 uppercase tracking-wider">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
          Financial Briefing
        </span>
        <span class="text-gray-700 text-xs">·</span>
        <time datetime={datePublished} class="text-xs text-gray-500 font-mono">{date}</time>
        <span class="text-gray-700 text-xs">·</span>
        <span class="text-xs text-gray-500 font-mono">{readTime}</span>
      </div>

      <h1 class="text-3xl sm:text-4xl md:text-5xl font-serif text-[#FEFFFF] font-bold tracking-tight leading-tight mb-6">
        {headline}
      </h1>

      <!-- Intro -->
      <p class="text-sm sm:text-base text-[#CBCFD8] leading-relaxed mb-6 max-w-2xl">{intro}</p>

      <!-- Author -->
      <div class="flex items-center gap-3 pt-4 border-t border-gray-800/60">
        <div class="w-10 h-10 rounded-full overflow-hidden border border-[#DAA035]/30 shrink-0">
          <img src="/Mehdi Jawed - Accountant For Small Businesses.png" alt="Mehdi Javed, Financial Controller" class="w-full h-full object-cover object-top" />
        </div>
        <div>
          <p class="text-xs font-bold text-white">Mehdi Javed</p>
          <p class="text-[10px] text-gray-500 font-mono">Financial Controller · accountantforsmallbusiness.com</p>
        </div>
        <a href="https://www.linkedin.com/in/mehdij/" target="_blank" rel="noopener noreferrer" class="ml-auto flex items-center gap-1.5 text-[10px] font-mono text-[#DAA035] hover:underline">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
    </div>
  </section>

  <!-- ════ ARTICLE BODY ════ -->
  <article class="bg-[#F8FAFC]" itemscope itemtype="https://schema.org/Article">
    <meta itemprop="headline" content={headline} />
    <meta itemprop="description" content={description} />
    <meta itemprop="datePublished" content={datePublished} />
    <meta itemprop="dateModified" content={dateModified} />
    <meta itemprop="image" content={ogImage} />
    <meta itemprop="inLanguage" content="en-SG" />
    <meta itemprop="url" content={canonicalUrl} />
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <slot />
    </div>
  </article>

  <!-- ════ ARTICLE CTA ════ -->
  <section class="bg-[#FFFDF2] py-16 border-t border-amber-100 text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-5">
      <h3 class="text-2xl sm:text-3xl font-sans text-amber-950 font-extrabold tracking-tight">{ctaLabel}</h3>
      <a href={ctaHref} class="inline-block bg-[#DCA33C] hover:bg-[#C8912F] text-[#000F22] font-mono text-xs font-bold uppercase tracking-widest px-8 py-4 rounded-xl shadow-lg hover:shadow-xl transition-all">
        Read more &nbsp;&rarr;
      </a>
    </div>
  </section>

  <!-- ════ RELATED POSTS ════ -->
  {relatedPosts.length > 0 && (
    <section class="bg-[#000F22] py-16 border-t border-gray-950">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h3 class="text-sm font-mono text-[#DAA035] uppercase tracking-widest font-bold mb-6">More from the blog</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {relatedPosts.map((post) => (
            <a href={post.href} class="block bg-[#0A1628] border border-gray-800 hover:border-[#DAA035]/30 rounded-xl p-5 transition-all group">
              <span class="block text-[10px] font-mono text-[#DAA035] uppercase tracking-wider mb-2">{post.tag}</span>
              <h4 class="text-sm font-semibold text-white leading-snug group-hover:text-[#DAA035] transition-colors">{post.title}</h4>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</BaseLayout>
