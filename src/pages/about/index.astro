---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'About Mehdi Javed | Accountant for Small Business Singapore';
const description = 'Meet Mehdi Javed, the Financial Controller behind accountantforsmallbusiness.com. 15+ years keeping SME books clean, serving Singapore businesses remotely.';

const schemaJsonLd = `<script type="application/ld+json">
{"@context":"https://schema.org","@graph":[{"@type":"AboutPage","@id":"https://accountantforsmallbusiness.com/about/#aboutpage","url":"https://accountantforsmallbusiness.com/about/","name":"About accountantforsmallbusiness.com","mainEntity":{"@id":"https://accountantforsmallbusiness.com/#mehdi"}},{"@type":"Person","@id":"https://accountantforsmallbusiness.com/#mehdi","name":"Mehdi Javed","jobTitle":"Financial Controller","worksFor":{"@id":"https://accountantforsmallbusiness.com/#org"},"sameAs":["https://www.linkedin.com/in/mehdij/"],"alumniOf":{"@type":"CollegeOrUniversity","name":"University of Karachi"},"knowsAbout":["Bookkeeping","Month-end close","Financial statements","Accounts payable and receivable","Payroll","Management reporting","QuickBooks Online","Xero","SFRS"],"description":"Financial Controller with 15+ years in accounting and finance for SMEs and logistics businesses across Pakistan, the UAE and the United States. Serves Singapore small businesses remotely."},{"@type":"Organization","@id":"https://accountantforsmallbusiness.com/#org","name":"accountantforsmallbusiness.com","founder":{"@id":"https://accountantforsmallbusiness.com/#mehdi"},"areaServed":{"@type":"Country","name":"Singapore"}},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://accountantforsmallbusiness.com/"},{"@type":"ListItem","position":2,"name":"About","item":"https://accountantforsmallbusiness.com/about/"}]}]}
<\/script>`;

const glance = [
  { label: 'Role', value: 'Financial Controller / fractional accountant' },
  { label: 'Experience', value: '15+ years (PK, UAE, US)' },
  { label: 'Education', value: 'Executive MBA, Accounting & Finance (University of Karachi); B.Com.' },
  { label: 'Software', value: 'QuickBooks Online, Xero, advanced Excel, ERP systems' },
  { label: 'Specialisms', value: 'Month-end close, financial statements, AP/AR, payroll, management reporting' },
  { label: 'Results', value: '28% faster financial close, 10% cost reduction' },
  { label: 'Model', value: 'Remote, serving Singapore SMEs from Karachi' },
  { label: 'Not offered', value: 'GST filing, corporate tax filing, company incorporation (handled by your tax agent)' },
];
---

<BaseLayout {title} {description} schemaJsonLd={schemaJsonLd}>

<!-- ════ HERO ════ -->
<section class="relative overflow-hidden bg-gradient-to-b from-[#000F22] to-[#0A1628] pt-20 pb-16 border-b border-gray-900 text-center">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(220,163,60,0.02)_0%,transparent_70%)] pointer-events-none"></div>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 space-y-6">
    <nav class="flex items-center justify-center gap-2 text-xs text-gray-500 font-mono mb-2">
      <a href="/" class="hover:text-[#DAA035] transition-colors">Home</a>
      <span>/</span>
      <span class="text-[#DAA035]">About</span>
    </nav>
    <span class="inline-block py-1.5 px-3 rounded-full bg-[#DAA035]/15 border border-[#DAA035]/30 text-[#DAA035] text-xs font-mono uppercase tracking-widest">
      One accountant. One point of contact. Always.
    </span>
    <h1 class="text-4xl sm:text-5xl font-serif text-[#FEFFFF] font-bold tracking-tight leading-tight">
      About accountantforsmallbusiness.com
    </h1>
    <p class="text-sm sm:text-base text-[#CBCFD8] max-w-2xl mx-auto leading-relaxed">
      One qualified accountant, not a faceless firm. I keep small business books clean and current, so you always know where your numbers stand.
    </p>
    <div class="flex flex-wrap justify-center gap-4 pt-2">
      <a href="/contact/" class="bg-[#DCA33C] hover:bg-[#C8912F] text-[#000F22] font-semibold px-8 py-3.5 rounded-lg text-sm transition-all hover:scale-[1.01] shadow-lg shadow-[#DCA33C]/10">
        Book a free consultation
      </a>
      <a href="/accounting-services-singapore/" class="bg-transparent border border-[#DAA035] hover:bg-[#DAA035] hover:text-[#000F22] text-[#DAA035] font-semibold px-8 py-3.5 rounded-lg text-sm transition-all">
        View services
      </a>
    </div>
  </div>
</section>

<!-- ════ SPLIT 1: Who is behind it? (light F8FAFC, text left) ════ -->
<section class="bg-[#F8FAFC] text-[#000F22] py-20 border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <div class="lg:col-span-7 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">THE PERSON BEHIND IT</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">
          Who is behind accountantforsmallbusiness.com?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#F2F4F7] text-[#000F22] shadow-sm">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#000F22]">
            The service is run by Mehdi Javed, a Financial Controller with more than 15 years in accounting and finance. He works directly with each client, so the person who keeps your books is the same person who knows your business, not a rotating call centre or an anonymous assigned clerk.
          </p>
        </div>
        <p class="text-sm sm:text-base leading-relaxed text-gray-700 font-sans">
          Most accounting firms hide behind 'our team'. You sign up, hand over your records, and never quite know who is doing the work. This service is the opposite. You deal with one named, qualified accountant from the first call onward.
        </p>
        <div class="flex flex-wrap gap-3 pt-2">
          {[
            { label: '15+ Years experience' },
            { label: 'Financial Controller' },
            { label: 'Executive MBA' },
            { label: 'Xero & QuickBooks' },
          ].map((badge) => (
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-gray-200 rounded-full text-xs font-semibold text-[#000F22] shadow-sm">
              <span class="w-1.5 h-1.5 rounded-full bg-[#DAA035]"></span>
              {badge.label}
            </span>
          ))}
        </div>
      </div>

      <!-- Visual: profile placeholder -->
      <div class="lg:col-span-5 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <!-- Mehdi Javed photo -->
          <div class="flex flex-col items-center gap-5">
            <div class="w-36 h-36 rounded-full overflow-hidden border-2 border-[#DAA035]/40 shadow-xl" style="box-shadow: 0 0 24px rgba(220,163,60,0.15);">
              <img
                src="/Mehdi Jawed - Accountant For Small Businesses.png"
                alt="Mehdi Javed, Financial Controller"
                class="w-full h-full object-cover object-top"
              />
            </div>
            <div class="text-center">
              <h3 class="text-xl font-bold text-white">Mehdi Javed</h3>
              <p class="text-sm text-[#DAA035] font-mono">Financial Controller</p>
              <p class="text-xs text-gray-500 mt-1">Karachi &rarr; Singapore</p>
            </div>
          </div>

          <div class="space-y-3 mt-6 font-sans">
            {[
              { icon: 'M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z', label: 'Executive MBA, Accounting & Finance', href: null },
              { icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', label: '15+ years across PK, UAE & US', href: null },
              { icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z', label: 'Serving Singapore SMEs remotely', href: null },
            ].map((item) => (
              <div class="flex items-center gap-3 p-3 bg-[#020B16] rounded-xl border border-gray-800">
                <svg class="w-4 h-4 text-[#DAA035] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={item.icon}/>
                </svg>
                <span class="text-xs text-[#CBCFD8]">{item.label}</span>
              </div>
            ))}
            <!-- LinkedIn link row -->
            <a href="https://www.linkedin.com/in/mehdij/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 bg-[#020B16] rounded-xl border border-gray-800 hover:border-[#DAA035]/40 transition-colors group">
              <svg class="w-4 h-4 text-[#DAA035] shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              <span class="text-xs text-[#CBCFD8] group-hover:text-[#DAA035] transition-colors">Connect on LinkedIn</span>
            </a>
          </div>
          <p class="text-[10px] text-gray-600 font-mono text-center pt-4 border-t border-gray-800 mt-4">*One accountant. Your accountant.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ SPLIT 2: Qualifications & track record (dark 0A1B30, visual left) ════ -->
<section class="bg-[#0A1B30] text-[#CBCFD8] py-20 border-b border-gray-950/45">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <!-- Visual: milestones + experience -->
      <div class="lg:col-span-5 order-2 lg:order-1 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="border-b border-gray-800 pb-3 mb-6 font-mono text-center">
              <span class="text-xs text-[#DAA035] uppercase font-bold tracking-wider">Operational Milestones</span>
            </div>
            <div class="space-y-4">
              {[
                { value: '28% Faster', label: 'Financial Month-End Close', width: '72%', grad: 'from-[#DCA33C] to-[#DAA035]' },
                { value: '10% Less', label: 'Total Operating Overhead Cost', width: '90%', grad: 'from-emerald-600 to-emerald-400' },
                { value: '15+ Years', label: 'Multi-Entity SME Experience', width: '100%', grad: 'from-blue-500 to-cyan-400' },
                { value: '5+ Years', label: 'Remote US Business Support', width: '80%', grad: 'from-purple-500 to-violet-400' },
              ].map((stat) => (
                <div class="bg-[#000F22]/50 p-4 rounded-xl border border-gray-900">
                  <span class="block text-2xl font-black text-[#DAA035] tracking-tight">{stat.value}</span>
                  <span class="block text-[11px] uppercase tracking-wider text-[#FEFFFF] font-mono mt-1">{stat.label}</span>
                  <div class="w-full bg-gray-950 h-1 rounded-full mt-2.5 overflow-hidden">
                    <div class={`bg-gradient-to-r ${stat.grad} h-full rounded-full`} style={`width:${stat.width}`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="mt-4 space-y-2">
            <p class="text-[10px] text-gray-600 font-mono uppercase tracking-wider text-center border-t border-gray-800 pt-3">Experience across</p>
            <div class="flex justify-center gap-3 flex-wrap">
              {['Sealine Services', 'ARS Logistics', 'Al Rais FZC', 'Rags2000'].map(co => (
                <span class="text-[10px] font-mono text-gray-500 bg-gray-900 px-2 py-0.5 rounded border border-gray-800">{co}</span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">QUALIFICATIONS & TRACK RECORD</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#FEFFFF] font-extrabold tracking-tight">
          What are Mehdi's qualifications and track record?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#0A1628] text-[#FEFFFF] shadow-inner">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#FEFFFF]">
            Mehdi holds an Executive MBA in Accounting and Finance from the University of Karachi and has spent 15+ years running finance operations for SMEs and logistics businesses across Pakistan, the UAE and the United States. His work has delivered measurable results, including a 28% faster financial close and 10% cost reduction through better process and reporting.
          </p>
        </div>
        <div class="space-y-4 text-sm sm:text-base leading-relaxed text-[#CBCFD8] font-sans">
          <p>As Financial Controller at Sealine Services, he leads month-end close, reporting, reconciliations, budgeting and audit readiness for a busy freight and customs operation.</p>
          <p>Across Sealine Services USA, ARS Logistic Services, Al Rais FZC, Al Awan Transport and Rags2000, he has designed accounting systems, built AP/AR and payroll workflows, and managed multi-currency books for US and UAE businesses.</p>
          <p>He works hands-on in QuickBooks Online and Xero, and has 5+ years supporting US-based businesses remotely, so distance has never been a barrier to accurate books.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ SPLIT 3: Remote accounting (light EDF0F5, text left) ════ -->
<section class="bg-[#EDF0F5] text-[#000F22] py-20 border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <div class="lg:col-span-7 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">REMOTE DELIVERY</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">
          How does a remote accountant work for a Singapore business?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#F2F4F7] text-[#000F22] shadow-sm">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#000F22]">
            It works exactly like an in-house accountant, just delivered over the cloud. Mehdi is based in Karachi and serves Singapore small businesses remotely through Xero and QuickBooks Online. You connect your bank and share records online, he keeps the books current, and you get reports and statements without anyone needing to be in the same room.
          </p>
        </div>
        <div class="space-y-4 text-sm sm:text-base leading-relaxed text-gray-700 font-sans">
          <p>Cloud accounting removed the need for a local desk years ago. Your data lives in Xero or QuickBooks, reconciliation happens online, and you review everything from wherever you are.</p>
          <p>Being remote is also why the fees are lower. There's no Singapore office overhead to pass on to you, so you get experienced, qualified work at a price an in-house hire could never match.</p>
        </div>
      </div>

      <!-- Visual: remote pipeline -->
      <div class="lg:col-span-5 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="text-center pb-3 border-b border-gray-800 font-mono mb-6">
              <span class="text-xs text-[#DAA035] uppercase font-bold tracking-widest block">Karachi &rarr; Singapore</span>
              <span class="text-[11px] text-gray-400 mt-0.5 block">Encrypted cloud delivery</span>
            </div>
            <!-- Timeline of locations -->
            <div class="relative pl-4 border-l border-[#DAA035]/30 space-y-5 font-sans">
              {[
                { step: '1', title: 'You share records', sub: 'Connect bank feed or upload via Xero / QuickBooks', flag: '🇸🇬' },
                { step: '2', title: 'Mehdi does the work', sub: 'Reconciles, posts and reviews everything in Karachi', flag: '🇵🇰' },
                { step: '3', title: 'You get reports', sub: 'Clean books + statements delivered online', flag: '🇸🇬' },
              ].map((item) => (
                <div class="flex items-start gap-4 relative z-10">
                  <div class="w-7 h-7 rounded-full bg-[#DAA035]/10 text-[#DAA035] border border-[#DAA035]/35 font-mono text-xs font-bold flex items-center justify-center shrink-0 -ml-[1.875rem]">{item.step}</div>
                  <div>
                    <div class="flex items-center gap-2">
                      <span class="text-xs font-bold text-white">{item.title}</span>
                      <span class="text-sm">{item.flag}</span>
                    </div>
                    <span class="block text-[11px] text-[#CBCFD8] leading-snug">{item.sub}</span>
                  </div>
                </div>
              ))}
            </div>
            <div class="mt-5 flex items-center justify-center gap-2">
              <div class="w-2 h-2 rounded-full bg-emerald-500"></div>
              <span class="text-[10px] text-gray-500 font-mono uppercase tracking-wider">256-bit SSL encrypted</span>
            </div>
          </div>
          <div class="mt-4 p-3 bg-[#DAA035]/10 rounded-xl border border-[#DAA035]/25 text-center">
            <p class="text-[10px] font-mono text-[#DAA035] font-bold uppercase">No office overhead</p>
            <p class="text-xs text-gray-400 mt-0.5">Lower fees because there is no Singapore desk to maintain</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ SPLIT 4: Scope, what Mehdi does vs tax agent (dark 061224) ════ -->
<section class="bg-[#061224] text-[#CBCFD8] py-20 border-b border-gray-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <!-- Visual: scope split -->
      <div class="lg:col-span-5 order-2 lg:order-1 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="border-b border-gray-800 pb-3 mb-6 font-mono text-center">
              <span class="text-xs text-[#DAA035] uppercase font-bold tracking-wider">Clear scope split</span>
            </div>
            <div class="space-y-3 font-sans">
              <div class="p-4 bg-[#DAA035]/10 rounded-xl border border-[#DAA035]/25 space-y-2">
                <span class="block text-[10px] font-mono text-[#DAA035] uppercase font-bold">Mehdi handles</span>
                <ul class="space-y-1 text-[11px] text-gray-300">
                  {['Bookkeeping & bank reconciliation', 'Financial statements (SFRS)', 'Payroll with CPF & payslips', 'Accounts payable & receivable', 'Monthly management reporting'].map(item => (
                    <li class="flex gap-1.5"><span class="text-emerald-400 shrink-0">&#10003;</span>{item}</li>
                  ))}
                </ul>
              </div>
              <div class="p-4 bg-[#020B16] rounded-xl border border-gray-800 space-y-2">
                <span class="block text-[10px] font-mono text-gray-500 uppercase font-bold">Your tax agent handles</span>
                <ul class="space-y-1 text-[11px] text-gray-500">
                  {['GST filing (Form F5)', 'Corporate income tax filing', 'Company incorporation', 'Statutory audit (if required)'].map(item => (
                    <li class="flex gap-1.5"><span class="text-gray-600 shrink-0">&#10145;</span>{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
          <p class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-4">*Clean books = your tax agent files accurately and on time</p>
        </div>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">SCOPE CLARITY</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#FEFFFF] font-extrabold tracking-tight">
          What do you do, and what do you leave to a tax agent?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#0A1628] text-[#FEFFFF] shadow-inner">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#FEFFFF]">
            Mehdi handles the accounting: bookkeeping, bank reconciliation, financial statements, payroll with CPF, accounts payable and receivable, and monthly management reporting. He does not file your GST or corporate tax. Those are filed by your licensed Singapore tax agent, and clean, ready books are exactly what lets them file accurately and on time.
          </p>
        </div>
        <div class="space-y-4 text-sm sm:text-base leading-relaxed text-[#CBCFD8] font-sans">
          <p>This boundary is deliberate and honest. Singapore tax and GST filing needs local licensing and registration. So the setup is simple. Mehdi keeps your books tax-ready, and your tax agent files them. You get the best of both, without paying one provider to do work outside their lane.</p>
        </div>
        <a href="/accounting-services-singapore/" class="text-xs font-mono text-[#DAA035] hover:underline font-bold">
          See the full list on the accounting services page &rarr;
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY TRUST (warm FFFDF2) ════ -->
<section class="bg-[#FFFDF2] text-[#000F22] py-20 border-b border-amber-100">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8">
    <div class="text-center space-y-3">
      <span class="text-xs font-mono text-amber-700 uppercase tracking-widest font-bold block">TRUST & TRANSPARENCY</span>
      <h2 class="text-3xl sm:text-4xl font-sans text-amber-950 font-extrabold tracking-tight">Why should a small business trust you with their books?</h2>
    </div>
    <div class="p-8 border-l-[3px] border-[#DAA035] rounded-r-2xl bg-white shadow-sm">
      <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#000F22]">
        Because you get a named, qualified Financial Controller who has done this for 15+ years, works in your software, and tells you plainly what he does and doesn't do. No hidden tiers, no faceless team, no overclaiming. Just accurate books from someone who treats your numbers the way he treats his own clients' across three countries.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
      {[
        { icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z', title: 'Named accountant', desc: 'You know exactly who keeps your books, from the first call to every month after.' },
