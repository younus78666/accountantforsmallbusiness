---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Accounting Services for Small Business Singapore | AFSB';
const description = 'Affordable accounting services for small businesses in Singapore. See what\'s included, what drives the price, and get a fixed monthly fee with no hidden add-ons.';

const schemaJsonLd = `<script type="application/ld+json">
{"@context":"https://schema.org","@graph":[{"@type":["Service","AccountingService"],"@id":"https://accountantforsmallbusiness.com/accounting-services-singapore/#service","name":"Accounting Services for Small Business Singapore","serviceType":"Small business accounting","provider":{"@id":"https://accountantforsmallbusiness.com/#org"},"areaServed":{"@type":"Country","name":"Singapore"},"description":"Fixed-fee accounting services for Singapore small businesses: bookkeeping, financial statements, payroll and management reporting, delivered remotely.","offers":{"@type":"Offer","priceCurrency":"SGD","priceSpecification":{"@type":"PriceSpecification","minPrice":"90","maxPrice":"800","priceCurrency":"SGD"}},"hasOfferCatalog":{"@type":"OfferCatalog","name":"Accounting services","itemListElement":[{"@type":"Offer","itemOffered":{"@type":"Service","name":"Bookkeeping"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Financial statements"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Management reporting"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Accounts payable and receivable"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Payroll and CPF"}}]}},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Do I need monthly or annual bookkeeping?","acceptedAnswer":{"@type":"Answer","text":"If you are GST-registered or want regular reports, choose monthly. Low-volume businesses needing only year-end compliance can start annual and upgrade later."}},{"@type":"Question","name":"Do you handle GST and corporate tax filing?","acceptedAnswer":{"@type":"Answer","text":"No. We focus on accounting: bookkeeping, financial statements, payroll and management reporting. We keep your books clean and statements ready so your tax agent can file accurately."}},{"@type":"Question","name":"Will I get a dedicated accountant?","acceptedAnswer":{"@type":"Answer","text":"Yes. You work with one named accountant who knows your business, not a different person each time."}},{"@type":"Question","name":"Which accounting software do you use?","acceptedAnswer":{"@type":"Answer","text":"Both Xero and QuickBooks Online, whichever you prefer. Both give you real-time access to your numbers."}},{"@type":"Question","name":"How do I switch from my current accountant?","acceptedAnswer":{"@type":"Answer","text":"We manage the handover, collecting records, setting up Xero and picking up filings with no gap in compliance."}}]},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://accountantforsmallbusiness.com/"},{"@type":"ListItem","position":2,"name":"Accounting Services","item":"https://accountantforsmallbusiness.com/accounting-services-singapore/"}]}]}
<\/script>`;

const faqs = [
  { q: 'Do I need monthly or annual bookkeeping?', a: "If you're GST-registered or want regular reports for decisions, choose monthly. Low-volume businesses that only need year-end compliance can start with annual bookkeeping and upgrade later." },
  { q: 'Do you handle GST and corporate tax filing?', a: 'No. We focus on accounting: bookkeeping, financial statements, payroll and management reporting. We keep your books clean and statements ready so your tax agent can file GST and corporate tax accurately.' },
  { q: 'Will I get a dedicated accountant?', a: 'Yes. You work with one named accountant who knows your business, not a different person each time you call.' },
  { q: 'Which accounting software do you use?', a: 'We work in both Xero and QuickBooks Online, whichever you prefer. Both are SFRS-friendly and give you real-time access to your numbers.' },
  { q: 'How do I switch from my current accountant?', a: 'We manage the handover, collecting your records, setting up Xero and picking up your filings with no gap in compliance.' },
];

const services = [
  { n:'01', title:'Bookkeeping', desc:'Monthly records, reconciled on Xero', href:'/bookkeeping-services-singapore/', accent:'text-[#DAA035]', numBg:'bg-amber-500/10', numColor:'text-[#DAA035]', numBorder:'border-[#DAA035]/25', bg:'bg-[#0A1628]', border:'hover:border-amber-500/50' },
  { n:'02', title:'Financial Statements', desc:'SFRS-compliant year-end accounts', href:'/financial-statements-singapore/', accent:'text-sky-400', numBg:'bg-sky-500/10', numColor:'text-sky-400', numBorder:'border-sky-500/25', bg:'bg-[#081F38]', border:'hover:border-sky-500/50' },
  { n:'03', title:'Management Reports', desc:'Monthly numbers you can act on', href:'/accounting-services-singapore/', accent:'text-emerald-400', numBg:'bg-emerald-500/10', numColor:'text-emerald-400', numBorder:'border-emerald-500/25', bg:'bg-[#042840]', border:'hover:border-emerald-500/50' },
  { n:'04', title:'AP / AR', desc:'Payables and receivables tracked', href:'/accounting-services-singapore/', accent:'text-purple-400', numBg:'bg-purple-500/10', numColor:'text-purple-400', numBorder:'border-purple-500/25', bg:'bg-[#0C1B2A]', border:'hover:border-purple-500/50' },
  { n:'05', title:'Payroll & CPF', desc:'Payslips and CPF submission', href:'/payroll-services-singapore/', accent:'text-pink-400', numBg:'bg-pink-500/10', numColor:'text-pink-400', numBorder:'border-pink-500/25', bg:'bg-[#121E2F]', border:'hover:border-pink-500/50' },
  { n:'06', title:'Bank Reconciliation', desc:'Every account matched monthly', href:'/bookkeeping-services-singapore/', accent:'text-teal-400', numBg:'bg-teal-500/10', numColor:'text-teal-400', numBorder:'border-teal-500/25', bg:'bg-[#05293A]', border:'hover:border-teal-500/50' },
];
---

<BaseLayout {title} {description} schemaJsonLd={schemaJsonLd}>

<!-- ════ HERO ════ -->
<section class="relative overflow-hidden bg-gradient-to-b from-[#000F22] to-[#0A1628] pt-20 pb-16 border-b border-gray-900 text-center">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(220,163,60,0.02)_0%,transparent_70%)] pointer-events-none"></div>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 space-y-6">
    <!-- Breadcrumb -->
    <nav class="flex items-center justify-center gap-2 text-xs text-gray-500 font-mono mb-2">
      <a href="/" class="hover:text-[#DAA035] transition-colors">Home</a>
      <span>/</span>
      <span class="text-[#DAA035]">Accounting Services</span>
    </nav>
    <h1 class="text-4xl sm:text-5xl font-serif text-[#FEFFFF] font-bold tracking-tight leading-tight">
      Accounting Services for Small Businesses in Singapore
    </h1>
    <p class="text-sm sm:text-base text-[#CBCFD8] max-w-2xl mx-auto leading-relaxed">
      Everything your small business needs to keep clean books, in one fixed monthly fee. Bookkeeping, financial statements, payroll and management reporting, handled remotely by a Financial Controller with 15+ years of experience.
    </p>
    <div class="flex flex-wrap justify-center gap-4 pt-2">
      <a href="/contact/" class="bg-[#DCA33C] hover:bg-[#C8912F] text-[#000F22] font-semibold px-8 py-3.5 rounded-lg text-sm transition-all hover:scale-[1.01] shadow-lg shadow-[#DCA33C]/10">
        Get a fixed quote
      </a>
      <a href="/contact/" class="bg-transparent border border-[#DAA035] hover:bg-[#DAA035] hover:text-[#000F22] text-[#DAA035] font-semibold px-8 py-3.5 rounded-lg text-sm transition-all">
        Book a free consultation
      </a>
    </div>
  </div>
</section>

<!-- ════ SPLIT 1: What does it include? (light F8FAFC, text left) ════ -->
<section class="bg-[#F8FAFC] text-[#000F22] py-20 border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <div class="lg:col-span-7 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">WHAT'S INCLUDED</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">
          What does a small business accounting service include?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#F2F4F7] text-[#000F22] shadow-sm">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#000F22]">
            A small business accounting service in Singapore typically covers monthly bookkeeping, bank reconciliation, SFRS-compliant financial statements, payroll with CPF, and management reporting. Bundled into one fee, they keep your records accurate and your statutory accounts ready, without you touching a spreadsheet.
          </p>
        </div>
        <div class="space-y-4 text-sm sm:text-base leading-relaxed text-gray-700">
          <p>The point of a service, rather than software, is that a qualified person does the work and takes responsibility for it. You hand over your invoices, receipts and bank statements, and you get back clean books, accurate filings and reports you can actually read.</p>
          <p>Our service covers monthly bookkeeping and reconciliation, SFRS-compliant unaudited financial statements, accounts payable and receivable, monthly payroll with CPF and itemised payslips, and clear management reports.</p>
        </div>
      </div>

      <!-- Visual: live ledger status -->
      <div class="lg:col-span-5 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="flex items-center justify-between border-b border-gray-800 pb-3 mb-6 font-mono">
              <span class="text-xs text-[#DAA035] font-bold uppercase tracking-wider">Service scope</span>
              <span class="text-[10px] bg-emerald-500/15 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded font-bold uppercase">All included</span>
            </div>
            <div class="space-y-3 font-sans">
              {[
                { label: 'Monthly bookkeeping & reconciliation', check: true },
                { label: 'SFRS-compliant financial statements', check: true },
                { label: 'Accounts payable & receivable', check: true },
                { label: 'Monthly payroll with CPF', check: true },
                { label: 'Itemised payslips', check: true },
                { label: 'Management reports', check: true },
              ].map((row) => (
                <div class="p-3 bg-[#020B16] rounded-xl border border-gray-800 flex items-center justify-between hover:border-gray-700 transition-colors">
                  <span class="text-xs font-bold text-white">{row.label}</span>
                  <span class="w-5 h-5 rounded-full bg-emerald-500/15 border border-emerald-500/25 flex items-center justify-center text-emerald-400 text-xs font-bold shrink-0">&#10003;</span>
                </div>
              ))}
            </div>
          </div>
          <p class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-4">*All under one fixed monthly fee</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ SPLIT 2: How much does it cost? (dark 0A1B30, visual left) ════ -->
<section class="bg-[#0A1B30] text-[#CBCFD8] py-20 border-b border-gray-950/45">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <!-- Visual: pricing tiers -->
      <div class="lg:col-span-5 order-2 lg:order-1 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between text-gray-200">
          <div>
            <div class="flex items-center justify-between border-b border-gray-800 pb-3 mb-6 font-mono">
              <span class="text-xs text-[#DAA035] font-bold uppercase">Typical market range</span>
              <span class="text-[10px] bg-emerald-500/15 text-emerald-400 px-2.5 py-1 rounded border border-emerald-500/20 font-bold uppercase">No hidden costs</span>
            </div>
            <div class="space-y-4 font-sans">
              <div class="p-3 bg-[#020B16] rounded-xl border border-gray-800 flex justify-between items-center">
                <div>
                  <span class="block text-[10px] font-mono text-[#DAA035] font-bold uppercase">Bookkeeping only</span>
                  <span class="text-xs font-bold text-white">Low-volume SME</span>
                </div>
                <span class="text-base font-black font-mono text-[#DAA035] shrink-0">S$90<span class="text-[10px] font-normal text-gray-400"> /mo</span></span>
              </div>
              <div class="p-4 bg-[#0A1628] text-white rounded-xl border border-[#DAA035] flex justify-between items-center shadow-lg scale-[1.02]">
                <div>
                  <span class="block text-[10px] font-mono text-[#DAA035] font-bold uppercase">Full managed package</span>
                  <span class="text-xs font-bold font-sans">Books + statements + payroll</span>
                </div>
                <span class="text-base font-black font-mono text-[#DAA035] shrink-0">S$300<span class="text-[10px] font-normal text-gray-400"> /mo</span></span>
              </div>
              <div class="p-3 bg-[#020B16] rounded-xl border border-gray-800 flex justify-between items-center">
                <div>
                  <span class="block text-[10px] font-mono text-red-400 font-bold uppercase">Market average (other firms)</span>
                  <span class="text-xs font-bold text-white">With hidden add-ons</span>
                </div>
                <span class="text-base font-black font-mono text-red-400 shrink-0">S$800+<span class="text-[10px] font-normal text-gray-400"> /mo</span></span>
              </div>
            </div>
          </div>
          <div class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-4">
            *We quote on your actual transaction count
          </div>
        </div>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">COST & PRICING</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#FEFFFF] font-extrabold tracking-tight">
          How much do accounting services for a small business cost in Singapore?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#0A1628] text-[#FEFFFF] shadow-inner">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#FEFFFF]">
            Monthly bookkeeping for a Singapore SME usually costs S$90 to S$300, while a full managed package covering bookkeeping, statements and tax runs from S$300 to S$800 a month with most providers. The figure depends mainly on your transaction volume, whether you're GST-registered, and how often your books are done.
          </p>
        </div>
        <div class="space-y-4 text-sm sm:text-base leading-relaxed text-[#CBCFD8] font-sans">
          <p>Most firms hide what actually moves you between tiers. Ours doesn't. Your fee tracks your real monthly transaction count and the services you need, so you never subsidise features you'll never use.</p>
          <p>See exact figures on our <a href="/pricing/" class="text-[#DAA035] hover:underline">pricing page</a>, or get a fixed quote in one short call.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ SPLIT 3: What drives the price? (light EDF0F5, text left) ════ -->
<section class="bg-[#EDF0F5] text-[#000F22] py-20 border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <div class="lg:col-span-7 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">PRICE DRIVERS</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">
          What drives the price of an accounting service?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#F2F4F7] text-[#000F22] shadow-sm">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#000F22]">
            Four factors set your fee: monthly transaction volume, GST registration status, payroll headcount, and bookkeeping frequency (annual, monthly or weekly). A low-volume sole proprietor pays far less than a GST-registered company processing hundreds of invoices a month.
          </p>
        </div>
        <div class="space-y-3 text-sm text-gray-700">
          {[
            { label: 'Transaction volume', desc: 'More invoices and receipts mean more work, so it drives the fee more than anything else.' },
            { label: 'GST status', desc: 'Quarterly F5 filing means GST-registered businesses pay a little more.' },
            { label: 'Payroll headcount', desc: 'Each employee adds monthly payroll and CPF processing.' },
            { label: 'Frequency', desc: 'Weekly books cost more than monthly, and monthly more than annual.' },
          ].map((item) => (
            <div class="flex items-start gap-3 p-3 bg-white rounded-xl border border-gray-200 shadow-sm">
              <span class="w-2 h-2 rounded-full bg-[#DAA035] shrink-0 mt-2"></span>
              <div>
                <span class="font-bold text-[#000F22] block">{item.label}</span>
                <span class="text-gray-600">{item.desc}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Visual: price drivers -->
      <div class="lg:col-span-5 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="border-b border-gray-800 pb-3 mb-6 font-mono text-center">
              <span class="text-xs text-[#DAA035] uppercase font-bold tracking-wider">What sets your fee</span>
            </div>
            <div class="space-y-4 font-sans">
              {[
                { label: 'Monthly transactions', low: '5', high: '150+', barColor: 'bg-[#DAA035]', barPct: '70%' },
                { label: 'GST registration', low: 'No GST', high: 'GST-reg', barColor: 'bg-sky-500', barPct: '40%' },
                { label: 'Payroll headcount', low: '0 staff', high: '20 staff', barColor: 'bg-emerald-500', barPct: '50%' },
                { label: 'Bookkeeping frequency', low: 'Annual', high: 'Weekly', barColor: 'bg-purple-500', barPct: '55%' },
              ].map((item) => (
                <div class="space-y-1.5">
                  <div class="flex justify-between text-[10px] font-mono font-bold text-gray-500 uppercase tracking-wider">
                    <span>{item.label}</span>
                  </div>
                  <div class="flex items-center gap-2 text-[10px] text-gray-500 font-sans">
                    <span class="shrink-0 w-14 text-right">{item.low}</span>
                    <div class="flex-1 h-2 bg-gray-900 rounded-full overflow-hidden">
                      <div class={`h-full ${item.barColor} rounded-full`} style={`width: ${item.barPct}`}></div>
                    </div>
                    <span class="shrink-0 w-14">{item.high}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <p class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-4">*Illustrative — exact fee quoted after free call</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ SPLIT 4: Software vs service? (dark 061224, visual left) ════ -->
<section class="bg-[#061224] text-[#CBCFD8] py-20 border-b border-gray-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <!-- Visual: software vs service comparison -->
      <div class="lg:col-span-5 order-2 lg:order-1 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="border-b border-gray-800 pb-3 mb-6 font-mono text-center">
              <span class="text-xs text-[#DAA035] uppercase font-bold tracking-wider">Software vs Service</span>
            </div>
            <div class="grid grid-cols-2 gap-3 font-sans">
              <div class="p-4 bg-[#020B16] rounded-xl border border-gray-800 space-y-2">
                <span class="block text-[10px] font-mono text-gray-500 uppercase font-bold">Xero / QBO Alone</span>
                <ul class="space-y-2 text-[11px] text-gray-400">
                  <li class="flex items-start gap-1.5"><span class="text-red-400 shrink-0">✗</span> You still do the work</li>
                  <li class="flex items-start gap-1.5"><span class="text-red-400 shrink-0">✗</span> Falls behind easily</li>
                  <li class="flex items-start gap-1.5"><span class="text-red-400 shrink-0">✗</span> Year-end catch-up fees</li>
                  <li class="flex items-start gap-1.5"><span class="text-amber-400 shrink-0">~</span> S$35/mo software only</li>
                </ul>
              </div>
              <div class="p-4 bg-emerald-950/25 rounded-xl border border-emerald-900/40 space-y-2">
                <span class="block text-[10px] font-mono text-[#DAA035] uppercase font-bold">AFSB Service</span>
                <ul class="space-y-2 text-[11px] text-gray-300">
                  <li class="flex items-start gap-1.5"><span class="text-emerald-400 shrink-0">✓</span> We do the work</li>
                  <li class="flex items-start gap-1.5"><span class="text-emerald-400 shrink-0">✓</span> Always current</li>
                  <li class="flex items-start gap-1.5"><span class="text-emerald-400 shrink-0">✓</span> No year-end surprises</li>
                  <li class="flex items-start gap-1.5"><span class="text-emerald-400 shrink-0">✓</span> Software included</li>
                </ul>
              </div>
            </div>
          </div>
          <p class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-4">*Managed service keeps books current every month</p>
        </div>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">SOFTWARE VS SERVICE</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#FEFFFF] font-extrabold tracking-tight">
          Accounting software or an accounting service: which do you need?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#0A1628] text-[#FEFFFF] shadow-inner">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#FEFFFF]">
            Software like Xero gives you the tools, but you or someone you hire still has to do the bookkeeping and filing. A service does the work for you. If accounting is eating your time or you're unsure your filings are correct, a service is the safer choice; if you have the time and the know-how, software alone can work.
          </p>
        </div>
        <p class="text-sm sm:text-base leading-relaxed text-[#CBCFD8] font-sans">Many SMEs buy software, fall behind, then pay extra at year-end for clean-up. A managed service avoids that by keeping the books current every month, with the software cost already included.</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ SPLIT 5: Outsource or in-house? (light F8FAFC, text left) ════ -->
<section class="bg-[#F8FAFC] text-[#000F22] py-20 border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <div class="lg:col-span-7 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">OUTSOURCING</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">
          Should you outsource your accounting or keep it in-house?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#F2F4F7] text-[#000F22] shadow-sm">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#000F22]">
            For most Singapore small businesses, outsourcing is the cheaper and safer option. A full-time accountant costs salary plus CPF, benefits and software, often more than S$3,000 a month, and outsourcing can save 70 to 85% of that while still giving you qualified expertise and continuity.
          </p>
        </div>
        <div class="space-y-4 text-sm sm:text-base leading-relaxed text-gray-700 font-sans">
          <p>Hire in-house and you carry the salary, CPF, leave and software, plus the risk if that person leaves or makes a mistake.</p>
          <p>Outsource and you get a fixed fee, a dedicated accountant, compliant software, and a service that scales with you.</p>
        </div>
