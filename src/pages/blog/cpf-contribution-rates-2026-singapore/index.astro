   "url":"https://accountantforsmallbusiness.com/blog/cpf-contribution-rates-2026-singapore/",
   "datePublished":"2026-06-22","dateModified":"2026-06-22","inLanguage":"en-SG",
   "image":{"@type":"ImageObject","url":"https://accountantforsmallbusiness.com/hero-bg.jpg","width":1200,"height":630},
   "author":{"@id":"https://accountantforsmallbusiness.com/#mehdi"},
   "publisher":{"@id":"https://accountantforsmallbusiness.com/#org"},
   "about":["CPF contribution rates","CPF employer","Singapore payroll","CPF 2026"],
   "keywords":["cpf contribution rate 2026","cpf contribution rate singapore","employer cpf rate 2026","cpf contribution calculator","cpf employer contribution"],
   "mainEntityOfPage":{"@type":"WebPage","@id":"https://accountantforsmallbusiness.com/blog/cpf-contribution-rates-2026-singapore/"}},
  {"@type":"FAQPage","mainEntity":[
