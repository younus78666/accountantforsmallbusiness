---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Bookkeeping Services Singapore for Small Business | AFSB';
const description = 'Affordable bookkeeping services in Singapore for small businesses. Monthly Xero bookkeeping and bank reconciliation, with clear transaction-based pricing.';

const schemaJsonLd = `<script type="application/ld+json">
{"@context":"https://schema.org","@graph":[{"@type":["Service","AccountingService"],"@id":"https://accountantforsmallbusiness.com/bookkeeping-services-singapore/#service","name":"Bookkeeping Services Singapore","serviceType":"Bookkeeping","provider":{"@id":"https://accountantforsmallbusiness.com/#org"},"areaServed":{"@type":"Country","name":"Singapore"},"description":"Monthly Xero bookkeeping and bank reconciliation for Singapore small businesses, reviewed by a Financial Controller, priced on transaction volume.","offers":{"@type":"Offer","priceCurrency":"SGD","priceSpecification":{"@type":"PriceSpecification","minPrice":"90","maxPrice":"800","priceCurrency":"SGD"}},"isRelatedTo":{"@id":"https://accountantforsmallbusiness.com/accounting-services-singapore/#service"}},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Should I do monthly or annual bookkeeping?","acceptedAnswer":{"@type":"Answer","text":"If you are GST-registered or want regular reports, choose monthly. Low-volume businesses needing only year-end compliance can start annual and upgrade as they grow."}},{"@type":"Question","name":"Do you work in Xero?","acceptedAnswer":{"@type":"Answer","text":"Yes, plus QuickBooks Online. We work in both, whichever you prefer."}},{"@type":"Question","name":"Can you clean up months of backlog?","acceptedAnswer":{"@type":"Answer","text":"Yes. We run a catch-up first to get you current, then move you onto a steady monthly cycle."}},{"@type":"Question","name":"Is bookkeeping required by law in Singapore?","acceptedAnswer":{"@type":"Answer","text":"Yes. IRAS requires businesses to keep proper accounting records for at least five years."}},{"@type":"Question","name":"Does bookkeeping include GST and tax filing?","acceptedAnswer":{"@type":"Answer","text":"No. We keep records clean and statements ready, which is the foundation for filing. GST and corporate tax are filed by your tax agent."}}]},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://accountantforsmallbusiness.com/"},{"@type":"ListItem","position":2,"name":"Accounting Services","item":"https://accountantforsmallbusiness.com/accounting-services-singapore/"},{"@type":"ListItem","position":3,"name":"Bookkeeping Services","item":"https://accountantforsmallbusiness.com/bookkeeping-services-singapore/"}]}]}
<\/script>`;

const faqs = [
  { q: 'Should I do monthly or annual bookkeeping?', a: "If you're GST-registered or want regular reports, choose monthly. Low-volume businesses needing only year-end compliance can start annual and upgrade as they grow." },
  { q: 'Do you work in Xero?', a: 'Yes. We work in both Xero and QuickBooks Online, whichever you prefer. Both are SFRS-friendly and give you real-time access to your numbers.' },
  { q: 'Can you clean up months of backlog?', a: 'Yes. We run a catch-up first to get you current, then move you onto a steady monthly cycle.' },
  { q: 'Is bookkeeping required by law in Singapore?', a: 'Yes. IRAS requires businesses to keep proper accounting records for at least five years, so some level of bookkeeping is mandatory.' },
  { q: 'Does bookkeeping include GST and tax filing?', a: "No. We keep your records clean and your statements ready, which is the foundation for filing. Your GST and corporate tax are filed by your tax agent, and clean books make their job accurate and on time." },
];
---

<BaseLayout {title} {description} schemaJsonLd={schemaJsonLd}>

<!-- ════ HERO ════ -->
<section class="relative overflow-hidden bg-gradient-to-b from-[#000F22] to-[#0A1628] pt-20 pb-16 border-b border-gray-900 text-center">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(220,163,60,0.02)_0%,transparent_70%)] pointer-events-none"></div>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 space-y-6">
    <nav class="flex items-center justify-center gap-2 text-xs text-gray-500 font-mono mb-2">
      <a href="/" class="hover:text-[#DAA035] transition-colors">Home</a>
      <span>/</span>
      <a href="/accounting-services-singapore/" class="hover:text-[#DAA035] transition-colors">Accounting Services</a>
      <span>/</span>
      <span class="text-[#DAA035]">Bookkeeping</span>
    </nav>
    <h1 class="text-4xl sm:text-5xl font-serif text-[#FEFFFF] font-bold tracking-tight leading-tight">
      Bookkeeping Services in Singapore for Small Businesses
    </h1>
    <p class="text-sm sm:text-base text-[#CBCFD8] max-w-2xl mx-auto leading-relaxed">
      Clean, current books every month, reconciled on Xero and reviewed by a Financial Controller. Stop catching up on weekends and pay only for the transactions you actually have.
    </p>
    <div class="flex flex-wrap justify-center gap-4 pt-2">
      <a href="/contact/" class="bg-[#DCA33C] hover:bg-[#C8912F] text-[#000F22] font-semibold px-8 py-3.5 rounded-lg text-sm transition-all hover:scale-[1.01] shadow-lg shadow-[#DCA33C]/10">
        Get a bookkeeping quote
      </a>
      <a href="/contact/" class="bg-transparent border border-[#DAA035] hover:bg-[#DAA035] hover:text-[#000F22] text-[#DAA035] font-semibold px-8 py-3.5 rounded-lg text-sm transition-all">
        Book a free consultation
      </a>
    </div>
  </div>
</section>

<!-- ════ SPLIT 1: What is bookkeeping? (light F8FAFC, text left) ════ -->
<section class="bg-[#F8FAFC] text-[#000F22] py-20 border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <div class="lg:col-span-7 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">THE SERVICE</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">
          What is bookkeeping and what does the service cover?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#F2F4F7] text-[#000F22] shadow-sm">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#000F22]">
            Bookkeeping is the day-to-day recording of your business transactions: sales, expenses and bank movements, all logged and reconciled so your records are accurate and current. Our service does this for you each month in Xero, covering data entry, bank reconciliation, ledger maintenance and a clear monthly summary.
          </p>
        </div>
        <div class="space-y-4 text-sm sm:text-base leading-relaxed text-gray-700">
          <p>Done properly, bookkeeping is the foundation everything else stands on. Accurate books turn your financial statements, and your tax agent's filing work, into routine instead of a year-end scramble.</p>
          <p>Each month we handle transaction recording, bank and credit-card reconciliation, accounts payable and receivable tracking, and a tidy set of books ready for reporting.</p>
        </div>
      </div>

      <!-- Visual: monthly cycle status -->
      <div class="lg:col-span-5 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="flex items-center justify-between border-b border-gray-800 pb-3 mb-6 font-mono">
              <span class="text-xs text-[#DAA035] font-bold uppercase tracking-wider">Monthly cycle</span>
              <span class="text-[10px] bg-emerald-500/15 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded font-bold uppercase">On track</span>
            </div>
            <div class="space-y-3 font-sans">
              {[
                { label: 'Transaction recording', status: 'DONE', color: 'text-emerald-400', dot: 'bg-emerald-500' },
                { label: 'Bank reconciliation', status: 'DONE', color: 'text-emerald-400', dot: 'bg-emerald-500' },
                { label: 'AP / AR tracking', status: 'DONE', color: 'text-emerald-400', dot: 'bg-emerald-500' },
                { label: 'Ledger review by FC', status: 'IN REVIEW', color: 'text-amber-400', dot: 'bg-amber-500 animate-pulse' },
                { label: 'Monthly summary sent', status: 'PENDING', color: 'text-gray-500', dot: 'bg-gray-600' },
              ].map((row) => (
                <div class="p-3 bg-[#020B16] rounded-xl border border-gray-800 flex items-center justify-between hover:border-gray-700 transition-colors">
                  <div class="flex items-center gap-2.5">
                    <span class={`w-2.5 h-2.5 rounded-full shrink-0 ${row.dot}`}></span>
                    <span class="text-xs font-bold text-white">{row.label}</span>
                  </div>
                  <span class={`text-[10px] font-mono font-bold uppercase ${row.color}`}>{row.status}</span>
                </div>
              ))}
            </div>
          </div>
          <p class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-4">*Every account matched, every month</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ SPLIT 2: Bookkeeping vs accounting? (dark 0A1B30, visual left) ════ -->
<section class="bg-[#0A1B30] text-[#CBCFD8] py-20 border-b border-gray-950/45">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <!-- Visual: input/output comparison -->
      <div class="lg:col-span-5 order-2 lg:order-1 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="border-b border-gray-800 pb-3 mb-6 font-mono text-center">
              <span class="text-xs text-[#DAA035] uppercase font-bold tracking-wider">How They Connect</span>
            </div>
            <!-- Flow diagram -->
            <div class="space-y-3 font-sans">
              <div class="p-4 bg-[#020B16] rounded-xl border border-sky-500/30 space-y-2">
                <span class="text-[10px] font-mono text-sky-400 uppercase font-bold">Bookkeeping (INPUT)</span>
                <p class="text-xs text-gray-300">Records every sale, expense and bank movement. Keeps Xero accurate and current each month.</p>
                <div class="flex flex-wrap gap-1.5 pt-1">
                  {['Data entry', 'Reconciliation', 'Ledger posting'].map(t => (
                    <span class="text-[9px] bg-sky-500/10 border border-sky-500/20 text-sky-400 px-2 py-0.5 rounded font-mono font-bold uppercase">{t}</span>
                  ))}
                </div>
              </div>

              <!-- Arrow -->
              <div class="flex items-center justify-center py-1">
                <svg class="w-5 h-5 text-[#DAA035]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
              </div>

              <div class="p-4 bg-[#020B16] rounded-xl border border-[#DAA035]/30 space-y-2">
                <span class="text-[10px] font-mono text-[#DAA035] uppercase font-bold">Accounting (OUTPUT)</span>
                <p class="text-xs text-gray-300">Uses clean books to produce financial statements, management reports and analysis.</p>
                <div class="flex flex-wrap gap-1.5 pt-1">
                  {['Statements', 'Reports', 'Analysis'].map(t => (
                    <span class="text-[9px] bg-[#DAA035]/10 border border-[#DAA035]/20 text-[#DAA035] px-2 py-0.5 rounded font-mono font-bold uppercase">{t}</span>
                  ))}
                </div>
              </div>

              <!-- Arrow -->
              <div class="flex items-center justify-center py-1">
                <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
              </div>

              <div class="p-3 bg-emerald-950/25 rounded-xl border border-emerald-900/40">
                <span class="text-[10px] font-mono text-emerald-400 uppercase font-bold block mb-1">Tax Agent (FILING)</span>
                <p class="text-xs text-gray-400">Files GST and corporate tax from the clean books and finished statements.</p>
              </div>
            </div>
          </div>
          <p class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-4">*We cover bookkeeping + accounting; tax agent covers filing</p>
        </div>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">BOOKKEEPING VS ACCOUNTING</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#FEFFFF] font-extrabold tracking-tight">
          What's the difference between bookkeeping and accounting?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#0A1628] text-[#FEFFFF] shadow-inner">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#FEFFFF]">
            Bookkeeping records the transactions; accounting interprets them. A bookkeeper logs your sales, expenses and bank movements into Xero and reconciles them. An accountant uses those records to prepare financial statements and management reports. For most small businesses, one provider does both, while a tax agent handles the actual GST and tax filing.
          </p>
        </div>
        <div class="space-y-4 text-sm sm:text-base leading-relaxed text-[#CBCFD8] font-sans">
          <p>This is the question we hear most. Put simply, bookkeeping is the input and accounting is the output. You cannot get accurate statements, or accurate tax filings from your tax agent, without clean books underneath them.</p>
          <p>We cover both. Bookkeeping keeps your records current, and our wider accounting service turns them into statements and filings.</p>
        </div>
        <a href="/accounting-services-singapore/" class="inline-flex items-center gap-2 text-[#DAA035] hover:underline font-mono text-sm font-bold">
          See our full accounting service &rarr;
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ════ SPLIT 3: How much does it cost? (light EDF0F5, text left) ════ -->
<section class="bg-[#EDF0F5] text-[#000F22] py-20 border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <div class="lg:col-span-7 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">PRICING</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">
          How much do bookkeeping services cost in Singapore?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#F2F4F7] text-[#000F22] shadow-sm">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#000F22]">
            Monthly bookkeeping for a Singapore SME typically costs S$90 to S$800, depending on transaction volume. A freelance bookkeeper runs S$300 to S$800 a month for basic scope, while DIY with Xero is about S$35 a month in software plus your own time. We price on your real transaction count, not a fixed tier.
          </p>
        </div>
        <div class="space-y-4 text-sm sm:text-base leading-relaxed text-gray-700 font-sans">
          <p>The biggest cost driver is simple: how many transactions you have each month. A low-volume sole proprietor pays far less than a busy GST-registered company. We quote on that actual number so you never pay for a tier you haven't grown into.</p>
          <p>See full pricing on our <a href="/pricing/" class="text-[#DAA035] hover:underline">pricing page</a>, or get a fixed bookkeeping quote in one short call.</p>
        </div>
      </div>

      <!-- Visual: pricing comparison -->
      <div class="lg:col-span-5 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="border-b border-gray-800 pb-3 mb-6 font-mono text-center">
              <span class="text-xs text-[#DAA035] uppercase font-bold tracking-wider">Monthly Cost Options</span>
            </div>
            <div class="space-y-4 font-sans">
              <div class="p-3 bg-[#020B16] rounded-xl border border-gray-800 flex justify-between items-center">
                <div>
                  <span class="block text-[10px] font-mono text-gray-500 font-bold uppercase">DIY Xero software</span>
                  <span class="text-xs font-bold text-white">Your time + effort</span>
                </div>
                <span class="text-sm font-black font-mono text-gray-400 shrink-0">S$35<span class="text-[10px] font-normal text-gray-600"> /mo</span></span>
              </div>
              <div class="p-3 bg-[#020B16] rounded-xl border border-gray-800 flex justify-between items-center">
                <div>
                  <span class="block text-[10px] font-mono text-orange-400 font-bold uppercase">Freelance bookkeeper</span>
                  <span class="text-xs font-bold text-white">Basic scope only</span>
                </div>
                <span class="text-sm font-black font-mono text-orange-400 shrink-0">S$300+<span class="text-[10px] font-normal text-gray-400"> /mo</span></span>
              </div>
              <div class="p-4 bg-[#0A1628] rounded-xl border border-[#DAA035] flex justify-between items-center shadow-lg scale-[1.02]">
                <div>
                  <span class="block text-[10px] font-mono text-[#DAA035] font-bold uppercase">AFSB managed service</span>
                  <span class="text-xs font-bold text-white">FC-reviewed, Xero included</span>
                </div>
                <span class="text-base font-black font-mono text-[#DAA035] shrink-0">S$90+<span class="text-[10px] font-normal text-gray-400"> /mo</span></span>
              </div>
              <div class="p-3 bg-red-950/20 rounded-xl border border-red-900/40 flex justify-between items-center">
                <div>
                  <span class="block text-[10px] font-mono text-red-400 font-bold uppercase">In-house bookkeeper</span>
                  <span class="text-xs font-bold text-red-200">Salary + CPF + benefits</span>
                </div>
                <span class="text-sm font-black font-mono text-red-400 shrink-0">S$3,500+<span class="text-[10px] font-normal text-gray-400"> /mo</span></span>
              </div>
            </div>
          </div>
          <p class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-4">*AFSB price tracks your real transaction count</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ SPLIT 4: DIY vs outsource? (dark 061224, visual left) ════ -->
<section class="bg-[#061224] text-[#CBCFD8] py-20 border-b border-gray-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <!-- Visual: DIY vs outsource -->
      <div class="lg:col-span-5 order-2 lg:order-1 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="border-b border-gray-800 pb-3 mb-6 font-mono text-center">
              <span class="text-xs text-[#DAA035] uppercase font-bold tracking-wider">DIY Xero vs Outsourcing</span>
            </div>
            <div class="grid grid-cols-2 gap-3 font-sans">
              <div class="p-4 bg-[#020B16] rounded-xl border border-gray-800 space-y-3">
                <span class="block text-[10px] font-mono text-gray-500 uppercase font-bold">DIY Xero</span>
                <p class="text-[10px] font-bold text-emerald-400">Works when:</p>
                <ul class="space-y-1 text-[11px] text-gray-400">
                  <li>&#10003; Few transactions</li>
                  <li>&#10003; Time available</li>
                  <li>&#10003; Confident to reconcile</li>
                </ul>
                <div class="border-t border-gray-800 pt-2 mt-2">
                  <p class="text-[10px] font-bold text-red-400">Fails when:</p>
                  <ul class="space-y-1 text-[11px] text-gray-500 mt-1">
                    <li>&#10007; Volume grows</li>
                    <li>&#10007; Books fall behind</li>
                    <li>&#10007; Year-end scramble</li>
                  </ul>
                </div>
              </div>
              <div class="p-4 bg-emerald-950/25 rounded-xl border border-emerald-900/40 space-y-3">
                <span class="block text-[10px] font-mono text-[#DAA035] uppercase font-bold">AFSB Service</span>
                <p class="text-[10px] font-bold text-emerald-400">Always works:</p>
                <ul class="space-y-1 text-[11px] text-gray-300">
                  <li>&#10003; Any volume</li>
                  <li>&#10003; Always current</li>
                  <li>&#10003; FC-reviewed</li>
                  <li>&#10003; No weekends</li>
                  <li>&#10003; Xero included</li>
                </ul>
              </div>
            </div>
          </div>
          <p class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-4">*Outsourcing gives you the same accuracy at a fraction of in-house cost</p>
        </div>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">DIY VS OUTSOURCE</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#FEFFFF] font-extrabold tracking-tight">
          Should you DIY bookkeeping with Xero or outsource it?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#0A1628] text-[#FEFFFF] shadow-inner">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#FEFFFF]">
            DIY with Xero works while you have the time and your transaction volume is low. Once books start eating your evenings or you're unsure they're correct, outsourcing is the safer call. A full-time in-house bookkeeper costs S$3,500 to S$5,500 a month with CPF, so outsourcing gives you the same accuracy for a fraction of that.
          </p>
        </div>
        <div class="space-y-3 text-sm sm:text-base text-[#CBCFD8] font-sans">
          <p>DIY Xero suits you when you have few transactions, the time to keep up, and the confidence to reconcile correctly.</p>
          <p>Outsourcing suits you when bookkeeping is falling behind, you're GST-registered, or you'd rather spend the hours on your business.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ SPLIT 5: When is it time to outsource? (warm FFFDF2, visual left) ════ -->
<section class="bg-[#FFFDF2] text-[#000F22] py-20 border-b border-amber-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <!-- Visual: 5 warning signs -->
      <div class="lg:col-span-5 order-2 lg:order-1 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-2 border-b border-gray-800 pb-3 mb-6 font-mono">
              <span class="w-2 h-2 rounded-full bg-amber-500 animate-ping shrink-0"></span>
              <span class="text-xs text-[#DAA035] uppercase font-bold tracking-wider">5 Warning Signs</span>
            </div>
            <div class="space-y-3 font-sans">
              {[
                'You are doing books at the weekend',
                'You are behind by more than a month',
                'You are unsure your records are correct',
                'Your statements are never ready on time',
                'Your tax agent won\'t file until you clean up',
              ].map((sign, i) => (
                <div class="p-3 bg-[#020B16] rounded-xl border border-amber-500/20 flex items-start gap-3">
                  <span class="w-6 h-6 rounded-full bg-amber-500/15 text-amber-400 text-xs font-bold font-mono flex items-center justify-center shrink-0 mt-0.5">{i+1}</span>
                  <span class="text-xs text-[#CBCFD8] leading-snug">{sign}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="p-3 bg-emerald-950/25 rounded-xl border border-emerald-900/40 mt-4">
            <p class="text-[10px] font-mono text-[#DAA035] font-bold uppercase mb-1">Any one of these = time to outsource</p>
            <p class="text-xs text-gray-400">It will save you money and stress.</p>
          </div>
        </div>
      </div>

