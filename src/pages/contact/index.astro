---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../islands/ContactForm';

const title = 'Contact | Accountant for Small Business Singapore | AFSB';
const description = 'Get in touch for a free, no-obligation consultation. Reach Mehdi Javed directly about bookkeeping, payroll and accounting for your Singapore small business.';

const sections = [
  {
    title: 'What happens after you get in touch?',
    answer: "You'll hear back within one business day. We ask a few quick questions about your transaction volume and what you need, give you a fixed monthly quote with no obligation, and if it's a fit, we handle a clean handover onto Xero or QuickBooks. No pressure, no long sales process.",
    paragraphs: [],
  },
  {
    title: 'Do we work with businesses outside Singapore hours?',
    answer: "Yes. We're a remote service based in Karachi, working with Singapore small businesses on cloud accounting. We align to Singapore business hours and respond within a business day, so being remote never slows anything down. Everything runs on Xero or QuickBooks Online, which you can access any time.",
    paragraphs: [],
  },
  {
    title: 'What should you have ready for the first call?',
    answer: "Nothing formal. It helps to know your rough monthly transaction volume, whether you have employees on payroll, and which software you use, if any. If you don't know these yet, that's fine. We'll work it out together on the call.",
    paragraphs: [],
  },
];

const faqs = [
  { question: 'What happens after I get in touch?', answer: "You hear back within one business day. We ask about your transaction volume and needs, give a fixed quote with no obligation, and handle a clean handover onto Xero or QuickBooks if it is a fit." },
  { question: 'Do you work with businesses outside Singapore?', answer: "Yes. We are a remote service based in Karachi serving Singapore small businesses on cloud accounting, aligned to Singapore hours with responses within a business day." },
  { question: 'What should I have ready for the first call?', answer: "Your rough monthly transaction volume, whether you have employees on payroll, and which software you use. If you do not know yet, we work it out together." },
];
---

<BaseLayout {title} {description}>

  <!-- ════ HERO ════ -->
  <section class="relative overflow-hidden bg-gradient-to-b from-[#000F22] to-[#0A1628] pt-20 pb-16 border-b border-gray-900 text-center">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(220,163,60,0.02)_0%,transparent_70%)] pointer-events-none"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 space-y-6">
      <h1 class="text-4xl sm:text-5xl font-serif text-[#FEFFFF] font-bold tracking-tight">Contact Us</h1>
      <p class="text-sm sm:text-base text-[#CBCFD8] max-w-2xl mx-auto leading-relaxed">
        Tell us a little about your business and we'll come back with a clear, fixed quote. The first consultation is free and there's no obligation.
      </p>
      <div class="flex flex-wrap justify-center gap-4 pt-4">
        <a href="#contact-form" class="bg-[#DCA33C] hover:bg-[#C8912F] text-[#000F22] font-sans font-semibold px-6 py-2.5 rounded-lg text-sm transition-all">
          Get a fixed quote
        </a>
        <a href="/pricing/" class="bg-transparent border border-[#DAA035] text-[#DAA035] hover:bg-[#DAA035] hover:text-[#000F22] px-6 py-2.5 rounded-lg text-sm transition-all">
          See Plan Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- ════ CONTACT INFO BANNER ════ -->
  <section class="bg-[#0A1628] py-12 border-b border-gray-950 text-xs sm:text-sm">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 text-center">

        <!-- Email -->
        <div class="bg-[#000F22] p-4 rounded-lg border border-gray-800 space-y-1">
          <svg class="w-5 h-5 mx-auto text-[#DAA035] mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <span class="text-[10px] text-gray-500 font-mono block uppercase tracking-wider">EMAIL</span>
          <a href="mailto:hello@accountantforsmallbusiness.com" class="font-semibold text-[#FEFFFF] hover:text-[#DAA035] transition-colors break-all block">
            hello@accountantforsmallbusiness.com
          </a>
        </div>

        <!-- WhatsApp -->
        <div class="bg-[#000F22] p-4 rounded-lg border border-gray-800 space-y-1">
          <svg class="w-5 h-5 mx-auto text-[#DAA035] mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <span class="text-[10px] text-gray-500 font-mono block uppercase tracking-wider">WHATSAPP</span>
          <!-- CONFIRM phone -->
          <span class="font-semibold text-[#FEFFFF] block">+92 333 2999777</span>
        </div>

        <!-- Response time -->
        <div class="bg-[#000F22] p-4 rounded-lg border border-gray-800 space-y-1">
          <svg class="w-5 h-5 mx-auto text-[#DAA035] mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-[10px] text-gray-500 font-mono block uppercase tracking-wider">RESPONSE SPEED</span>
          <span class="font-semibold text-[#FEFFFF] block">Within one business day</span>
        </div>

        <!-- Hours -->
        <div class="bg-[#000F22] p-4 rounded-lg border border-gray-800 space-y-1">
          <svg class="w-5 h-5 mx-auto text-[#DAA035] mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-[10px] text-gray-500 font-mono block uppercase tracking-wider">OPERATING HOURS</span>
          <span class="font-semibold text-[#FEFFFF] block">Mon&ndash;Fri, Singapore (GMT+8)</span>
        </div>

      </div>
    </div>
  </section>

  <!-- ════ CONTENT SECTIONS (alternating) ════ -->
  {sections.map((sec, idx) => {
    const isEven = idx % 2 === 0;
    return (
      <section class={`py-16 border-b border-gray-950/40 ${isEven ? 'bg-[#000F22] text-[#CBCFD8]' : 'bg-[#F5F7FA] text-[#000F22]'}`}>
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class={`text-2xl sm:text-3xl font-serif font-semibold tracking-tight mb-5 ${isEven ? 'text-[#FEFFFF]' : 'text-[#000F22]'}`}>
            {sec.title}
          </h2>
          <!-- AnswerBlock -->
          <div class={`p-6 my-6 border-l-[3px] border-[#DAA035] rounded-r-lg ${isEven ? 'bg-[#0A1628] text-[#FEFFFF] shadow-inner' : 'bg-[#F2F4F7] text-[#000F22] shadow-sm'}`}>
            <p class={`text-base md:text-lg leading-relaxed font-semibold italic ${isEven ? 'text-[#FEFFFF]' : 'text-[#000F22]'}`}>
              {sec.answer}
            </p>
          </div>
          {sec.paragraphs.map((p) => (
            <p class="text-sm leading-relaxed mb-4">{p}</p>
          ))}
        </div>
      </section>
    );
  })}

  <!-- ════ CONTACT FORM ════ -->
  <section id="contact-form" class="bg-[#000F22] py-16 border-b border-gray-950">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8">
      <div class="text-center space-y-3">
        <h3 class="text-3xl font-serif text-[#FEFFFF] font-bold">Request a bespoke estimate</h3>
        <p class="text-xs text-[#CBCFD8]">Fill out the form below and we'll compute your plan pricing parameters.</p>
      </div>
      <ContactForm client:load />
    </div>
  </section>

  <!-- ════ FAQs ════ -->
  {faqs.length > 0 && (
    <section class="bg-[#000F22] py-16 border-b border-gray-950">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-2xl mx-auto mb-12">
          <h3 class="text-2xl sm:text-3xl font-serif text-white font-semibold">Frequently Asked Questions</h3>
        </div>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <details class="bg-[#0A1628] border border-gray-900 rounded-lg p-5 group">
              <summary class="w-full flex items-center justify-between text-left font-sans text-sm sm:text-base font-semibold text-white cursor-pointer list-none select-none">
                <span>{faq.question}</span>
                <svg class="w-5 h-5 text-gray-500 group-open:text-[#DAA035] transition-colors shrink-0 ml-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <div class="mt-4 pt-4 border-t border-gray-800 text-xs sm:text-sm text-[#CBCFD8] leading-relaxed">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ════ FOOTER CTA ════ -->
  <section class="bg-gradient-to-tr from-[#000F22] via-[#0A1628] to-[#000F22] py-20 text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6">
      <h3 class="text-3xl font-serif text-[#FEFFFF] font-bold">Need an honest scope evaluation?</h3>
      <p class="text-sm leading-relaxed text-[#CBCFD8] max-w-xl mx-auto">
        Connect with Mehdi Javed directly on WhatsApp or fill in the form above.
      </p>
      <a
        href="#contact-form"
        class="inline-block bg-[#DCA33C] hover:bg-[#C8912F] text-[#000F22] font-semibold px-8 py-3 rounded-lg text-sm transition-all"
      >
        Get a fixed quote
      </a>
    </div>
  </section>

</BaseLayout>
