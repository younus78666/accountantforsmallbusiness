---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../islands/ContactForm';

const title = 'Contact | Accountant for Small Business Singapore | AFSB';
const description = 'Get in touch for a free, no-obligation consultation. Reach Mehdi Javed directly about bookkeeping, payroll and accounting for your Singapore small business.';

const schemaJsonLd = `<script type="application/ld+json">
{"@context":"https://schema.org","@graph":[{"@type":"ContactPage","@id":"https://accountantforsmallbusiness.com/contact/#page","url":"https://accountantforsmallbusiness.com/contact/","name":"Contact Accountant for Small Business","description":"Get in touch for a free consultation about accounting services for your Singapore small business.","mainEntity":{"@id":"https://accountantforsmallbusiness.com/#org"}},{"@type":["Organization","ProfessionalService"],"@id":"https://accountantforsmallbusiness.com/#org","name":"Accountant for Small Business","url":"https://accountantforsmallbusiness.com/","email":"accforsmes@gmail.com","contactPoint":{"@type":"ContactPoint","contactType":"customer service","availableLanguage":"English","areaServed":"Singapore","hoursAvailable":{"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday"]}}},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What happens after I get in touch?","acceptedAnswer":{"@type":"Answer","text":"You hear back within one business day with a fixed quote, no obligation."}},{"@type":"Question","name":"Is the first consultation free?","acceptedAnswer":{"@type":"Answer","text":"Yes. No credit card, no contract, no obligation. We scope your needs and send a quote."}}]},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://accountantforsmallbusiness.com/"},{"@type":"ListItem","position":2,"name":"Contact","item":"https://accountantforsmallbusiness.com/contact/"}]}]}
<\/script>`;

const faqs = [
  { q: 'What happens after I get in touch?', a: 'You hear back within one business day. We ask about your transaction volume and needs, give a fixed quote with no obligation, and handle a clean handover onto Xero or QuickBooks if it is a fit.' },
  { q: 'Do you work with businesses outside Singapore?', a: 'Yes. We are a remote service serving Singapore small businesses on cloud accounting, aligned to Singapore hours with responses within a business day.' },
  { q: 'What should I have ready for the first call?', a: "Your rough monthly transaction volume, whether you have employees on payroll, and which software you use. If you don't know yet, we'll work it out together." },
  { q: 'Is the first consultation really free?', a: 'Yes. No credit card, no contract, no obligation. We scope your needs, send a quote, and you decide. If it is not a fit, there is nothing owed.' },
];
---

<BaseLayout {title} {description} schemaJsonLd={schemaJsonLd}>

<!-- ════════════════════════════════════════════ HERO ════ -->
<section class="relative overflow-hidden bg-gradient-to-b from-[#000F22] to-[#0A1628] pt-24 pb-20 border-b border-gray-900 text-center">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(220,163,60,0.03)_0%,transparent_70%)] pointer-events-none"></div>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 space-y-6">
    <span class="inline-block py-1.5 px-3 rounded-full bg-[#DAA035]/15 border border-[#DAA035]/30 text-[#DAA035] text-xs font-mono uppercase tracking-widest">
      Free Consultation &bull; No Obligation
    </span>
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-serif text-[#FEFFFF] font-bold tracking-tight leading-tight">
      Let's talk about your books
    </h1>
    <p class="text-base sm:text-lg text-[#CBCFD8] max-w-2xl mx-auto leading-relaxed">
      Tell us a little about your business and we'll come back with a clear, fixed quote within one business day. No pressure, no jargon.
    </p>
    <div class="flex flex-wrap justify-center gap-4 pt-2">
      <a href="#contact-form" class="bg-[#DCA33C] hover:bg-[#C8912F] text-[#000F22] font-semibold px-8 py-3.5 rounded-lg text-sm transition-all hover:scale-[1.01] shadow-lg shadow-[#DCA33C]/10">
        Get a fixed quote
      </a>
      <a href="/pricing/" class="bg-transparent border border-[#DAA035] text-[#DAA035] hover:bg-[#DAA035] hover:text-[#000F22] px-8 py-3.5 rounded-lg text-sm transition-all">
        See pricing first
      </a>
    </div>
  </div>
</section>

<!-- ════════════════════════════ CONTACT QUICK-INFO STRIP ════ -->
<section class="bg-[#0A1628] py-10 border-b border-gray-950">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {[
        { icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', label: 'Email', value: 'accforsmes@gmail.com', href: 'mailto:accforsmes@gmail.com', small: true },
        { icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z', label: 'WhatsApp', value: '+92 333 2999777', href: null, small: false },
        { icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', label: 'Response time', value: 'Within 1 business day', href: null, small: false },
        { icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z', label: 'Coverage', value: 'Singapore SMEs', href: null, small: false },
      ].map((item) => (
        <div class="bg-[#000F22] p-4 rounded-xl border border-gray-800 flex items-start gap-3 hover:border-[#DAA035]/30 transition-colors">
          <div class="w-8 h-8 rounded-lg bg-[#DAA035]/10 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-[#DAA035]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={item.icon}/>
            </svg>
          </div>
          <div class="min-w-0">
            <p class="text-[10px] text-gray-500 font-mono uppercase tracking-wider mb-0.5">{item.label}</p>
            {item.href
              ? <a href={item.href} class={`text-[#FEFFFF] font-semibold hover:text-[#DAA035] transition-colors ${item.small ? 'text-[11px] break-all' : 'text-sm'}`}>{item.value}</a>
              : <p class="text-sm text-[#FEFFFF] font-semibold leading-snug">{item.value}</p>
            }
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════════════ SPLIT 1: What happens after? (dark, text L / visual R) ════ -->
<section class="bg-[#000F22] py-20 border-b border-gray-950/50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <!-- Text -->
      <div class="lg:col-span-7 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">AFTER YOU CONTACT US</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#FEFFFF] font-extrabold tracking-tight">
          What happens after you get in touch?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#0A1628] text-[#FEFFFF] shadow-inner">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#FEFFFF]">
            You'll hear back within one business day. We ask a few quick questions about your transaction volume and what you need, give you a fixed monthly quote with no obligation, and if it's a fit, we handle a clean handover onto Xero or QuickBooks. No pressure, no long sales process.
          </p>
        </div>
        <div class="grid grid-cols-3 gap-3 pt-2">
          {[
            { n: '24h', label: 'Response time' },
            { n: 'S$0', label: 'Transition cost' },
            { n: '1 call', label: 'All you need' },
          ].map((stat) => (
            <div class="bg-[#0A1628] border border-gray-800 rounded-xl p-4 text-center">
              <span class="block text-2xl font-black text-[#DAA035] tracking-tight">{stat.n}</span>
              <span class="block text-[11px] text-gray-500 font-mono uppercase tracking-wide mt-1">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Visual: Process timeline -->
      <div class="lg:col-span-5 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="flex items-center justify-between border-b border-gray-800 pb-3 mb-6 font-mono">
              <span class="text-xs text-[#DAA035] font-bold uppercase tracking-wider">Onboarding Pipeline</span>
              <span class="text-[10px] bg-emerald-500/15 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded font-bold uppercase">LIVE</span>
            </div>

            <div class="relative space-y-0">
              <!-- Connector line -->
              <div class="absolute left-4 top-5 bottom-5 w-px bg-gray-800"></div>

              {[
                { step: '01', label: 'Form Submitted', sub: 'We receive your details securely', status: 'RECEIVED', statusClass: 'text-emerald-400 bg-emerald-500/15 border-emerald-500/20', dotClass: 'bg-emerald-500' },
                { step: '02', label: 'Scope Review', sub: 'Mehdi reviews your transaction volume', status: 'IN REVIEW', statusClass: 'text-amber-400 bg-amber-500/15 border-amber-500/20 animate-pulse', dotClass: 'bg-amber-500 animate-pulse' },
                { step: '03', label: 'Fixed Quote Sent', sub: 'Clear monthly fee, no hidden costs', status: 'PENDING', statusClass: 'text-gray-500 bg-gray-800/50 border-gray-700', dotClass: 'bg-gray-600' },
                { step: '04', label: 'Xero Handover', sub: 'We onboard you, zero downtime', status: 'PENDING', statusClass: 'text-gray-500 bg-gray-800/50 border-gray-700', dotClass: 'bg-gray-600' },
              ].map((row) => (
                <div class="flex items-start gap-4 py-3.5 relative z-10">
                  <div class={`w-8 h-8 rounded-full border-2 border-gray-800 flex items-center justify-center shrink-0 ${row.dotClass.includes('animate') ? 'border-amber-500/40' : ''}`} style="background: #0A1628;">
                    <span class={`w-2.5 h-2.5 rounded-full ${row.dotClass}`}></span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-2 flex-wrap">
                      <span class="text-xs font-bold text-white">{row.label}</span>
                      <span class={`text-[9px] font-mono font-bold uppercase border px-1.5 py-0.5 rounded ${row.statusClass}`}>{row.status}</span>
                    </div>
                    <span class="text-[11px] text-gray-500 leading-snug block mt-0.5">{row.sub}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="text-[10px] text-gray-600 font-mono text-center pt-4 border-t border-gray-800 mt-4">
            *Typical onboarding timeline: 5&ndash;7 business days
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════ SPLIT 2: Remote delivery (light, visual L / text R) ════ -->
<section class="bg-[#EDF0F5] py-20 border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <!-- Visual: Remote pipeline -->
      <div class="lg:col-span-5 order-2 lg:order-1 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="text-center pb-3 border-b border-gray-800 font-mono mb-6">
              <span class="text-xs text-[#DAA035] uppercase font-bold tracking-widest block">Remote Operations Hub</span>
              <span class="text-[11px] text-gray-400 mt-0.5 block">Karachi &rarr; Singapore &bull; Encrypted</span>
            </div>

            <!-- Timezone display -->
            <div class="grid grid-cols-2 gap-3 mb-6">
              <div class="bg-[#020B16] rounded-xl p-3 border border-gray-800 text-center">
                <span class="text-[10px] font-mono text-gray-500 uppercase tracking-wider block mb-1">Karachi</span>
                <span class="text-lg font-black text-white font-mono">PKT</span>
                <span class="block text-[10px] text-gray-600 font-mono">GMT+5</span>
              </div>
              <div class="bg-[#020B16] rounded-xl p-3 border border-[#DAA035]/30 text-center">
                <span class="text-[10px] font-mono text-[#DAA035] uppercase tracking-wider block mb-1">Singapore</span>
                <span class="text-lg font-black text-[#DAA035] font-mono">SGT</span>
                <span class="block text-[10px] text-gray-500 font-mono">GMT+8</span>
              </div>
            </div>

            <!-- Pipeline steps -->
            <div class="relative space-y-4 pl-4 border-l border-gray-800">
              {[
                { n: '1', title: 'You upload documents', sub: 'Xero bank feed or secure file share' },
                { n: '2', title: 'Books reconciled remotely', sub: 'Fully SFRS-compliant, every month' },
                { n: '3', title: 'Reports delivered to you', sub: 'P&L, balance sheet, management pack' },
              ].map((step) => (
                <div class="flex items-start gap-3 relative z-10 font-sans">
                  <div class="w-6 h-6 rounded-full bg-[#DAA035]/10 text-[#DAA035] border border-[#DAA035]/35 font-mono text-xs font-bold flex items-center justify-center shrink-0">{step.n}</div>
                  <div>
                    <span class="block text-xs font-bold text-white">{step.title}</span>
                    <span class="block text-[11px] text-[#CBCFD8] leading-normal">{step.sub}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="flex items-center justify-center gap-2 pt-4 border-t border-gray-800 mt-4">
            <div class="w-2 h-2 rounded-full bg-emerald-500"></div>
            <span class="text-[10px] text-gray-500 font-mono uppercase tracking-wider">256-bit SSL encrypted pipeline</span>
          </div>
        </div>
      </div>

      <!-- Text -->
      <div class="lg:col-span-7 order-1 lg:order-2 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">REMOTE DELIVERY</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">
          Do we work with businesses outside Singapore hours?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#F2F4F7] text-[#000F22] shadow-sm">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#000F22]">
            Yes. We're a remote service based in Karachi, working with Singapore small businesses on cloud accounting. We align to Singapore business hours and respond within a business day, so being remote never slows anything down.
          </p>
        </div>
        <div class="space-y-4 text-sm sm:text-base leading-relaxed text-gray-700">
          <p>Everything runs on Xero or QuickBooks Online, which you can access any time. You're never waiting on an office to open.</p>
        </div>
        <!-- Trust badges -->
        <div class="flex flex-wrap gap-3 pt-2">
          {[
            { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', label: 'SFRS Compliant' },
            { icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z', label: 'Encrypted' },
            { icon: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z', label: 'Cloud-based' },
          ].map((badge) => (
            <div class="flex items-center gap-2 bg-white border border-gray-200 px-3 py-1.5 rounded-lg shadow-sm">
              <svg class="w-4 h-4 text-[#DAA035]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={badge.icon}/>
              </svg>
              <span class="text-xs font-mono font-bold text-[#000F22] uppercase tracking-wide">{badge.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════ SPLIT 3: What to prepare (dark, text L / visual R) ════ -->
<section class="bg-[#061224] py-20 border-b border-gray-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <!-- Text -->
      <div class="lg:col-span-7 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">FIRST CALL PREP</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#FEFFFF] font-extrabold tracking-tight">
          What should you have ready for the first call?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#0A1628] text-[#FEFFFF] shadow-inner">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#FEFFFF]">
            Nothing formal. It helps to know your rough monthly transaction volume, whether you have employees on payroll, and which software you use, if any. If you don't know these yet, that's fine — we'll work it out together on the call.
          </p>
        </div>
        <div class="space-y-3 text-sm text-[#CBCFD8]">
          {[
            'Rough number of monthly transactions (invoices, bills, receipts)',
            'Number of employees on payroll, if any',
            'Current accounting software, or none at all',
            "Your year-end date, if you know it — if not, that's fine",
          ].map((item) => (
            <div class="flex items-start gap-3">
              <span class="w-5 h-5 rounded-full bg-[#DAA035]/15 text-[#DAA035] text-xs font-mono font-bold flex items-center justify-center shrink-0 mt-0.5 border border-[#DAA035]/25">&#10003;</span>
              <span>{item}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Visual: Prep checklist card -->
      <div class="lg:col-span-5 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="pb-3 border-b border-gray-800 font-mono mb-6">
              <span class="text-xs text-[#DAA035] uppercase font-bold text-center block">Scoping Checklist</span>
            </div>

            <!-- Transaction volume -->
            <div class="mb-5">
              <span class="text-[10px] font-mono text-gray-500 uppercase tracking-wider block mb-2">Monthly Transactions</span>
              <div class="grid grid-cols-3 gap-2">
                {[
                  { label: 'Under 30', active: true, hint: 'Starter' },
                  { label: '30–100', active: false, hint: 'Growth' },
                  { label: '100+', active: false, hint: 'Full' },
                ].map((opt) => (
                  <div class={`p-2.5 rounded-lg border text-center transition-colors ${opt.active ? 'border-[#DAA035] bg-[#DAA035]/10' : 'border-gray-800 bg-[#020B16]'}`}>
                    <span class={`block text-xs font-bold font-sans ${opt.active ? 'text-[#DAA035]' : 'text-gray-400'}`}>{opt.label}</span>
                    <span class="block text-[9px] font-mono text-gray-600 mt-0.5">{opt.hint}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- Staff -->
            <div class="mb-5">
              <span class="text-[10px] font-mono text-gray-500 uppercase tracking-wider block mb-2">Employees on Payroll</span>
              <div class="grid grid-cols-4 gap-2">
                {['None', '1–5', '6–20', '20+'].map((opt, i) => (
                  <div class={`p-2 rounded-lg border text-center ${i === 0 ? 'border-[#DAA035] bg-[#DAA035]/10' : 'border-gray-800 bg-[#020B16]'}`}>
                    <span class={`text-xs font-bold font-sans ${i === 0 ? 'text-[#DAA035]' : 'text-gray-500'}`}>{opt}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- Software -->
            <div class="mb-4">
              <span class="text-[10px] font-mono text-gray-500 uppercase tracking-wider block mb-2">Current Software</span>
              <div class="grid grid-cols-3 gap-2">
                {['Xero', 'QuickBooks', 'None/Other'].map((opt, i) => (
                  <div class={`p-2.5 rounded-lg border text-center ${i === 2 ? 'border-[#DAA035] bg-[#DAA035]/10' : 'border-gray-800 bg-[#020B16]'}`}>
                    <span class={`text-xs font-bold font-sans ${i === 2 ? 'text-[#DAA035]' : 'text-gray-400'}`}>{opt}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
          <div class="text-[10px] text-gray-600 font-mono text-center pt-4 border-t border-gray-800">
            *We configure everything for you during onboarding
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════ CONTACT FORM SPLIT ════ -->
<section id="contact-form" class="bg-[#000F22] py-20 border-b border-gray-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 space-y-3">
      <span class="inline-block text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold">Get In Touch</span>
      <h2 class="text-3xl sm:text-4xl font-serif text-[#FEFFFF] font-bold">Request a bespoke estimate</h2>
      <p class="text-sm text-[#CBCFD8] max-w-xl mx-auto">Fill out the form and we'll send your fixed monthly price within one business day.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

      <!-- Left: Contact info + trust signals -->
      <div class="lg:col-span-4 space-y-5">

        <!-- Direct contact -->
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 space-y-5">
          <h3 class="text-sm font-mono text-[#DAA035] uppercase tracking-wider font-bold border-b border-gray-800 pb-3">Direct Contact</h3>

          {[
            { icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', label: 'Email', value: 'accforsmes@gmail.com', href: 'mailto:accforsmes@gmail.com', small: true },
            { icon: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z', label: 'WhatsApp', value: '+92 333 2999777', href: 'https://wa.me/923332999777', small: false },
