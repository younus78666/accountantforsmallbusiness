import GSTCalculator from '../../islands/GSTCalculator';

const title = 'GST Registration Calculator Singapore 2026 | Check Your Threshold | AFSB';
const description = 'Free Singapore GST registration calculator for 2026. Find out if your business must register for GST, how far you are from the S$1 million threshold, and what happens if you miss the deadline.';

const schemaJsonLd = `<script type="application/ld+json">
