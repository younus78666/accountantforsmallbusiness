    name: 'Starter', price: 'S$90', period: '/month', tagline: 'For low-volume sole proprietors',
    features: ['Monthly bookkeeping','Bank reconciliation','Unaudited financial statements','Management reports','Xero subscription included'],
    cta: { label: 'Get a fixed quote', href: '/contact/' }, highlighted: false,
  },
  {
    name: 'Growth', price: 'S$250', period: '/month', tagline: 'For growing SMEs',
    features: ['Everything in Starter','Accounts payable & receivable','GST tracking & support','Priority response','Monthly strategy call'],
    cta: { label: 'Get a fixed quote', href: '/contact/' }, highlighted: true,
  },
  {
    name: 'Full', price: 'S$450', period: '/month + S$8/employee', tagline: 'For SMEs with staff',
    features: ['Everything in Growth','Monthly payroll & CPF','Itemised payslips','Multi-entity support','Dedicated accountant'],
    cta: { label: 'Get a fixed quote', href: '/contact/' }, highlighted: false,
  },
];

const whoWeHelp = [
