const steps = [
  { n: '01', title: 'Free consultation', desc: 'Tell us about your business. We scope exactly what you need and ask the right questions about your transaction volume, GST status, and payroll.',
    path: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z' },
  { n: '02', title: 'Fixed quote sent', desc: 'You receive a clear monthly fee in writing within 24 hours. No hidden tiers, no ambiguous add-ons. You approve it and we begin.',
    path: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
  { n: '03', title: 'We take over', desc: "We onboard you onto Xero, collect your records from the previous accountant, and start month one. You don't lift a finger.",
