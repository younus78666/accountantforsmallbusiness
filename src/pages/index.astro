---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import AnswerBlock from '../components/AnswerBlock.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PricingTier from '../components/PricingTier.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import CTASection from '../components/CTASection.astro';

const title = 'Accounting Services Singapore for Small Business | AFSB';
const description = 'Affordable accounting services in Singapore for small businesses. Fixed monthly fees, Xero, GST, payroll and tax handled remotely by an expert accountant.';

const schemaJsonLd = `<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["Organization","ProfessionalService","AccountingService"],
      "@id": "https://accountantforsmallbusiness.com/#org",
      "name": "Accountant for Small Business",
      "url": "https://accountantforsmallbusiness.com/",
      "description": "Affordable accounting services in Singapore for small businesses, delivered remotely. Bookkeeping, GST, payroll and tax handled by an experienced Financial Controller.",
      "areaServed": { "@type": "Country", "name": "Singapore" },
      "priceRange": "S$60-S$400/month",
      "founder": { "@id": "https://accountantforsmallbusiness.com/#mehdi" },
      "knowsAbout": ["Accounting","Bookkeeping","Financial statements","Payroll","Management reporting","AP/AR","SFRS","Xero"],
      "sameAs": ["https://www.linkedin.com/company/", "https://sealineservices.com"]
    },
    {
      "@type": "Person",
      "@id": "https://accountantforsmallbusiness.com/#mehdi",
      "name": "Mehdi Javed",
      "jobTitle": "Financial Controller",
      "description": "Financial Controller with 15+ years managing accounting operations for SMEs and logistics businesses across Pakistan, the UAE and the United States. Executive MBA in Accounting & Finance.",
      "alumniOf": "University of Karachi",
      "knowsAbout": ["IFRS","SFRS","ERP implementation","Financial reporting","Payroll","Management accounting"],
      "sameAs": ["https://www.linkedin.com/in/mehdij/", "https://sealineservices.com"]
    },
    {
      "@type": "WebSite",
      "@id": "https://accountantforsmallbusiness.com/#website",
      "url": "https://accountantforsmallbusiness.com/",
      "name": "Accountant for Small Business",
      "publisher": { "@id": "https://accountantforsmallbusiness.com/#org" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {"@type":"Question","name":"Can a remote accountant keep my books compliant?","acceptedAnswer":{"@type":"Answer","text":"Yes. Bookkeeping, financial statements and payroll meet Singapore SFRS and CPF standards regardless of where the accountant is based, prepared on Xero and ready for your tax agent."}},
        {"@type":"Question","name":"How much do accounting services cost in Singapore?","acceptedAnswer":{"@type":"Answer","text":"Accounting services in Singapore typically cost between S$60 and S$400 per month depending on transaction volume, GST status and payroll. We charge a transparent fixed monthly fee within that range."}},
        {"@type":"Question","name":"Which accounting software do you use?","acceptedAnswer":{"@type":"Answer","text":"We work in both Xero and QuickBooks Online, whichever you prefer. Both give you real-time access to your numbers."}},
        {"@type":"Question","name":"Do you handle payroll and management reports?","acceptedAnswer":{"@type":"Answer","text":"Yes. We run monthly payroll with CPF and itemised payslips, and provide clear monthly management reports."}},
        {"@type":"Question","name":"How do I switch from my current accountant?","acceptedAnswer":{"@type":"Answer","text":"We manage the handover, collecting your records, setting up Xero and picking up your filings with no gap in compliance."}}
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Home","item":"https://accountantforsmallbusiness.com/"}
      ]
    }
  ]
}
<\/script>`;

const services = [
  {
    title: 'Accounting & Bookkeeping',
    blurb: 'Clean, SFRS-compliant books every month',
    href: '/accounting-services-singapore/',
  },
  {
    title: 'Bookkeeping',
    blurb: 'Day-to-day records, reconciled on Xero',
    href: '/bookkeeping-services-singapore/',
  },
  {
    title: 'Management Reports',
    blurb: 'Monthly numbers you can act on',
    href: '/accounting-services-singapore/',
  },
  {
    title: 'AP / AR',
    blurb: 'Payables and receivables tracked',
    href: '/accounting-services-singapore/',
  },
  {
    title: 'Payroll & CPF',
    blurb: 'Monthly payroll, payslips, CPF',
    href: '/payroll-services-singapore/',
  },
  {
    title: 'Financial Statements',
    blurb: 'SFRS-compliant year-end accounts',
    href: '/accounting-services-singapore/',
  },
];

const faqs = [
  {
    q: 'Can a remote accountant keep my books compliant?',
    a: 'Yes. Your bookkeeping, financial statements and payroll all meet Singapore SFRS and CPF standards regardless of where your accountant is based, prepared on Xero and ready for your tax agent to file.',
  },
  {
    q: 'Is my financial data safe?',
    a: 'Yes. Data is shared through encrypted, access-controlled channels and stored securely. Only your assigned accountant can access your records, and we work under confidentiality terms.',
  },
  {
    q: 'Which accounting software do you use?',
    a: 'We work in both Xero and QuickBooks Online, whichever you prefer. Both are SFRS-friendly and give you real-time access to your numbers.',
  },
  {
    q: 'Do you handle payroll and management reports?',
    a: 'Yes. We run monthly payroll with CPF and itemised payslips, and provide clear monthly management reports, all within your package.',
  },
  {
    q: 'How do I switch from my current accountant?',
    a: 'We manage the handover for you, collecting your records, setting up Xero and picking up your filings with no gap in compliance.',
  },
];

// CONFIRM - all prices below are placeholders awaiting client confirmation
const pricingTiers = [
  {
    name: 'Starter',
    price: 'S$90',
    period: '/month',
    tagline: 'For low-volume sole proprietors',
    features: [
      'Monthly bookkeeping',
      'Bank reconciliation',
      'Unaudited financial statements',
      'Management reports',
      'Xero subscription included',
    ],
    cta: { label: 'Get a fixed quote', href: '/contact/' },
    highlighted: false,
  },
  {
    name: 'Growth',
    price: 'S$250',
    period: '/month',
    tagline: 'For growing SMEs',
    features: [
      'Everything in Starter',
      'Accounts payable & receivable',
      'GST tracking & support',
      'Priority response',
      'Monthly strategy call',
    ],
    cta: { label: 'Get a fixed quote', href: '/contact/' },
    highlighted: true,
  },
  {
    name: 'Full',
    price: 'S$450',
    period: '/month + S$8/employee',
    tagline: 'For SMEs with staff',
    features: [
      'Everything in Growth',
      'Monthly payroll & CPF',
      'Itemised payslips',
      'Multi-entity support',
      'Dedicated accountant',
    ],
    cta: { label: 'Get a fixed quote', href: '/contact/' },
    highlighted: false,
  },
];
---

<BaseLayout {title} {description} schemaJsonLd={schemaJsonLd}>

  <!-- Hero -->
  <Hero
    h1="Accounting Services in Singapore"
    h1Accent="for Small Businesses"
    subhead="Fixed monthly fees. No surprises. Your books, payroll and financial statements handled remotely by a Financial Controller with 15+ years of experience, so you can get back to running your business."
    primaryCta={{ label: 'Book a free consultation', href: '/contact/' }}
    secondaryCta={{ label: 'Get a fixed quote', href: '/contact/' }}
    trustItems={[
      "Xero & QuickBooks",
      "SFRS-ready books",
      "15+ years' experience",
      "Serving Singapore SMEs remotely",
    ]}
  />

  <!-- Section 1: What services? (light-bg) -->
  <section class="bg-light-bg py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="max-w-3xl">
        <h2 class="text-3xl lg:text-4xl text-ink mb-4" style="font-family: var(--font-serif);">
          What accounting services do small businesses in Singapore need?
        </h2>
        <AnswerBlock>
          <p class="text-base leading-relaxed text-ink">
            Most Singapore small businesses need a few core things handled well: bookkeeping, SFRS-compliant financial statements, payroll with CPF, and clear monthly management reports. Get these right and your records stay accurate, your statutory accounts are ready, and you have numbers you can actually use to run the business.
          </p>
        </AnswerBlock>
        <p class="text-base leading-relaxed text-ink/80 mt-4">
          You don't need a full finance department. You need the essentials done correctly and on time. Everything most SMEs require sits inside one fixed monthly fee, so nothing slips through the cracks and you always know what you're paying.
        </p>
        <p class="text-base leading-relaxed text-ink/80 mt-4">
          Day to day that means monthly bookkeeping and bank reconciliation, SFRS-compliant unaudited financial statements, accounts payable and receivable, monthly payroll with CPF and itemised payslips, and management reports you can read.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 2: How much does it cost? (white) -->
  <section class="bg-white py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="max-w-3xl">
        <h2 class="text-3xl lg:text-4xl text-ink mb-4" style="font-family: var(--font-serif);">
          How much do accounting services cost in Singapore?
        </h2>
        <AnswerBlock>
          <p class="text-base leading-relaxed text-ink">
            Accounting services in Singapore typically cost between S$60 and S$400 per month, depending on your transaction volume, GST status and payroll headcount. We charge a transparent fixed monthly fee in that range. You'll know the exact figure before you commit, with no hidden add-ons.
          </p>
        </AnswerBlock>
        <p class="text-base leading-relaxed text-ink/80 mt-4">
          Pricing confusion is the number one frustration we hear. One firm quotes S$75, another over S$1,000, and it's never clear what's included. Our fix is simple: publish what each package covers and quote a flat monthly fee up front.
        </p>
        <p class="text-base leading-relaxed text-ink/80 mt-4">
          See full pricing on our <a href="/pricing/" class="text-gold hover:underline">pricing page</a>, or get a fixed quote in one short call.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 3: In-house vs outsource? (light-bg) -->
  <section class="bg-light-bg py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="max-w-3xl">
        <h2 class="text-3xl lg:text-4xl text-ink mb-4" style="font-family: var(--font-serif);">
          Should you hire an in-house accountant or outsource?
        </h2>
        <AnswerBlock>
          <p class="text-base leading-relaxed text-ink">
            For most small businesses in Singapore, outsourcing is cheaper and safer than hiring in-house. A full-time accountant costs a monthly salary plus CPF, leave and software, often S$3,000+ a month, and is idle when transaction volume is low. Outsourcing gives you the same expertise for a fraction of the cost.
          </p>
        </AnswerBlock>
        <p class="text-base leading-relaxed text-ink/80 mt-4">
          Hire in-house and you pay salary, CPF, benefits, software and training, then carry the risk yourself if that person leaves or makes an error.
        </p>
        <p class="text-base leading-relaxed text-ink/80 mt-4">
          Outsource to us and you get one fixed fee, a dedicated qualified accountant, compliant software, and continuity you never have to manage. Scale the service up or down as the business grows.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 4: Remote delivery (white) -->
  <section class="bg-white py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="max-w-3xl">
        <h2 class="text-3xl lg:text-4xl text-ink mb-4" style="font-family: var(--font-serif);">
          How do you deliver Singapore accounting services remotely?
        </h2>
        <AnswerBlock>
          <p class="text-base leading-relaxed text-ink">
            We work entirely in the cloud using Xero, secure document sharing and scheduled video calls. Because we operate remotely with lower overhead, our fees are lower than a traditional Singapore firm's, while every filing still meets ACRA, IRAS and SFRS requirements. You get the same compliance, less cost.
          </p>
        </AnswerBlock>
        <p class="text-base leading-relaxed text-ink/80 mt-4">
          Remote doesn't mean hands-off. You get a named accountant, real-time access to your numbers on Xero, monthly reports, and direct answers when you have a question. Your records stay confidential and encrypted at every step.
        </p>
        <p class="text-base leading-relaxed text-ink/80 mt-4">
          Founder Mehdi Javed has managed accounting operations for SMEs and logistics businesses across Pakistan, the UAE and the United States, so your books are in experienced hands, wherever they're kept.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 5: How to choose (light-bg) -->
  <section class="bg-light-bg py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="max-w-3xl">
        <h2 class="text-3xl lg:text-4xl text-ink mb-4" style="font-family: var(--font-serif);">
          How do you choose the right accountant for your business?
        </h2>
        <AnswerBlock>
          <p class="text-base leading-relaxed text-ink">
            Three things matter most. Genuine local compliance knowledge across ACRA, IRAS, GST and SFRS. Pricing you can see before you sign. And direct access to a qualified person instead of a rotating call centre. A good accountant files on time, explains your numbers, and flags problems before they turn into penalties.
          </p>
        </AnswerBlock>
        <p class="text-base leading-relaxed text-ink/80 mt-4">
          Most Singapore firms hide their fees and their people. With us, you know exactly what you pay and exactly who handles your account. You talk to Mehdi, not a queue.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 6: Missing deadlines (white) -->
  <section class="bg-white py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="max-w-3xl">
        <h2 class="text-3xl lg:text-4xl text-ink mb-4" style="font-family: var(--font-serif);">
          What happens if you miss an ACRA or IRAS deadline?
        </h2>
        <AnswerBlock>
          <p class="text-base leading-relaxed text-ink">
            Messy or late records cause real problems. Your statutory accounts slip, your tax agent cannot file on time, and decisions get made on numbers you cannot trust. We keep your books current and your financial statements ready, so nothing holds up your year-end.
          </p>
        </AnswerBlock>
        <p class="text-base leading-relaxed text-ink/80 mt-4">
          We close your books monthly and keep your statements ready ahead of year-end, so whoever files your tax and GST has clean numbers to work from. No last-minute scrambles, no chasing missing records.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 7: Services grid (navy) -->
  <section class="bg-navy py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold uppercase tracking-widest gold-gradient mb-3">What we do</p>
        <h2 class="text-3xl lg:text-4xl text-white" style="font-family: var(--font-serif);">
          Core accounting services for Singapore SMEs
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map((svc) => (
          <ServiceCard
            title={svc.title}
            blurb={svc.blurb}
            href={svc.href}
            dark={true}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Section 8: Who we help (light-bg) -->
  <section class="bg-light-bg py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="max-w-3xl">
        <h2 class="text-3xl lg:text-4xl text-ink mb-4" style="font-family: var(--font-serif);">
          Who do you help?
        </h2>
        <AnswerBlock>
          <p class="text-base leading-relaxed text-ink">
            We work with Singapore small businesses and SMEs, sole proprietors, new Pte Ltd companies, e-commerce sellers, agencies and growing startups with one to twenty staff. If you'd rather run your business than wrestle with IRAS forms, you're who we built this for.
          </p>
        </AnswerBlock>
      </div>
    </div>
  </section>

  <!-- Section 9: Pricing (navy) -->
  <section class="bg-navy py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold uppercase tracking-widest gold-gradient mb-3">Transparent pricing</p>
        <h2 class="text-3xl lg:text-4xl text-white mb-4" style="font-family: var(--font-serif);">
          Fixed monthly fees, published up front
        </h2>
        <p class="text-muted max-w-xl mx-auto">No hidden costs. No locked tiers you can't leave. See the <a href="/pricing/" class="text-gold hover:underline">full pricing page</a> or get a custom quote.</p>
      </div>
      <!-- CONFIRM all prices below are placeholders -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {pricingTiers.map((tier) => (
          <PricingTier
            name={tier.name}
            price={tier.price}
            period={tier.period}
            tagline={tier.tagline}
            features={tier.features}
            cta={tier.cta}
            highlighted={tier.highlighted}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Section 10: Why choose us / About Mehdi (light-bg) -->
  <section class="bg-light-bg py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="max-w-3xl">
        <h2 class="text-3xl lg:text-4xl text-ink mb-4" style="font-family: var(--font-serif);">
          Why choose accountantforsmallbusiness.com?
        </h2>
        <AnswerBlock>
          <p class="text-base leading-relaxed text-ink">
            Because you get a qualified Financial Controller, transparent fixed pricing, and direct personal service, not a faceless retainer. Mehdi Javed brings 15+ years of multi-entity finance experience, an Executive MBA in Accounting &amp; Finance, and a track record of 28% faster financial close and 10% cost reduction.
          </p>
        </AnswerBlock>
        <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl p-6 card-shadow">
            <div class="text-2xl font-bold mb-2 gold-gradient" style="font-family: var(--font-serif);">Expertise</div>
            <p class="text-sm text-ink/70 leading-relaxed">IFRS and SFRS reporting, ERP implementation, and automated AP/AR and payroll.</p>
          </div>
          <div class="bg-white rounded-xl p-6 card-shadow">
            <div class="text-2xl font-bold mb-2 gold-gradient" style="font-family: var(--font-serif);">Price</div>
            <p class="text-sm text-ink/70 leading-relaxed">Fixed monthly fees published up front with no hidden costs.</p>
          </div>
          <div class="bg-white rounded-xl p-6 card-shadow">
            <div class="text-2xl font-bold mb-2 gold-gradient" style="font-family: var(--font-serif);">Access</div>
            <p class="text-sm text-ink/70 leading-relaxed">Work with a dedicated accountant who knows your business, never a call centre.</p>
          </div>
        </div>
        <p class="mt-6 text-base text-ink/80">
          <a href="/about/" class="text-gold hover:underline font-medium">Read more about Mehdi.</a>
        </p>
      </div>
    </div>
  </section>

  <!-- Section 11: How to get started (white) -->
  <section class="bg-white py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="max-w-3xl">
        <h2 class="text-3xl lg:text-4xl text-ink mb-4" style="font-family: var(--font-serif);">
          How do you get started?
        </h2>
        <AnswerBlock>
          <p class="text-base leading-relaxed text-ink">
            Getting started takes three steps and one free call. You book a consultation, we assess your needs and send a fixed quote, then we onboard your business onto Xero and take over your books, usually within a week, with no downtime.
          </p>
        </AnswerBlock>
        <ol class="mt-6 flex flex-col gap-5">
          <li class="flex items-start gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-gold-btn text-navy text-sm font-bold flex items-center justify-center" style="font-family: var(--font-serif);">1</span>
            <div>
              <span class="font-semibold text-ink">Book a free consultation</span>
              <span class="text-ink/70"> &ndash; tell us about your business, no obligation.</span>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-gold-btn text-navy text-sm font-bold flex items-center justify-center" style="font-family: var(--font-serif);">2</span>
            <div>
              <span class="font-semibold text-ink">Get your fixed quote</span>
              <span class="text-ink/70"> &ndash; a clear monthly fee for exactly what you need.</span>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-gold-btn text-navy text-sm font-bold flex items-center justify-center" style="font-family: var(--font-serif);">3</span>
            <div>
              <span class="font-semibold text-ink">We take over</span>
              <span class="text-ink/70"> &ndash; we onboard you onto Xero and handle the handover from your current accountant.</span>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- Section 12: FAQ (light-bg) -->
  <section class="bg-light-bg py-24">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="max-w-3xl">
        <h2 class="text-3xl lg:text-4xl text-ink mb-10" style="font-family: var(--font-serif);">
          Frequently asked questions
        </h2>
        <FaqAccordion items={faqs} />
      </div>
    </div>
  </section>

  <!-- Closing CTA (navy) -->
  <CTASection
    heading="Ready to stop worrying about your books?"
    subtext="Book a free consultation with Mehdi today and get a fixed monthly quote. No obligation, no jargon."
    primaryLabel="Book a free consultation"
    primaryHref="/contact/"
  />

</BaseLayout>
