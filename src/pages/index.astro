        <div class="hidden md:block absolute top-14 left-[calc(16.67%+1.5rem)] right-[calc(16.67%+1.5rem)] h-px" style="background: linear-gradient(90deg, transparent 0%, rgba(220,163,60,0.35) 20%, rgba(220,163,60,0.35) 80%, transparent 100%);"></div>

        {steps.map((step) => (
          <div class="group relative bg-navy-panel rounded-2xl p-8 border border-white/8 hover:border-gold/30 transition-all duration-200 hover:-translate-y-1">
