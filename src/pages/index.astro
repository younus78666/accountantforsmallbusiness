      <svg class="absolute inset-0 w-full h-full opacity-[0.03]" xmlns="http://www.w3.org/2000/svg">
        <defs><pattern id="dots-price" width="36" height="36" patternUnits="userSpaceOnUse"><circle cx="18" cy="18" r="1.5" fill="#DAA035"/></pattern></defs>
        <rect width="100%" height="100%" fill="url(#dots-price)"/>
