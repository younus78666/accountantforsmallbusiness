import ContactSection from '../components/ContactSection.astro';

const title = 'Accounting Services Singapore for Small Business | AFSB';
const description = 'Affordable accounting services in Singapore for small businesses. Fixed monthly fees, Xero, GST, payroll and tax handled remotely by an expert accountant.';

const schemaJsonLd = `<script type="application/ld+json">
{
  "@context": "https://schema.org",
