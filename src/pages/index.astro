---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlanCalculator from '../islands/PlanCalculator';
import TestimonialsCarousel from '../islands/TestimonialsCarousel';

const title = 'Accounting Services Singapore for Small Business | AFSB';
const description = 'Affordable accounting services in Singapore for small businesses. Fixed monthly fees, Xero, GST, payroll and tax handled remotely by an expert accountant.';

const schemaJsonLd = `<script type="application/ld+json">
{"@context":"https://schema.org","@graph":[{"@type":["Organization","ProfessionalService","AccountingService"],"@id":"https://accountantforsmallbusiness.com/#org","name":"Accountant for Small Business","url":"https://accountantforsmallbusiness.com/","description":"Affordable accounting services in Singapore for small businesses, delivered remotely.","areaServed":{"@type":"Country","name":"Singapore"},"priceRange":"S$60-S$400/month","founder":{"@id":"https://accountantforsmallbusiness.com/#mehdi"}},{"@type":"Person","@id":"https://accountantforsmallbusiness.com/#mehdi","name":"Mehdi Javed","jobTitle":"Financial Controller","description":"Financial Controller with 15+ years managing accounting operations for SMEs across Pakistan, UAE and the United States. Executive MBA in Accounting & Finance."},{"@type":"WebSite","@id":"https://accountantforsmallbusiness.com/#website","url":"https://accountantforsmallbusiness.com/","name":"Accountant for Small Business","publisher":{"@id":"https://accountantforsmallbusiness.com/#org"}},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Can a remote accountant keep my books compliant?","acceptedAnswer":{"@type":"Answer","text":"Yes. Bookkeeping, financial statements and payroll meet Singapore SFRS and CPF standards regardless of where the accountant is based."}},{"@type":"Question","name":"How much do accounting services cost in Singapore?","acceptedAnswer":{"@type":"Answer","text":"Typically S$60 to S$400 per month depending on transaction volume, GST status and payroll headcount."}}]}]}
<\/script>`;
---

<BaseLayout {title} {description} schemaJsonLd={schemaJsonLd}>

  <!-- ═══════════════════════════════════ HERO ════════════ -->
  <section class="relative overflow-hidden bg-gradient-to-b from-[#000F22] to-[#0A1628] pt-24 pb-20 border-b border-gray-900 text-center">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(circle at center, rgba(220,163,60,0.03) 0%, transparent 70%);"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

      <span class="inline-block py-1.5 px-3 rounded-full bg-[#DAA035]/15 border border-[#DAA035]/30 text-[#DAA035] text-xs font-mono uppercase tracking-widest mb-6">
        Serving Singapore SMEs Remotely
      </span>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-serif text-[#FEFFFF] font-bold tracking-tight mb-6 leading-tight max-w-3xl mx-auto">
        Accounting Services in Singapore for Small Businesses
      </h1>

      <p class="text-base sm:text-lg md:text-xl text-[#CBCFD8] mb-10 max-w-2xl mx-auto leading-relaxed font-sans">
        Fixed monthly fees. No surprises. Your books, payroll and financial statements handled remotely by a Financial Controller with 15+ years of experience, so you can get back to running your business.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
        <a href="/contact/" class="w-full sm:w-auto bg-[#DCA33C] hover:bg-[#C8912F] text-[#000F22] font-semibold px-8 py-3.5 rounded-lg text-base transition-all hover:scale-[1.01] shadow-lg text-center">
          Book a free consultation
        </a>
        <a href="/pricing/" class="w-full sm:w-auto bg-transparent border border-[#DAA035] hover:bg-[#DAA035] hover:text-[#000F22] text-[#DAA035] font-semibold px-8 py-3.5 rounded-lg text-base transition-all text-center">
          Get a fixed quote
        </a>
      </div>

      <!-- Trust strip -->
      <div class="border-t border-gray-800/80 pt-8 mt-12 grid grid-cols-2 md:grid-cols-4 gap-6 text-xs text-[#CBCFD8] font-mono tracking-wider">
        {['Xero & QuickBooks', 'SFRS-ready books', "15+ years' experience", 'Serving clients remotely'].map((item) => (
          <div class="flex items-center justify-center gap-2">
            <span class="w-2 h-2 rounded-full bg-[#DAA035]"></span>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════ PLAN CALCULATOR (React island) ════════════ -->
  <PlanCalculator client:load />

  <!-- ═══════════════════ SECTION 1: What services? (light bg, left text) ════════════ -->
  <section class="bg-[#F8FAFC] text-[#000F22] py-20 border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 font-sans">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

        <div class="lg:col-span-7 flex flex-col justify-center space-y-6">
          <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">SERVICES NEEDED</span>
          <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">
            What accounting services do small businesses in Singapore need?
          </h2>
          <div class="answer-block-light">
            Most Singapore small businesses need a few core things handled well: bookkeeping, SFRS-compliant financial statements, payroll with CPF, and clear monthly management reports. Get these right and your records stay accurate, your statutory accounts are ready, and you have numbers you can actually use to run the business.
          </div>
          <div class="space-y-4 text-sm sm:text-base leading-relaxed text-gray-700">
            <p>You don't need a full finance department. You need the essentials done correctly and on time. Everything most SMEs require sits inside one fixed monthly fee, so nothing slips through the cracks and you always know what you're paying.</p>
            <p>Day to day that means monthly bookkeeping and bank reconciliation, SFRS-compliant unaudited financial statements, accounts payable and receivable, monthly payroll with CPF and itemised payslips, and management reports you can read.</p>
          </div>
        </div>

        <!-- WhatServicesVisual -->
        <div class="lg:col-span-5 h-full">
          <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
            <div>
              <div class="flex items-center justify-between border-b border-gray-800 pb-3 font-mono">
                <span class="text-xs text-[#DAA035] font-bold uppercase tracking-wider">AFSB Singapore ledger</span>
                <span class="text-[10px] uppercase bg-emerald-500/15 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded font-bold">LIVE SYNCED</span>
              </div>
              <div class="space-y-4 font-sans mt-6">
                {[
                  { label: 'Monthly Bookkeeping & Reconciling', status: 'COMPLETED', color: 'bg-emerald-500', textColor: 'text-emerald-400', pulse: false },
                  { label: 'SFRS Financial Statement Drafting', status: 'DRAFTING', color: 'bg-amber-500', textColor: 'text-amber-500', pulse: true },
                  { label: 'CPF & Staff Payroll Processing', status: 'DONE', color: 'bg-emerald-500', textColor: 'text-emerald-400', pulse: false },
                  { label: 'Qualified Controller Audit Review', status: 'ACTIVE', color: 'bg-blue-500', textColor: 'text-blue-400', pulse: false },
                ].map((row) => (
                  <div class="p-3 bg-[#020B16] rounded-xl border border-gray-800 flex items-center justify-between hover:border-gray-700 transition-colors">
                    <div class="flex items-center gap-2.5">
                      <span class={`w-2.5 h-2.5 rounded-full ${row.color} shrink-0 ${row.pulse ? 'animate-pulse' : ''}`}></span>
                      <span class="text-xs font-bold text-white">{row.label}</span>
                    </div>
                    <span class={`text-[10px] font-mono ${row.textColor} uppercase font-bold bg-[#020B16]/20 px-1.5 py-0.5 rounded`}>{row.status}</span>
                  </div>
                ))}
              </div>
            </div>
            <div class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-6">
              *Active Singapore Ledger Handover Synchronized
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ SECTION 2: How much does it cost? (dark bg, image left) ════════════ -->
  <section class="bg-[#0A1B30] text-[#CBCFD8] py-20 border-b border-gray-950/45">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

        <!-- PricingVisual -->
        <div class="lg:col-span-5 order-2 lg:order-1 h-full">
          <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between text-gray-200">
            <div>
              <div class="flex items-center justify-between border-b border-gray-800 pb-3 font-mono">
                <span class="text-xs text-[#DAA035] font-bold uppercase">Price Transparency</span>
                <span class="text-[10px] bg-emerald-500/15 text-emerald-400 px-2.5 py-1 rounded border border-emerald-500/20 font-bold uppercase">No Hidden Surcharges</span>
              </div>
              <div class="space-y-4 font-sans mt-6">
                <div class="p-3 bg-[#020B16] rounded-xl border border-gray-800 flex justify-between items-center hover:border-gray-700 transition-colors">
                  <div>
                    <span class="block text-[10px] font-mono text-[#DAA035] font-bold uppercase">Starter Tier</span>
                    <span class="text-xs font-bold text-white">Up to 30 Transactions</span>
                  </div>
                  <span class="text-base font-black font-mono text-[#DAA035] shrink-0">S$90<span class="text-[10px] font-normal text-gray-400"> /mo</span></span>
                </div>
                <div class="p-4 bg-[#0A1628] text-white rounded-xl border border-[#DAA035] flex justify-between items-center shadow-lg scale-[1.02]">
                  <div>
                    <span class="block text-[10px] font-mono text-[#DAA035] font-bold uppercase">Growth Tier</span>
                    <span class="text-xs font-bold font-sans">Up to 100 Transactions</span>
                  </div>
                  <span class="text-lg font-black font-mono text-[#DAA035] shrink-0">S$250<span class="text-[10px] font-normal text-gray-400"> /mo</span></span>
                </div>
              </div>
            </div>
            <div class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-6">
              Cancel anytime &bull; Includes Xero Connection Bundles
            </div>
          </div>
        </div>

        <div class="lg:col-span-7 order-1 lg:order-2 flex flex-col justify-center space-y-6">
          <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">COST & FEES</span>
          <h2 class="text-3xl sm:text-4xl font-sans text-[#FEFFFF] font-extrabold tracking-tight">
            How much do accounting services cost in Singapore?
          </h2>
          <div class="answer-block-dark">
            Accounting services in Singapore typically cost between S$60 and S$400 per month, depending on your transaction volume, GST status and payroll headcount. We charge a transparent fixed monthly fee in that range. You'll know the exact figure before you commit, with no hidden add-ons.
          </div>
          <div class="space-y-4 text-sm sm:text-base leading-relaxed text-[#CBCFD8] font-sans">
            <p>Pricing confusion is the number one frustration we hear. One firm quotes S$75, another over S$1,000, and it's never clear what's included. Our fix is simple: publish what each package covers and quote a flat monthly fee up front.</p>
            <p>See full pricing on our <a href="/pricing/" class="text-[#DAA035] hover:underline">pricing page</a>, or get a fixed quote in one short call.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ TESTIMONIALS CAROUSEL (React island) ════════════ -->
  <TestimonialsCarousel client:load />

  <!-- ═══════════════════════ SECTION 4: In-house vs outsource (light EDF0F5) ════════════ -->
  <section class="bg-[#EDF0F5] text-[#000F22] py-20 border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

        <div class="lg:col-span-7 flex flex-col justify-center space-y-6">
          <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">OUTSOURCING COMPARISON</span>
          <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">
            Should you hire an in-house accountant or outsource?
          </h2>
          <div class="answer-block-light">
            For most small businesses in Singapore, outsourcing is cheaper and safer than hiring in-house. A full-time accountant costs a monthly salary plus CPF, leave and software, often S$3,000+ a month, and is idle when transaction volume is low. Outsourcing gives you the same expertise for a fraction of the cost.
          </div>
          <div class="space-y-4 text-sm sm:text-base leading-relaxed text-gray-700 font-sans">
            <p>Hire in-house and you pay salary, CPF, benefits, software and training, then carry the risk yourself if that person leaves or makes an error.</p>
            <p>Outsource to us and you get one fixed fee, a dedicated qualified accountant, compliant software, and continuity you never have to manage. Scale the service up or down as the business grows.</p>
          </div>
        </div>

        <!-- OutsourceVisual -->
        <div class="lg:col-span-5 h-full">
          <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
            <div>
              <div class="text-center pb-2 border-b border-gray-800">
                <span class="text-[10px] font-mono uppercase tracking-widest text-[#DAA035] block font-bold">Monthly Operating Costs</span>
                <span class="text-sm font-extrabold text-white font-sans">Local Headcount Comparison</span>
              </div>
              <div class="space-y-4 font-sans mt-6">
                <div class="p-4 bg-red-950/20 rounded-xl border border-red-900/40 space-y-1">
                  <span class="block text-[9px] font-mono text-red-400 font-bold uppercase">In-House Staff</span>
                  <span class="block text-base font-black text-red-200">S$3,500+ <span class="text-[10px] font-normal text-gray-400">/mo</span></span>
                  <span class="block text-[11px] text-gray-400 leading-relaxed">Carries salary overheads, CPF increments, workspace tooling & licenses.</span>
                </div>
                <div class="p-4 bg-emerald-950/25 rounded-xl border border-emerald-900/40 space-y-1">
                  <span class="block text-[9px] font-mono text-[#DAA035] font-bold uppercase">AFSB Outsourced</span>
                  <span class="block text-base font-black text-emerald-300">S$90&ndash;450 <span class="text-[10px] font-normal text-gray-400">/mo</span></span>
                  <span class="block text-[11px] text-gray-400 leading-relaxed">Flat business pricing. Dedicated financial controller direct review.</span>
                </div>
              </div>
            </div>
            <div class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-6">
              *Calculated for active Singapore SMEs under Xero parameters
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ GOLD CTA FULL-WIDTH ════════════ -->
  <section class="relative py-20 w-full overflow-hidden border-b border-gray-950" style="background: linear-gradient(to right, #E5B25D, #DAA035, #B88425);">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(circle at center, rgba(255,255,255,0.15) 0%, transparent 80%);"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="bg-[#000F22]/95 backdrop-blur-md border border-[#DAA035]/30 rounded-3xl p-8 sm:p-16 text-center space-y-6 shadow-2xl">
        <span class="inline-block py-1.5 px-3.5 rounded-full bg-[#DAA035]/15 border border-[#DAA035]/35 text-[#DAA035] text-[11px] font-mono uppercase tracking-wider font-bold">
          Fixed Price Guarantee
        </span>
        <h3 class="text-3xl sm:text-5xl font-sans text-white font-extrabold tracking-tight leading-tight max-w-3xl mx-auto">
          Ready to Transition to Certified Fixed-Rate Books?
        </h3>
        <p class="text-sm sm:text-base text-gray-300 max-w-2xl mx-auto leading-relaxed font-sans">
          Stop fighting catch-ups and worrying about messy ledger backlogs over precious weekends. Partner with Singapore's premier remote Financial Controller services under an honest, contract-free subscription plan with S$0 transition charges.
        </p>
        <div class="flex justify-center pt-4">
          <a href="/contact/" class="w-full sm:w-auto bg-[#DAA035] text-[#000F22] hover:bg-[#C8912F] font-mono text-xs font-bold uppercase py-4 px-8 rounded-xl tracking-widest transition-all shadow-xl text-center">
            Book 15-Min Free Call &nbsp;&rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ SECTION 6: Remote delivery (dark 061224) ════════════ -->
  <section class="bg-[#061224] text-[#CBCFD8] py-20 border-b border-gray-950">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

        <!-- RemoteVisual -->
        <div class="lg:col-span-5 order-2 lg:order-1 h-full">
          <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
            <div>
              <div class="text-center pb-2 border-b border-gray-800 font-mono">
                <span class="text-xs text-[#DAA035] uppercase font-bold tracking-widest block">Safe Digital Pipeline</span>
                <span class="text-[11px] text-gray-400 mt-0.5 block font-bold">100% cloud delivery</span>
              </div>
              <div class="relative space-y-6 mt-6 pl-4 border-l border-gray-800">
                {[
                  { n: '1', title: 'Document Sync', desc: 'Transmit invoices or connect transaction feeds dynamically inside Xero.' },
                  { n: '2', title: 'Ledger Matching', desc: 'Books reconciled properly under strict operational SFRS compliance.' },
                  { n: '3', title: 'Named Review', desc: 'All numbers vetted directly by Mehdi Javed (Chartered Accountant / FC).' },
                ].map((step) => (
                  <div class="flex items-start gap-3.5 relative z-10 font-sans">
                    <div class="w-6 h-6 rounded-full bg-[#DAA035]/10 text-[#DAA035] border border-[#DAA035]/35 font-mono text-xs font-bold flex items-center justify-center shrink-0">{step.n}</div>
                    <div>
                      <span class="block text-xs font-bold text-white">{step.title}</span>
                      <span class="block text-[11px] text-[#CBCFD8] leading-normal">{step.desc}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <div class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-6">
              *256-Bit SSL Encrypted Ledger Links
            </div>
          </div>
        </div>

        <div class="lg:col-span-7 order-1 lg:order-2 flex flex-col justify-center space-y-6">
          <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">REMOTE ENGINE</span>
          <h2 class="text-3xl sm:text-4xl font-sans text-[#FEFFFF] font-extrabold tracking-tight">
            How do you deliver Singapore accounting services remotely?
          </h2>
          <div class="answer-block-dark">
            We work entirely in the cloud using Xero, secure document sharing and scheduled video calls. Because we operate remotely with lower overhead, our fees are lower than a traditional Singapore firm's, while every filing still meets ACRA, IRAS and SFRS requirements. You get the same compliance, less cost.
          </div>
          <div class="space-y-4 text-sm sm:text-base leading-relaxed text-[#CBCFD8] font-sans">
            <p>Remote doesn't mean hands-off. You get a named accountant, real-time access to your numbers on Xero, monthly reports, and direct answers when you have a question. Your records stay confidential and encrypted at every step.</p>
            <p>Founder Mehdi Javed has managed accounting operations for SMEs and logistics businesses across Pakistan, the UAE and the United States, so your books are in experienced hands, wherever they're kept.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ SERVICES CARD GRID (light EBF3FC) ════════════ -->
  <section class="bg-[#EBF3FC] py-20 border-b border-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">What We Do</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">
          Structured Bookkeeping & Financial Reporting
        </h2>
        <p class="text-sm text-[#000F22] leading-relaxed font-sans font-medium">
          Six core financial columns managed by a dedicated named Financial Controller. Each service is custom integrated with Xero or QuickBooks.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { n:'01', title:'Accounting & Bookkeeping', desc:'Clean, SFRS-compliant ledger books updated remotely every month, finalized under professional senior supervisor checkpoint verification.', href:'/accounting-services-singapore/', accent:'text-[#DAA035]', border:'hover:border-amber-500/50', numBg:'bg-amber-500/10', numColor:'text-[#DAA035]', numBorder:'border-[#DAA035]/25', iconColor:'text-[#DAA035]', bg:'bg-[#0A1628]' },
          { n:'02', title:'Daily Statement Reconciliation', desc:'Day-to-day accounts matching, voucher scanning extraction, and digital hub receipt verification on cloud ledger interfaces.', href:'/bookkeeping-services-singapore/', accent:'text-sky-400', border:'hover:border-[#DAA035]/50', numBg:'bg-sky-500/10', numColor:'text-sky-400', numBorder:'border-sky-500/25', iconColor:'text-sky-400', bg:'bg-[#081F38]' },
          { n:'03', title:'Active Management Reports', desc:'Detailed monthly cash flow charts, operating margin maps, statutory ratios, and raw transaction volumes formatted instantly.', href:'/accounting-services-singapore/', accent:'text-emerald-400', border:'hover:border-emerald-500/50', numBg:'bg-emerald-500/10', numColor:'text-emerald-400', numBorder:'border-emerald-500/25', iconColor:'text-emerald-400', bg:'bg-[#042840]' },
          { n:'04', title:'Liquidity AP / AR Tracking', desc:'Diligently logging open aging statements, tracking overdue consumer claims, and scheduling payables securely.', href:'/accounting-services-singapore/', accent:'text-purple-400', border:'hover:border-purple-500/50', numBg:'bg-purple-500/10', numColor:'text-purple-400', numBorder:'border-purple-500/25', iconColor:'text-purple-400', bg:'bg-[#0C1B2A]' },
          { n:'05', title:'Structured Payroll & CPF', desc:'Standardized salaries logs, dynamic payslips generation, CPF calculation variables, and legal Board submission schedules.', href:'/payroll-services-singapore/', accent:'text-pink-400', border:'hover:border-pink-500/50', numBg:'bg-pink-500/10', numColor:'text-pink-400', numBorder:'border-pink-500/25', iconColor:'text-pink-400', bg:'bg-[#121E2F]' },
          { n:'06', title:'Year-End Financial Statements', desc:'SFRS-compliant draft unaudited templates, compiling clean Trial Balances for your designated tax compliance filing agencies.', href:'/financial-statements-singapore/', accent:'text-teal-400', border:'hover:border-teal-500/50', numBg:'bg-teal-500/10', numColor:'text-teal-400', numBorder:'border-teal-500/25', iconColor:'text-teal-400', bg:'bg-[#05293A]' },
        ].map((card) => (
          <a
            href={card.href}
            class={`${card.bg} border border-gray-800 ${card.border} p-6 rounded-2xl relative space-y-4 group hover:-translate-y-1 transition-all cursor-pointer shadow-xl text-white overflow-hidden block`}
          >
            <div class={`absolute top-4 right-4 ${card.numBg} ${card.numColor} text-xs font-mono font-bold w-8 h-8 rounded-full flex items-center justify-center border ${card.numBorder}`}>
              {card.n}
            </div>
            <h3 class="text-lg font-bold text-white pt-2 font-sans tracking-tight">{card.title}</h3>
            <p class="text-xs text-gray-300 font-sans leading-relaxed">{card.desc}</p>
            <div class={`pt-2 text-xs ${card.accent} font-mono font-bold group-hover:underline flex items-center gap-1`}>
              Explore Option &nbsp;&rarr;
            </div>
          </a>
        ))}
      </div>
    </div>
