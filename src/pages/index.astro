      <div class="text-center">
        <a href="/contact/" class="inline-flex items-center gap-2 px-8 py-4 bg-gold-btn text-navy text-base font-700 rounded-xl hover:bg-gold-hover transition-all duration-200 hover:shadow-xl hover:shadow-gold/25 hover:-translate-y-0.5">
