        <defs><pattern id="grid-gs" width="60" height="60" patternUnits="userSpaceOnUse"><path d="M 60 0 L 0 0 0 60" fill="none" stroke="#DAA035" stroke-width="0.5"/></pattern></defs>
        <rect width="100%" height="100%" fill="url(#grid-gs)"/>
