                  <path stroke-linecap="round" stroke-linejoin="round" d={step.path} />
                </svg>
              </div>
              <div class="absolute top-1 left-1 w-12 h-12 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: rgba(220,163,60,0.14); filter: blur(12px);"></div>
