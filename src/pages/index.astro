const faqs = [
  { q: 'Can a remote accountant keep my books compliant?', a: 'Yes. Your bookkeeping, financial statements and payroll all meet Singapore SFRS and CPF standards regardless of where your accountant is based, prepared on Xero and ready for your tax agent to file.' },
  { q: 'Is my financial data safe?', a: 'Yes. Data is shared through encrypted, access-controlled channels and stored securely. Only your assigned accountant can access your records, and we work under confidentiality terms.' },
  { q: 'Which accounting software do you use?', a: 'We work in both Xero and QuickBooks Online, whichever you prefer. Both are SFRS-friendly and give you real-time access to your numbers.' },
  { q: 'Do you handle payroll and management reports?', a: 'Yes. We run monthly payroll with CPF and itemised payslips, and provide clear monthly management reports, all within your package.' },
  { q: 'How do I switch from my current accountant?', a: 'We manage the handover for you, collecting your records, setting up Xero and picking up your filings with no gap in compliance.' },
];

// CONFIRM - all prices below are placeholders awaiting client confirmation
