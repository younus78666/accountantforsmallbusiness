---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import AnswerBlock from '../components/AnswerBlock.astro';
import SplitSection from '../components/SplitSection.astro';
import ServiceCard from '../components/ServiceCard.astro';
import PricingTier from '../components/PricingTier.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import CTASection from '../components/CTASection.astro';
import StatsBanner from '../components/StatsBanner.astro';
import MiniBanner from '../components/MiniBanner.astro';
import ContactSection from '../components/ContactSection.astro';

const title = 'Accounting Services Singapore for Small Business | AFSB';
const description = 'Affordable accounting services in Singapore for small businesses. Fixed monthly fees, Xero, GST, payroll and tax handled remotely by an expert accountant.';

const schemaJsonLd = `<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["Organization","ProfessionalService","AccountingService"],
      "@id": "https://accountantforsmallbusiness.com/#org",
      "name": "Accountant for Small Business",
      "url": "https://accountantforsmallbusiness.com/",
      "description": "Affordable accounting services in Singapore for small businesses, delivered remotely. Bookkeeping, GST, payroll and tax handled by an experienced Financial Controller.",
      "areaServed": { "@type": "Country", "name": "Singapore" },
      "priceRange": "S$60-S$400/month",
      "founder": { "@id": "https://accountantforsmallbusiness.com/#mehdi" },
      "knowsAbout": ["Accounting","Bookkeeping","Financial statements","Payroll","Management reporting","AP/AR","SFRS","Xero"],
      "sameAs": ["https://www.linkedin.com/company/", "https://sealineservices.com"]
    },
    {
      "@type": "Person",
      "@id": "https://accountantforsmallbusiness.com/#mehdi",
      "name": "Mehdi Javed",
      "jobTitle": "Financial Controller",
      "description": "Financial Controller with 15+ years managing accounting operations for SMEs and logistics businesses across Pakistan, the UAE and the United States. Executive MBA in Accounting & Finance.",
      "alumniOf": "University of Karachi",
      "knowsAbout": ["IFRS","SFRS","ERP implementation","Financial reporting","Payroll","Management accounting"],
      "sameAs": ["https://www.linkedin.com/in/mehdij/", "https://sealineservices.com"]
    },
    {
      "@type": "WebSite",
      "@id": "https://accountantforsmallbusiness.com/#website",
      "url": "https://accountantforsmallbusiness.com/",
      "name": "Accountant for Small Business",
      "publisher": { "@id": "https://accountantforsmallbusiness.com/#org" }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {"@type":"Question","name":"Can a remote accountant keep my books compliant?","acceptedAnswer":{"@type":"Answer","text":"Yes. Bookkeeping, financial statements and payroll meet Singapore SFRS and CPF standards regardless of where the accountant is based, prepared on Xero and ready for your tax agent."}},
        {"@type":"Question","name":"How much do accounting services cost in Singapore?","acceptedAnswer":{"@type":"Answer","text":"Accounting services in Singapore typically cost between S$60 and S$400 per month depending on transaction volume, GST status and payroll. We charge a transparent fixed monthly fee within that range."}},
        {"@type":"Question","name":"Which accounting software do you use?","acceptedAnswer":{"@type":"Answer","text":"We work in both Xero and QuickBooks Online, whichever you prefer. Both give you real-time access to your numbers."}},
        {"@type":"Question","name":"Do you handle payroll and management reports?","acceptedAnswer":{"@type":"Answer","text":"Yes. We run monthly payroll with CPF and itemised payslips, and provide clear monthly management reports."}},
        {"@type":"Question","name":"How do I switch from my current accountant?","acceptedAnswer":{"@type":"Answer","text":"We manage the handover, collecting your records, setting up Xero and picking up your filings with no gap in compliance."}}
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Home","item":"https://accountantforsmallbusiness.com/"}
      ]
    }
  ]
}
<\/script>`;

const services = [
  {
    title: 'Accounting & Bookkeeping',
    blurb: 'Clean, SFRS-compliant books every month',
    href: '/accounting-services-singapore/',
  },
  {
    title: 'Bookkeeping',
    blurb: 'Day-to-day records, reconciled on Xero',
    href: '/bookkeeping-services-singapore/',
  },
  {
    title: 'Management Reports',
    blurb: 'Monthly numbers you can act on',
    href: '/accounting-services-singapore/',
  },
  {
    title: 'AP / AR',
    blurb: 'Payables and receivables tracked',
    href: '/accounting-services-singapore/',
  },
  {
    title: 'Payroll & CPF',
    blurb: 'Monthly payroll, payslips, CPF',
    href: '/payroll-services-singapore/',
  },
  {
    title: 'Financial Statements',
    blurb: 'SFRS-compliant year-end accounts',
    href: '/accounting-services-singapore/',
  },
];

const faqs = [
  {
    q: 'Can a remote accountant keep my books compliant?',
    a: 'Yes. Your bookkeeping, financial statements and payroll all meet Singapore SFRS and CPF standards regardless of where your accountant is based, prepared on Xero and ready for your tax agent to file.',
  },
  {
    q: 'Is my financial data safe?',
    a: 'Yes. Data is shared through encrypted, access-controlled channels and stored securely. Only your assigned accountant can access your records, and we work under confidentiality terms.',
  },
  {
    q: 'Which accounting software do you use?',
    a: 'We work in both Xero and QuickBooks Online, whichever you prefer. Both are SFRS-friendly and give you real-time access to your numbers.',
  },
  {
    q: 'Do you handle payroll and management reports?',
    a: 'Yes. We run monthly payroll with CPF and itemised payslips, and provide clear monthly management reports, all within your package.',
  },
  {
    q: 'How do I switch from my current accountant?',
    a: 'We manage the handover for you, collecting your records, setting up Xero and picking up your filings with no gap in compliance.',
  },
];

// CONFIRM - all prices below are placeholders awaiting client confirmation
const pricingTiers = [
  {
    name: 'Starter',
    price: 'S$90',
    period: '/month',
    tagline: 'For low-volume sole proprietors',
    features: [
      'Monthly bookkeeping',
      'Bank reconciliation',
      'Unaudited financial statements',
      'Management reports',
      'Xero subscription included',
    ],
    cta: { label: 'Get a fixed quote', href: '/contact/' },
    highlighted: false,
  },
  {
    name: 'Growth',
    price: 'S$250',
    period: '/month',
    tagline: 'For growing SMEs',
    features: [
      'Everything in Starter',
      'Accounts payable & receivable',
      'GST tracking & support',
      'Priority response',
      'Monthly strategy call',
    ],
    cta: { label: 'Get a fixed quote', href: '/contact/' },
    highlighted: true,
  },
  {
    name: 'Full',
    price: 'S$450',
    period: '/month + S$8/employee',
    tagline: 'For SMEs with staff',
    features: [
      'Everything in Growth',
      'Monthly payroll & CPF',
      'Itemised payslips',
      'Multi-entity support',
      'Dedicated accountant',
    ],
    cta: { label: 'Get a fixed quote', href: '/contact/' },
    highlighted: false,
  },
];
---

<BaseLayout {title} {description} schemaJsonLd={schemaJsonLd}>

  <!-- ════════════════════════════════════════════ HERO (navy) ══ -->
  <Hero
    h1="Accounting Services in Singapore"
    h1Accent="for Small Businesses"
    subhead="Fixed monthly fees. No surprises. Your books, payroll and financial statements handled remotely by a Financial Controller with 15+ years of experience, so you can get back to running your business."
    primaryCta={{ label: 'Book a free consultation', href: '/contact/' }}
    secondaryCta={{ label: 'Get a fixed quote', href: '/contact/' }}
    trustItems={[
      "Xero & QuickBooks",
      "SFRS-ready books",
      "15+ years' experience",
      "Serving Singapore SMEs remotely",
    ]}
  />

  <!-- ════════════════════════════════════════ STATS (gold bg) ══ -->
  <StatsBanner stats={[
    { value: "15+", label: "Years' experience" },
    { value: "28%", label: "Faster financial close" },
    { value: "S$90", label: "Starting from /month" },
    { value: "100%", label: "Cloud-based delivery" },
  ]} />

  <!-- ════════════════════════════ SPLIT 1: Services overview (white) ══ -->
  <!-- ── SPLIT SECTION 1: What services? (white, text left) ── -->
  <SplitSection
    eyebrow="Core Services"
    heading="What accounting services do small businesses in Singapore need?"
    imageAlt="Accountant reviewing bookkeeping records on Xero dashboard"
    placeholderLabel="Accountant at desk reviewing Xero dashboard with monthly reports, clean modern office"
    placeholderIcon="📒"
    flip={false}
  >
    <AnswerBlock>
      <p>
        Most Singapore small businesses need a few core things handled well: bookkeeping, SFRS-compliant financial statements, payroll with CPF, and clear monthly management reports. Get these right and your records stay accurate, your statutory accounts are ready, and you have numbers you can actually use to run the business.
      </p>
    </AnswerBlock>
    <p>
      You don't need a full finance department. You need the essentials done correctly and on time. Everything most SMEs require sits inside one fixed monthly fee, so nothing slips through the cracks and you always know what you're paying.
    </p>
    <a href="/accounting-services-singapore/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-navy text-white text-sm font-600 rounded-xl hover:bg-navy-deep transition-colors mt-2">
      See all services
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </a>
  </SplitSection>

  <!-- ── MINI CTA after section 1 ── -->
  <MiniBanner
    text="Not sure what services your business needs? Book a free 15-minute call."
    ctaLabel="Book free call"
    ctaHref="/contact/"
    variant="navy"
  />

  <!-- ── SPLIT SECTION 2: In-house vs outsource? (light-bg, image left) ── -->
  <SplitSection
    eyebrow="Cost Comparison"
    heading="Should you hire an in-house accountant or outsource?"
    imageAlt="Side-by-side cost comparison of in-house vs outsourced accountant"
    placeholderLabel="Split visual: in-house salary costs S$3,000+/mo vs fixed outsourced fee — clean comparison graphic"
    placeholderIcon="⚖️"
    flip={true}
    dark={false}
  >
    <AnswerBlock>
      <p>
        For most small businesses in Singapore, outsourcing is cheaper and safer than hiring in-house. A full-time accountant costs a monthly salary plus CPF, leave and software, often S$3,000+ a month, and is idle when transaction volume is low. Outsourcing gives you the same expertise for a fraction of the cost.
      </p>
    </AnswerBlock>
    <p>
      Hire in-house and you pay salary, CPF, benefits, software and training, then carry the risk yourself if that person leaves or makes an error.
    </p>
    <p>
      Outsource to us and you get one fixed fee, a dedicated qualified accountant, compliant software, and continuity you never have to manage. Scale the service up or down as the business grows.
    </p>
  </SplitSection>

  <!-- ══════════════════════════ SERVICES GRID (navy) ══ -->
  <section class="bg-navy py-24 lg:py-28">
    <div class="section-inner">
      <div class="text-center mb-14">
        <div class="eyebrow-dark mb-5">What We Do</div>
        <h2 class="text-3xl lg:text-5xl text-white max-w-2xl mx-auto">
          Core accounting services for Singapore SMEs
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map((svc) => (
          <ServiceCard title={svc.title} blurb={svc.blurb} href={svc.href} dark={true} />
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════ MAIN GOLD CTA ══ -->
  <CTASection
    variant="gold"
    heading="Get a fixed quote in one free call."
    subtext="No obligation, no jargon. We'll assess your needs and send a clear monthly price within 24 hours."
    primaryLabel="Get a Free Quote"
    primaryHref="/contact/"
    secondaryLabel="See pricing"
    secondaryHref="/pricing/"
  />

  <!-- ── SPLIT SECTION 3: Remote delivery (white, text right) ── -->
  <SplitSection
    eyebrow="How We Work"
    heading="How do you deliver Singapore accounting services remotely?"
    imageAlt="Remote accountant working on cloud accounting software with Singapore skyline"
    placeholderLabel="Laptop with Xero open, cloud icons, secure upload interface — modern remote accounting setup"
    placeholderIcon="☁️"
    flip={false}
    dark={false}
  >
    <AnswerBlock>
      <p>
        We work entirely in the cloud using Xero, secure document sharing and scheduled video calls. Because we operate remotely with lower overhead, our fees are lower than a traditional Singapore firm's, while every filing still meets ACRA, IRAS and SFRS requirements. You get the same compliance, less cost.
      </p>
    </AnswerBlock>
    <p>
      Remote doesn't mean hands-off. You get a named accountant, real-time access to your numbers on Xero, monthly reports, and direct answers when you have a question. Your records stay confidential and encrypted at every step.
    </p>
    <p>
      Founder Mehdi Javed has managed accounting operations for SMEs and logistics businesses across Pakistan, the UAE and the United States, so your books are in experienced hands, wherever they're kept.
    </p>
  </SplitSection>

  <!-- ── SPLIT SECTION 4: How to choose (light-bg, image right) ── -->
  <SplitSection
    eyebrow="Choosing Right"
    heading="How do you choose the right accountant for your business?"
    imageAlt="Checklist criteria for choosing an accountant in Singapore"
    placeholderLabel="Professional three-column comparison card: Compliance knowledge, Transparent pricing, Direct access"
    placeholderIcon="✅"
    flip={true}
    dark={false}
  >
    <AnswerBlock>
      <p>
        Three things matter most. Genuine local compliance knowledge across ACRA, IRAS, GST and SFRS. Pricing you can see before you sign. And direct access to a qualified person instead of a rotating call centre. A good accountant files on time, explains your numbers, and flags problems before they turn into penalties.
      </p>
    </AnswerBlock>
    <p>
      Most Singapore firms hide their fees and their people. With us, you know exactly what you pay and exactly who handles your account. You talk to Mehdi, not a queue.
    </p>
    <a href="/contact/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-navy text-white text-sm font-600 rounded-xl hover:bg-navy-deep transition-colors mt-2">
      Get a Quote
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </a>
  </SplitSection>

  <!-- ── MINI CTA ── -->
  <MiniBanner
    text="Ready to stop guessing? Get a fixed quote in one short call — no paperwork needed."
    ctaLabel="Book free consultation"
    ctaHref="/contact/"
    variant="light"
  />

  <!-- ══════════════ PRICING (navy) ══ -->
  <section class="bg-navy py-24 lg:py-28">
    <div class="section-inner">
      <div class="text-center mb-14">
        <div class="eyebrow-dark mb-5">Transparent Pricing</div>
        <h2 class="text-3xl lg:text-5xl text-white mb-4">
          Fixed monthly fees,<br/>published up front
        </h2>
        <p class="text-white/50 max-w-md mx-auto font-400">No hidden costs. No locked tiers. See the <a href="/pricing/" class="text-gold-btn hover:underline">full pricing page</a> or get a custom quote.</p>
      </div>
      <!-- CONFIRM all prices below are placeholders -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {pricingTiers.map((tier) => (
          <PricingTier
            name={tier.name}
            price={tier.price}
            period={tier.period}
            tagline={tier.tagline}
            features={tier.features}
            cta={tier.cta}
            highlighted={tier.highlighted}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── SPLIT: About Mehdi (light-bg, image left) ── -->
  <SplitSection
    eyebrow="Meet the Founder"
    heading="Why choose accountantforsmallbusiness.com?"
    imageAlt="Mehdi Javed, Financial Controller and founder"
    placeholderLabel="Professional portrait — confident South Asian man, business formal, neutral grey studio, warm lighting"
    placeholderIcon="👤"
    flip={true}
    dark={false}
  >
    <AnswerBlock>
      <p>
        Because you get a qualified Financial Controller, transparent fixed pricing, and direct personal service, not a faceless retainer. Mehdi Javed brings 15+ years of multi-entity finance experience, an Executive MBA in Accounting &amp; Finance, and a track record of 28% faster financial close and 10% cost reduction.
      </p>
    </AnswerBlock>
    <div class="grid grid-cols-3 gap-3 mt-2">
      {[
        { stat: '15+', label: 'Years experience' },
        { stat: '28%', label: 'Faster close' },
        { stat: '10%', label: 'Cost reduction' },
      ].map((s) => (
        <div class="bg-navy rounded-xl p-4 text-center">
          <div class="text-2xl font-800 text-gold-btn mb-1">{s.stat}</div>
          <div class="text-white/50 text-xs font-600 leading-tight">{s.label}</div>
        </div>
      ))}
    </div>
    <p class="mt-4">
      On expertise: IFRS and SFRS reporting, ERP implementation, automated AP/AR and payroll. On price: fixed monthly fees published up front. On access: you work with Mehdi directly, never a call centre.
    </p>
    <a href="/about/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-navy text-white text-sm font-600 rounded-xl hover:bg-navy-deep transition-colors mt-2">
      Read more about Mehdi
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </a>
  </SplitSection>

  <!-- ══════════════ GETTING STARTED (navy, redesigned) ══ -->
  <section class="bg-navy py-24 lg:py-28">
    <div class="section-inner">
      <div class="text-center mb-16">
        <div class="eyebrow-dark mb-5">Getting Started</div>
        <h2 class="text-3xl lg:text-5xl text-white mb-4">Up and running in one week</h2>
        <p class="text-white/50 max-w-md mx-auto font-400">Three steps, one free call. No paperwork, no downtime.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto mb-12">
        {[
          {
            n: '01',
            title: 'Free consultation',
            desc: 'Tell us about your business. We ask the right questions to understand your transaction volume, GST status, and payroll needs.',
            icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
          },
          {
            n: '02',
            title: 'Fixed quote sent',
            desc: "You receive a clear monthly fee in writing — no tiers, no hidden costs. You approve it. That's it.",
            icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
          },
          {
            n: '03',
            title: 'We take over',
            desc: 'We onboard you onto Xero, collect your records from your previous accountant, and start your first month with no gap in compliance.',
            icon: 'M5 13l4 4L19 7',
          },
        ].map((step) => (
          <div class="relative bg-navy-panel rounded-2xl p-8 border border-white/8 hover:border-gold/25 transition-all duration-200 group">
            <!-- Step number -->
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl bg-gold-btn/15 border border-gold-btn/20 flex items-center justify-center">
                <svg class="w-5 h-5 text-gold-btn" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={step.icon} />
                </svg>
              </div>
              <span class="text-gold-btn/40 text-2xl font-800 tracking-tight">{step.n}</span>
            </div>
            <h3 class="text-lg font-700 text-white mb-3">{step.title}</h3>
            <p class="text-white/50 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>

      <div class="text-center">
        <a
          href="/contact/"
          class="inline-flex items-center gap-2 px-8 py-4 bg-gold-btn text-navy text-base font-700 rounded-xl hover:bg-gold-hover transition-all duration-200 hover:shadow-xl hover:shadow-gold/25 hover:-translate-y-0.5"
        >
          Book a free consultation
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <p class="text-white/30 text-xs font-500 mt-4">Usually up and running within one week of your first call.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════ WHO WE HELP (white, icon grid) ══ -->
  <section class="bg-white py-20">
    <div class="section-inner">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <div class="eyebrow-light mb-5">Who We Help</div>
        <h2 class="text-3xl lg:text-4xl text-ink mb-4">Built for Singapore SMEs</h2>
        <p class="text-ink/55 text-lg font-400">
          We work with Singapore small businesses and SMEs, sole proprietors, new Pte Ltd companies, e-commerce sellers, agencies and growing startups with one to twenty staff. If you'd rather run your business than wrestle with IRAS forms, you're who we built this for.
        </p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 max-w-3xl mx-auto">
        {[
          { icon: '🏪', label: 'Sole Traders' },
          { icon: '🏢', label: 'Pte Ltd' },
          { icon: '🛍️', label: 'E-commerce' },
          { icon: '💼', label: 'Agencies' },
          { icon: '🚀', label: 'Startups' },
          { icon: '👥', label: '1-20 Staff' },
        ].map((item) => (
          <div class="bg-light-bg rounded-2xl p-5 flex flex-col items-center gap-3 text-center border border-ink/5 hover:border-gold/30 hover:-translate-y-0.5 transition-all duration-200">
            <span class="text-3xl">{item.icon}</span>
            <span class="text-xs font-700 text-ink/60 uppercase tracking-wide">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════ FAQ (light-bg) ══ -->
  <section class="bg-light-bg py-24">
    <div class="section-inner">
      <div class="max-w-3xl mx-auto">
        <div class="eyebrow-light mb-5">Common Questions</div>
        <h2 class="text-3xl lg:text-4xl text-ink mb-10">Frequently asked questions</h2>
        <FaqAccordion items={faqs} />
        <div class="mt-10 pt-8 border-t border-ink/8 text-center">
          <p class="text-ink/55 mb-4">Have a question not covered here?</p>
          <a href="/contact/" class="inline-flex items-center gap-2 px-6 py-3 bg-navy text-white text-sm font-600 rounded-xl hover:bg-navy-deep transition-colors">
            Ask us directly
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════ CONTACT + MAP (light-bg) ══ -->
  <ContactSection />

  <!-- ══════════════ FINAL GOLD CTA ══ -->
  <CTASection
    variant="gold"
    heading="Ready to stop worrying about your books?"
    subtext="Book a free consultation with Mehdi today and get a fixed monthly quote. No obligation, no jargon."
    primaryLabel="Book a free consultation"
    primaryHref="/contact/"
    secondaryLabel="See pricing"
    secondaryHref="/pricing/"
  />

</BaseLayout>
