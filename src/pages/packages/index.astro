---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Accounting Packages for Singapore Small Businesses | AFSB';
const description = 'Compare our accounting plans for Singapore SMEs feature by feature. See exactly what Starter, Growth and Full include and pick the right fit.';

const schemaJsonLd = `<script type="application/ld+json">
{"@context":"https://schema.org","@graph":[{"@type":"OfferCatalog","@id":"https://accountantforsmallbusiness.com/packages/#catalog","name":"Accounting Packages","itemListElement":[{"@type":"Offer","name":"Starter","priceCurrency":"SGD","price":"90","description":"Monthly bookkeeping, bank reconciliation, year-end financial statements and a dedicated accountant for low-volume businesses."},{"@type":"Offer","name":"Growth","priceCurrency":"SGD","price":"250","description":"Starter plus monthly management reports and accounts payable and receivable."},{"@type":"Offer","name":"Full","priceCurrency":"SGD","price":"450","description":"Growth plus monthly payroll with CPF and payslips; per-employee fee applies."},{"@type":"Offer","name":"Custom","description":"Tailored scope for multi-entity or high-volume businesses, priced on actual activity."}]},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is the difference between the plans?","acceptedAnswer":{"@type":"Answer","text":"Each plan adds to the one below. Starter covers bookkeeping and year-end statements, Growth adds management reports and AP/AR, Full adds payroll with CPF, and Custom is tailored for multi-entity or high-volume businesses."}},{"@type":"Question","name":"Which plan is right for my business?","acceptedAnswer":{"@type":"Answer","text":"Low-volume sole proprietors fit Starter, growing SMEs fit Growth, companies with staff fit Full, and multi-entity or high-volume businesses fit Custom."}},{"@type":"Question","name":"Can I move between plans as I grow?","acceptedAnswer":{"@type":"Answer","text":"Yes. Plans scale with you. You move up or down with no penalty and no locked contract, because pricing tracks your real activity."}},{"@type":"Question","name":"What is not included in any plan?","acceptedAnswer":{"@type":"Answer","text":"GST and corporate tax filing are done by your tax agent, incorporation by a filing agent, and statutory audit by an ACRA public accountant. We handle the accounting only."}}]},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://accountantforsmallbusiness.com/"},{"@type":"ListItem","position":2,"name":"Packages","item":"https://accountantforsmallbusiness.com/packages/"}]}]}
<\/script>`;

// CONFIRM, all prices are placeholders awaiting client confirmation
const matrix = [
  { feature: 'Monthly bookkeeping',          starter: true,  growth: true,  full: true,  custom: true  },
  { feature: 'Bank reconciliation',           starter: true,  growth: true,  full: true,  custom: true  },
  { feature: 'Year-end financial statements', starter: true,  growth: true,  full: true,  custom: true  },
  { feature: 'Dedicated named accountant',    starter: true,  growth: true,  full: true,  custom: true  },
  { feature: 'Xero or QuickBooks included',   starter: true,  growth: true,  full: true,  custom: true  },
  { feature: 'Monthly management reports',    starter: false, growth: true,  full: true,  custom: true  },
  { feature: 'Accounts payable & receivable', starter: false, growth: true,  full: true,  custom: true  },
  { feature: 'Payroll with CPF + payslips',   starter: false, growth: false, full: true,  custom: true  },
  { feature: 'Per-employee payroll (from S$8)', starter: false, growth: false, full: 'add', custom: 'add' },
  { feature: 'Multi-entity / consolidation',  starter: false, growth: false, full: false, custom: true  },
];

const plans = [
  { name: 'Starter',  price: 'S$90',  period: '/mo', bestFor: 'Sole props, low volume',   highlight: false, color: 'text-gray-300' },
  { name: 'Growth',   price: 'S$250', period: '/mo', bestFor: 'Growing SMEs',              highlight: true,  color: 'text-[#DAA035]' },
  { name: 'Full',     price: 'S$450', period: '/mo', bestFor: 'SMEs with staff',           highlight: false, color: 'text-emerald-400' },
  { name: 'Custom',   price: 'Quote', period: '',    bestFor: 'Multi-entity, high volume', highlight: false, color: 'text-purple-400' },
];

const faqs = [
  { q: 'What is the difference between the plans?', a: 'Each plan adds to the one below it. Starter keeps your books clean and your year-end statements ready. Growth adds monthly management reports and AP/AR for businesses that need regular numbers. Full adds payroll with CPF for companies with staff. Custom is for multi-entity or high-volume businesses that need a tailored scope.' },
  { q: 'Which plan is right for my business?', a: "Match the plan to how your business runs. If you're a sole proprietor with low transaction volume, Starter is enough. If you're growing and want regular management numbers, choose Growth. If you employ staff and need payroll, choose Full. If you run multiple entities or high volume, Custom is built around you." },
  { q: 'Can I move between plans as I grow?', a: "Yes. Plans are designed to scale with you. As your transaction volume rises or you take on staff, you move up a plan with no penalty and no renegotiation of a locked contract. If your volume drops, you can move down just as easily." },
  { q: "What's not included in any plan?", a: 'We handle the accounting, so filing sits elsewhere. GST and corporate tax are filed by your licensed Singapore tax agent, company incorporation is done by a filing agent, and a statutory audit (if your company needs one) is done by an ACRA-registered public accountant.' },
];
---

<BaseLayout {title} {description} schemaJsonLd={schemaJsonLd}>

<!-- ════ HERO ════ -->
<section class="relative overflow-hidden bg-gradient-to-b from-[#000F22] to-[#0A1628] pt-20 pb-16 border-b border-gray-900 text-center">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(220,163,60,0.02)_0%,transparent_70%)] pointer-events-none"></div>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 space-y-6">
    <nav class="flex items-center justify-center gap-2 text-xs text-gray-500 font-mono mb-2">
      <a href="/" class="hover:text-[#DAA035] transition-colors">Home</a>
      <span>/</span>
      <span class="text-[#DAA035]">Packages</span>
    </nav>
    <h1 class="text-4xl sm:text-5xl font-serif text-[#FEFFFF] font-bold tracking-tight leading-tight">
      Accounting Packages for Singapore Small Businesses
    </h1>
    <p class="text-sm sm:text-base text-[#CBCFD8] max-w-2xl mx-auto leading-relaxed">
      Three clear plans, one fixed monthly fee each. Compare them feature by feature and pick the one that fits how your business runs today. Move up whenever you grow.
    </p>
    <div class="flex flex-wrap justify-center gap-4 pt-2">
      <a href="/contact/" class="bg-[#DCA33C] hover:bg-[#C8912F] text-[#000F22] font-semibold px-8 py-3.5 rounded-lg text-sm transition-all hover:scale-[1.01] shadow-lg shadow-[#DCA33C]/10">
        Book a free consultation
      </a>
      <a href="/pricing/" class="bg-transparent border border-[#DAA035] hover:bg-[#DAA035] hover:text-[#000F22] text-[#DAA035] font-semibold px-8 py-3.5 rounded-lg text-sm transition-all">
        See pricing
      </a>
    </div>
  </div>
</section>

<!-- ════ WHAT'S THE DIFFERENCE (light F8FAFC) ════ -->
<section class="bg-[#F8FAFC] text-[#000F22] py-20 border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <div class="lg:col-span-7 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">PLAN DIFFERENCES</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">
          What's the difference between the plans?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#F2F4F7] text-[#000F22] shadow-sm">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#000F22]">
            Each plan adds to the one below it. Starter keeps your books clean and your year-end statements ready. Growth adds monthly management reports and AP/AR for businesses that need regular numbers. Full adds payroll with CPF for companies with staff. Custom is for multi-entity or high-volume businesses that need a tailored scope.
          </p>
        </div>
        <p class="text-sm sm:text-base leading-relaxed text-gray-700 font-sans">
          You're never paying for work you don't use. You pick the plan that matches how your business runs now, and move up only when your volume or headcount actually calls for it.
        </p>
      </div>

      <!-- Visual: stacked plan progression -->
      <div class="lg:col-span-5 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="border-b border-gray-800 pb-3 mb-6 font-mono text-center">
              <span class="text-xs text-[#DAA035] uppercase font-bold tracking-wider">Plan progression</span>
            </div>
            <div class="space-y-2 font-sans">
              {[
                { plan: 'Starter', adds: 'Bookkeeping + statements', price: 'S$90', color: 'border-gray-700 bg-gray-900/30' },
                { plan: 'Growth', adds: '+ Management reports + AP/AR', price: 'S$250', color: 'border-[#DAA035]/40 bg-[#DAA035]/5' },
                { plan: 'Full', adds: '+ Payroll with CPF', price: 'S$450', color: 'border-emerald-900/60 bg-emerald-950/20' },
                { plan: 'Custom', adds: '+ Multi-entity / high volume', price: 'Quote', color: 'border-purple-900/40 bg-purple-950/15' },
              ].map((row, i) => (
                <div class={`relative p-4 rounded-xl border ${row.color} flex items-center justify-between`} style={`margin-left: ${i * 0.5}rem`}>
                  {i > 0 && (
                    <div class="absolute -top-3 left-6 w-px h-3 bg-gray-700"></div>
                  )}
                  <div>
                    <span class="block text-xs font-bold text-white">{row.plan}</span>
                    <span class="block text-[10px] text-gray-500">{row.adds}</span>
                  </div>
                  <span class="text-sm font-black text-[#DAA035] font-mono shrink-0">{row.price}</span>
                </div>
              ))}
            </div>
          </div>
          <p class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-4"><!-- CONFIRM --> *All prices confirmed in your free call</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ FEATURE MATRIX (dark navy) ════ -->
<section class="relative bg-[#000F22] py-20 border-b border-gray-950 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <svg class="absolute inset-0 w-full h-full opacity-[0.03]" xmlns="http://www.w3.org/2000/svg">
      <defs><pattern id="dots-pkg" width="28" height="28" patternUnits="userSpaceOnUse"><circle cx="14" cy="14" r="1.2" fill="#DAA035"/></pattern></defs>
      <rect width="100%" height="100%" fill="url(#dots-pkg)"/>
    </svg>
  </div>
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 space-y-3">
      <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">Feature by Feature</span>
      <h2 class="text-3xl sm:text-4xl font-sans text-white font-extrabold tracking-tight">Compare plans feature by feature</h2>
      <p class="text-xs text-gray-600 font-mono"><!-- CONFIRM --> All prices are market-rate starting points, confirmed on your free call.</p>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-gray-800 shadow-2xl">
      <table class="w-full text-left border-collapse min-w-[640px]">
        <!-- Header -->
        <thead>
          <tr class="bg-[#0A1628] border-b border-gray-800">
            <th class="p-4 text-left font-mono text-xs text-gray-500 uppercase tracking-wider w-[38%]">Feature</th>
            {plans.map((plan) => (
              <th class={`p-4 text-center ${plan.highlight ? 'bg-[#DAA035]/8' : ''}`}>
                <div>
                  <span class={`block text-sm font-black font-mono ${plan.color}`}>{plan.name}</span>
                  <div class="flex items-baseline justify-center gap-0.5 mt-0.5">
                    <span class="text-lg font-black text-white">{plan.price}</span>
                    {plan.period && <span class="text-[10px] text-gray-500 font-mono">{plan.period}</span>}
                  </div>
                  <span class="block text-[10px] text-gray-600 mt-0.5 font-sans">{plan.bestFor}</span>
                </div>
              </th>
            ))}
          </tr>
        </thead>

        <!-- Rows -->
        <tbody class="divide-y divide-gray-800/60">
          {matrix.map((row, idx) => (
            <tr class={`${idx % 2 === 0 ? 'bg-[#020B16]' : 'bg-[#000F22]'} hover:bg-[#0A1628]/50 transition-colors`}>
              <td class="p-4 text-sm text-[#CBCFD8] font-medium">{row.feature}</td>
              {[row.starter, row.growth, row.full, row.custom].map((val, pi) => (
                <td class={`p-4 text-center ${plans[pi].highlight ? 'bg-[#DAA035]/5' : ''}`}>
                  {val === true && (
                    <svg class="w-5 h-5 text-emerald-400 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                    </svg>
                  )}
                  {val === false && (
                    <span class="text-gray-700 text-lg font-bold">-</span>
                  )}
                  {val === 'add' && (
                    <span class="text-[10px] font-mono font-bold text-amber-400 uppercase border border-amber-500/25 bg-amber-500/10 px-1.5 py-0.5 rounded">Add-on</span>
                  )}
                </td>
              ))}
            </tr>
          ))}

          <!-- Base monthly price row -->
          <tr class="bg-[#0A1628] border-t-2 border-[#DAA035]/30">
            <td class="p-4 text-sm font-bold text-[#DAA035] font-mono uppercase tracking-wider">Base monthly price <!-- CONFIRM --></td>
            {plans.map((plan) => (
              <td class={`p-4 text-center ${plan.highlight ? 'bg-[#DAA035]/8' : ''}`}>
                <span class={`text-lg font-black font-mono ${plan.color}`}>{plan.price}</span>
                {plan.period && <span class="text-[10px] text-gray-500 font-mono">{plan.period}</span>}
              </td>
            ))}
          </tr>

          <!-- CTA row -->
          <tr class="bg-[#000F22]">
            <td class="p-4 text-xs text-gray-500 font-mono italic">All plans include a dedicated named accountant</td>
            {plans.map((plan) => (
              <td class={`p-4 text-center ${plan.highlight ? 'bg-[#DAA035]/5' : ''}`}>
                <a
                  href="/contact/"
                  class={`inline-block px-4 py-2 text-xs font-bold rounded-xl transition-all duration-200 hover:-translate-y-0.5
                    ${plan.highlight
                      ? 'bg-[#DCA33C] text-[#000F22] hover:bg-[#C8912F]'
                      : 'bg-white/6 border border-white/10 text-[#DAA035] hover:bg-[#DCA33C] hover:text-[#000F22] hover:border-[#DCA33C]'
                    }`}
                >
                  Get a quote
                </a>
              </td>
            ))}
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- ════ WHICH PLAN IS RIGHT? (light EDF0F5) ════ -->
<section class="bg-[#EDF0F5] text-[#000F22] py-20 border-b border-gray-200">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-10">
    <div class="text-center space-y-3">
      <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">WHICH PLAN</span>
      <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">Which plan is right for your business?</h2>
      <div class="p-6 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#F2F4F7] text-[#000F22] shadow-sm text-left max-w-3xl mx-auto">
        <p class="text-base leading-relaxed font-semibold italic text-[#000F22]">
          Match the plan to how your business runs. If you're a sole proprietor with low transaction volume, Starter is enough. If you're growing and want regular management numbers, choose Growth. If you employ staff and need payroll, choose Full. If you run multiple entities or high volume, Custom is built around you.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {[
        { plan: 'Starter', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z', suits: 'Low-volume sole proprietors who mainly need clean books and year-end statements.', color: 'border-gray-300 hover:border-gray-400', iconBg: 'bg-gray-100', iconColor: 'text-gray-600' },
        { plan: 'Growth', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', suits: 'Businesses that want monthly reports and tracked payables and receivables.', color: 'border-[#DAA035] hover:border-[#C8912F]', iconBg: 'bg-amber-50', iconColor: 'text-amber-600' },
        { plan: 'Full', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zM7 10a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z', suits: 'Companies with employees who need payroll and CPF handled too.', color: 'border-emerald-300 hover:border-emerald-400', iconBg: 'bg-emerald-50', iconColor: 'text-emerald-600' },
        { plan: 'Custom', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4', suits: 'Multi-entity, high-volume or businesses needing a bespoke scope.', color: 'border-purple-300 hover:border-purple-400', iconBg: 'bg-purple-50', iconColor: 'text-purple-600' },
      ].map((item) => (
        <div class={`bg-white p-6 rounded-2xl border-2 ${item.color} shadow-sm hover:shadow-md transition-all duration-200 space-y-4`}>
          <div class={`w-12 h-12 rounded-xl ${item.iconBg} flex items-center justify-center`}>
            <svg class={`w-6 h-6 ${item.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={item.icon}/>
            </svg>
          </div>
          <div>
            <h3 class="text-base font-extrabold text-[#000F22] mb-1">{item.plan}</h3>
            <p class="text-xs text-gray-600 leading-relaxed">{item.suits}</p>
          </div>
          <a href="/contact/" class="inline-flex items-center gap-1 text-[#DAA035] text-xs font-bold hover:underline font-mono">
            Get a quote &rarr;
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ CAN YOU MOVE BETWEEN PLANS? (dark 0A1B30) ════ -->
<section class="bg-[#0A1B30] text-[#CBCFD8] py-20 border-b border-gray-950/45">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <div class="space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">PLAN FLEXIBILITY</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#FEFFFF] font-extrabold tracking-tight">
          Can you move between plans as you grow?
        </h2>
        <div class="p-6 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#0A1628] text-[#FEFFFF] shadow-inner">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#FEFFFF]">
            Yes. Plans are designed to scale with you. As your transaction volume rises or you take on staff, you move up a plan with no penalty and no renegotiation of a locked contract. If your volume drops, you can move down just as easily.
          </p>
        </div>
        <p class="text-sm sm:text-base leading-relaxed text-[#CBCFD8] font-sans">
          Because pricing tracks your real activity, the plan follows your business rather than trapping you in a tier you've outgrown or no longer need.
        </p>
      </div>

      <!-- Visual: scale up/down -->
      <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl">
        <div class="border-b border-gray-800 pb-3 mb-6 font-mono text-center">
          <span class="text-xs text-[#DAA035] uppercase font-bold tracking-wider">Scale freely, no lock-in</span>
        </div>
        <div class="space-y-3 font-sans">
          <div class="flex items-center gap-3 p-3 bg-emerald-950/25 rounded-xl border border-emerald-900/40">
            <svg class="w-5 h-5 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
            <div>
              <span class="text-xs font-bold text-white block">Move up as you grow</span>
              <span class="text-[10px] text-gray-500">Volume rises or you take on staff, upgrade seamlessly</span>
            </div>
          </div>
          <div class="flex items-center gap-3 p-3 bg-sky-950/25 rounded-xl border border-sky-900/30">
            <svg class="w-5 h-5 text-sky-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
            <div>
              <span class="text-xs font-bold text-white block">Move down if volume drops</span>
              <span class="text-[10px] text-gray-500">No penalty, no renegotiation required</span>
            </div>
          </div>
          <div class="flex items-center gap-3 p-3 bg-[#DAA035]/10 rounded-xl border border-[#DAA035]/25">
            <svg class="w-5 h-5 text-[#DAA035] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            <div>
              <span class="text-xs font-bold text-white block">We tell you before anything changes</span>
              <span class="text-[10px] text-gray-500">No surprise tier jumps, you approve every change</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHAT'S NOT INCLUDED (light F8FAFC) ════ -->
<section class="bg-[#F8FAFC] text-[#000F22] py-20 border-b border-gray-200">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-10">
    <div class="text-center space-y-3">
      <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">SCOPE BOUNDARY</span>
      <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">What's not included in any plan?</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="bg-white p-8 rounded-2xl border border-gray-200 shadow-sm space-y-5">
        <div class="p-5 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#F2F4F7] shadow-sm">
          <p class="text-sm leading-relaxed font-semibold italic text-[#000F22]">
            We handle the accounting, so filing sits elsewhere. GST and corporate tax are filed by your licensed Singapore tax agent, company incorporation is done by a filing agent, and a statutory audit, if your company needs one, is done by an ACRA-registered public accountant.
          </p>
        </div>
        <p class="text-sm text-gray-600">You only pay us for the accounting we actually do, never for work that belongs with a licensed specialist.</p>
      </div>

      <div class="bg-white p-8 rounded-2xl border border-gray-200 shadow-sm space-y-4">
        <h3 class="text-sm font-mono text-gray-500 uppercase tracking-wider font-bold">Who handles what</h3>
        <div class="space-y-3">
          {[
            { who: 'AFSB (us)', what: 'Bookkeeping, statements, payroll, reports', color: 'text-[#DAA035] bg-[#DAA035]/8 border-[#DAA035]/20' },
            { who: 'Your tax agent', what: 'GST filing, corporate tax filing', color: 'text-sky-600 bg-sky-50 border-sky-100' },
            { who: 'A filing agent', what: 'Company incorporation', color: 'text-purple-600 bg-purple-50 border-purple-100' },
            { who: 'ACRA public accountant', what: 'Statutory audit (if required)', color: 'text-gray-500 bg-gray-50 border-gray-100' },
          ].map((row) => (
            <div class={`p-3 rounded-xl border flex items-start gap-3 ${row.color}`}>
              <span class="text-xs font-bold shrink-0 mt-0.5">{row.who}</span>
              <span class="text-xs text-gray-600 leading-snug">{row.what}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

