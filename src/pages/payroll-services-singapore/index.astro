---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Payroll Services Singapore for Small Business | AFSB';
const description = 'Affordable payroll services in Singapore for small businesses. Monthly payroll, CPF, SDL and IR8A handled accurately and on time, priced per employee.';

const schemaJsonLd = `<script type="application/ld+json">
{"@context":"https://schema.org","@graph":[{"@type":["Service","AccountingService"],"@id":"https://accountantforsmallbusiness.com/payroll-services-singapore/#service","name":"Payroll Services Singapore","serviceType":"Payroll","provider":{"@id":"https://accountantforsmallbusiness.com/#org"},"areaServed":{"@type":"Country","name":"Singapore"},"description":"Monthly payroll for Singapore small businesses: salary processing, CPF, SDL, itemised payslips and IR8A filing, priced per employee.","offers":{"@type":"Offer","priceCurrency":"SGD","priceSpecification":{"@type":"UnitPriceSpecification","minPrice":"5","maxPrice":"80","priceCurrency":"SGD","unitText":"per employee per month"}},"isRelatedTo":{"@id":"https://accountantforsmallbusiness.com/accounting-services-singapore/#service"}},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Do foreign employees get CPF?","acceptedAnswer":{"@type":"Answer","text":"No. CPF applies to Singapore citizens and permanent residents. Foreign employees on Employment Pass, S Pass or Work Permit are not covered by CPF; Work Permit and S Pass holders attract the Foreign Worker Levy."}},{"@type":"Question","name":"What changed for payroll in 2026?","acceptedAnswer":{"@type":"Answer","text":"The Ordinary Wage ceiling rose to S$8,000, CPF rates stepped up for senior workers, and the Local Qualifying Salary increased to S$1,800."}},{"@type":"Question","name":"Do you handle IR8A and IR21?","acceptedAnswer":{"@type":"Answer","text":"Yes. We prepare and file annual IR8A and handle IR21 tax clearance for leavers."}},{"@type":"Question","name":"How fast must I pay salaries?","acceptedAnswer":{"@type":"Answer","text":"Under the Employment Act, salaries must be paid within seven days of the end of the pay cycle."}},{"@type":"Question","name":"Do you run payroll in Xero or QuickBooks?","acceptedAnswer":{"@type":"Answer","text":"Yes. Payroll runs alongside your books in Xero or QuickBooks Online, keeping payroll and accounting in one connected system."}}]},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://accountantforsmallbusiness.com/"},{"@type":"ListItem","position":2,"name":"Accounting Services","item":"https://accountantforsmallbusiness.com/accounting-services-singapore/"},{"@type":"ListItem","position":3,"name":"Payroll Services","item":"https://accountantforsmallbusiness.com/payroll-services-singapore/"}]}]}
<\/script>`;

const faqs = [
  { q: 'Do foreign employees get CPF?', a: 'No. CPF applies to Singapore citizens and permanent residents. Foreign employees on an Employment Pass, S Pass or Work Permit are not covered by CPF, though Work Permit and S Pass holders attract the Foreign Worker Levy.' },
  { q: 'What changed for payroll in 2026?', a: 'The Ordinary Wage ceiling rose to S$8,000, CPF rates stepped up for senior workers, and the Local Qualifying Salary increased to S$1,800. We apply these automatically.' },
  { q: 'Do you handle IR8A and IR21?', a: 'Yes. We prepare and file annual IR8A for your employees and handle IR21 tax clearance whenever someone leaves.' },
  { q: 'How fast must I pay salaries?', a: 'Under the Employment Act, salaries must be paid within seven days of the end of the pay cycle. We prepare your run early so payment is never late.' },
  { q: 'Do you run payroll in Xero or QuickBooks?', a: 'Yes. We run payroll alongside your books in Xero or QuickBooks Online, so payroll and accounting stay in one connected system.' },
];
---

<BaseLayout {title} {description} schemaJsonLd={schemaJsonLd}>

<!-- ════ HERO ════ -->
<section class="relative overflow-hidden bg-gradient-to-b from-[#000F22] to-[#0A1628] pt-20 pb-16 border-b border-gray-900 text-center">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(220,163,60,0.02)_0%,transparent_70%)] pointer-events-none"></div>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 space-y-6">
    <nav class="flex items-center justify-center gap-2 text-xs text-gray-500 font-mono mb-2">
      <a href="/" class="hover:text-[#DAA035] transition-colors">Home</a>
      <span>/</span>
      <a href="/accounting-services-singapore/" class="hover:text-[#DAA035] transition-colors">Accounting Services</a>
      <span>/</span>
      <span class="text-[#DAA035]">Payroll Services</span>
    </nav>
    <h1 class="text-4xl sm:text-5xl font-serif text-[#FEFFFF] font-bold tracking-tight leading-tight">
      Payroll Services in Singapore for Small Businesses
    </h1>
    <p class="text-sm sm:text-base text-[#CBCFD8] max-w-2xl mx-auto leading-relaxed">
      Salaries paid on time, CPF and IR8A filed correctly, payslips your staff can trust. We run your monthly payroll remotely and keep you compliant, priced simply per employee.
    </p>
    <div class="flex flex-wrap justify-center gap-4 pt-2">
      <a href="/contact/" class="bg-[#DCA33C] hover:bg-[#C8912F] text-[#000F22] font-semibold px-8 py-3.5 rounded-lg text-sm transition-all hover:scale-[1.01] shadow-lg shadow-[#DCA33C]/10">
        Get a payroll quote
      </a>
      <a href="/contact/" class="bg-transparent border border-[#DAA035] hover:bg-[#DAA035] hover:text-[#000F22] text-[#DAA035] font-semibold px-8 py-3.5 rounded-lg text-sm transition-all">
        Book a free consultation
      </a>
    </div>
  </div>
</section>

<!-- ════ SPLIT 1: What does a payroll service include? (light F8FAFC, text left) ════ -->
<section class="bg-[#F8FAFC] text-[#000F22] py-20 border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <div class="lg:col-span-7 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">WHAT'S INCLUDED</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">
          What does a payroll service in Singapore include?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#F2F4F7] text-[#000F22] shadow-sm">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#000F22]">
            A payroll service handles the full monthly cycle: salary calculation, CPF and SDL submission, itemised payslips, and year-end IR8A filing. A good provider also manages IR21 tax clearance for leavers and keeps up with rate changes, so your staff are paid correctly and your filings stay compliant with MOM, IRAS and the CPF Board.
          </p>
        </div>
        <div class="space-y-4 text-sm sm:text-base leading-relaxed text-gray-700">
          <p>Payroll in Singapore is more than transferring salaries. Every month you have statutory deductions to calculate, contributions to submit, and records to keep, each with its own deadline and penalty for getting it wrong.</p>
          <p>Each cycle we handle salary and overtime computation, CPF and SDL submission, itemised payslips, and the annual IR8A, plus IR21 clearance whenever someone leaves.</p>
        </div>
      </div>

      <!-- Visual: full cycle status -->
      <div class="lg:col-span-5 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="flex items-center justify-between border-b border-gray-800 pb-3 mb-6 font-mono">
              <span class="text-xs text-[#DAA035] font-bold uppercase tracking-wider">Monthly payroll cycle</span>
              <span class="text-[10px] bg-emerald-500/15 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded font-bold uppercase">All covered</span>
            </div>
            <div class="space-y-3 font-sans">
              {[
                { label: 'Salary & overtime computation', status: 'DONE', color: 'text-emerald-400', dot: 'bg-emerald-500' },
                { label: 'CPF & SDL submission', status: 'DONE', color: 'text-emerald-400', dot: 'bg-emerald-500' },
                { label: 'Itemised payslips', status: 'DONE', color: 'text-emerald-400', dot: 'bg-emerald-500' },
                { label: 'Bank transfer list', status: 'READY', color: 'text-sky-400', dot: 'bg-sky-500' },
                { label: 'Annual IR8A filing', status: 'TRACKED', color: 'text-amber-400', dot: 'bg-amber-500' },
                { label: 'IR21 for leavers', status: 'ON REQUEST', color: 'text-purple-400', dot: 'bg-purple-500' },
              ].map((row) => (
                <div class="p-3 bg-[#020B16] rounded-xl border border-gray-800 flex items-center justify-between hover:border-gray-700 transition-colors">
                  <div class="flex items-center gap-2.5">
                    <span class={`w-2.5 h-2.5 rounded-full shrink-0 ${row.dot}`}></span>
                    <span class="text-xs font-bold text-white">{row.label}</span>
                  </div>
                  <span class={`text-[10px] font-mono font-bold uppercase ${row.color}`}>{row.status}</span>
                </div>
              ))}
            </div>
          </div>
          <p class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-4">*Full compliance cycle, nothing missed</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ SPLIT 2: How does payroll work in Singapore? (dark 0A1B30, visual left) ════ -->
<section class="bg-[#0A1B30] text-[#CBCFD8] py-20 border-b border-gray-950/45">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <!-- Visual: 4 moving parts -->
      <div class="lg:col-span-5 order-2 lg:order-1 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="border-b border-gray-800 pb-3 mb-6 font-mono text-center">
              <span class="text-xs text-[#DAA035] uppercase font-bold tracking-wider">Singapore Payroll Components</span>
            </div>
            <div class="space-y-4 font-sans">
              {[
                { label: 'CPF', sub: 'Citizens & PRs', who: 'CPF Board', color: 'border-sky-500/30 bg-sky-950/20', textColor: 'text-sky-400', badge: 'Monthly' },
                { label: 'SDL', sub: 'All employees', who: 'CPF Board (alongside CPF)', color: 'border-emerald-900/40 bg-emerald-950/20', textColor: 'text-emerald-400', badge: 'Monthly' },
                { label: 'FWL', sub: 'Work Permit & S Pass holders', who: 'MOM', color: 'border-amber-900/30 bg-amber-950/20', textColor: 'text-amber-400', badge: 'Monthly' },
                { label: 'IR8A', sub: 'All employees', who: 'IRAS', color: 'border-purple-900/30 bg-purple-950/20', textColor: 'text-purple-400', badge: 'Annual' },
              ].map((item) => (
                <div class={`p-3.5 rounded-xl border ${item.color} flex items-center justify-between`}>
                  <div>
                    <div class="flex items-center gap-2">
                      <span class={`text-base font-black ${item.textColor}`}>{item.label}</span>
                      <span class={`text-[9px] font-mono font-bold uppercase border px-1.5 py-0.5 rounded ${item.textColor} bg-transparent border-current/30`}>{item.badge}</span>
                    </div>
                    <span class="text-[10px] text-gray-400 block">{item.sub}</span>
                    <span class="text-[10px] text-gray-600 font-mono">{item.who}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <p class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-4">*Each has its own rate, deadline and penalty</p>
        </div>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">SINGAPORE PAYROLL</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#FEFFFF] font-extrabold tracking-tight">
          How does payroll work in Singapore?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#0A1628] text-[#FEFFFF] shadow-inner">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#FEFFFF]">
            Singapore payroll has four moving parts an employer manages every month or year: CPF contributions for citizens and PRs, the Skills Development Levy (SDL) for all employees, the Foreign Worker Levy (FWL) for Work Permit and S Pass holders, and annual income reporting through IR8A. Each has its own rate, deadline and penalty.
          </p>
        </div>
        <div class="space-y-3 text-sm sm:text-base leading-relaxed text-[#CBCFD8] font-sans">
          <p>CPF goes to the CPF Board for every Singaporean and PR employee. SDL is a small levy on all staff, submitted alongside CPF.</p>
          <p>FWL covers Work Permit and S Pass holders and is paid to MOM. IR8A is the annual income report to IRAS, with IR21 for anyone who leaves.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ SPLIT 3: How much does it cost? (light EDF0F5, text left) ════ -->
<section class="bg-[#EDF0F5] text-[#000F22] py-20 border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <div class="lg:col-span-7 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">PRICING</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">
          How much does payroll outsourcing cost in Singapore?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#F2F4F7] text-[#000F22] shadow-sm">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#000F22]">
            Basic payroll processing runs about S$5 to S$15 per employee per month, while full-service payroll covering CPF, SDL, payslips and IR8A typically costs S$50 to S$80 per employee per month. Most providers charge a small base fee plus a per-employee rate, so the cost scales with your headcount.
          </p>
        </div>
        <div class="space-y-4 text-sm sm:text-base leading-relaxed text-gray-700 font-sans">
          <p>Because we price per employee, a five-person team pays far less than a fifty-person one, and you only ever pay for the people actually on your payroll that month.</p>
          <p>See full pricing on our <a href="/pricing/" class="text-[#DAA035] hover:underline">pricing page</a>, or get a per-employee quote in one short call.</p>
        </div>
      </div>

      <!-- Visual: per-employee pricing scale -->
      <div class="lg:col-span-5 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="border-b border-gray-800 pb-3 mb-6 font-mono text-center">
              <span class="text-xs text-[#DAA035] uppercase font-bold tracking-wider">Per-Employee Pricing</span>
            </div>
            <div class="space-y-4 font-sans">
              <div class="p-3 bg-[#020B16] rounded-xl border border-gray-800 flex justify-between items-center">
                <div>
                  <span class="block text-[10px] font-mono text-gray-500 font-bold uppercase">Basic processing</span>
                  <span class="text-xs font-bold text-white">Salary + payslips only</span>
                </div>
                <span class="text-sm font-black font-mono text-gray-400 shrink-0">S$5<span class="text-[10px] font-normal text-gray-600">/emp/mo</span></span>
              </div>
              <div class="p-4 bg-[#0A1628] rounded-xl border border-[#DAA035] flex justify-between items-center shadow-lg scale-[1.02]">
                <div>
                  <span class="block text-[10px] font-mono text-[#DAA035] font-bold uppercase">Full-service payroll</span>
                  <span class="text-xs font-bold text-white">CPF, SDL, payslips + IR8A</span>
                </div>
                <span class="text-base font-black font-mono text-[#DAA035] shrink-0">S$50<span class="text-[10px] font-normal text-gray-400">/emp/mo</span></span>
              </div>

              <!-- Headcount examples -->
              <div class="pt-2">
                <span class="block text-[10px] font-mono text-gray-500 uppercase tracking-wider mb-3">Example monthly costs</span>
                <div class="space-y-2">
                  {[
                    { n: '5 employees', cost: '~S$250', bar: '20%' },
                    { n: '10 employees', cost: '~S$500', bar: '40%' },
                    { n: '20 employees', cost: '~S$1,000', bar: '80%' },
                  ].map((ex) => (
                    <div class="flex items-center gap-3">
                      <span class="text-[11px] text-gray-500 w-24 shrink-0">{ex.n}</span>
                      <div class="flex-1 bg-gray-900 rounded-full h-1.5 overflow-hidden">
                        <div class="bg-[#DAA035] h-full rounded-full" style={`width: ${ex.bar}`}></div>
                      </div>
                      <span class="text-[11px] font-bold text-[#DAA035] w-16 text-right shrink-0">{ex.cost}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
          <p class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-4">*Pay only for the people actually on payroll that month</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ SPLIT 4: In-house vs outsource? (dark 061224, visual left) ════ -->
<section class="bg-[#061224] text-[#CBCFD8] py-20 border-b border-gray-950">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <!-- Visual: cost + risk comparison -->
      <div class="lg:col-span-5 order-2 lg:order-1 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="border-b border-gray-800 pb-3 mb-6 font-mono text-center">
              <span class="text-xs text-[#DAA035] uppercase font-bold tracking-wider">In-house vs Outsourced</span>
            </div>
            <div class="space-y-4 font-sans">
              <div class="p-4 bg-red-950/20 rounded-xl border border-red-900/40 space-y-2">
                <span class="block text-[10px] font-mono text-red-400 uppercase font-bold">In-house HR / Payroll exec</span>
                <ul class="space-y-1 text-[11px] text-gray-400">
                  <li class="flex gap-1.5"><span class="text-red-400 shrink-0">&#10007;</span> Salary + CPF + benefits</li>
                  <li class="flex gap-1.5"><span class="text-red-400 shrink-0">&#10007;</span> Must track every rate change</li>
                  <li class="flex gap-1.5"><span class="text-red-400 shrink-0">&#10007;</span> Compliance risk stays with you</li>
                  <li class="flex gap-1.5"><span class="text-red-400 shrink-0">&#10007;</span> Idle when headcount is low</li>
                </ul>
              </div>
              <div class="p-4 bg-emerald-950/25 rounded-xl border border-emerald-900/40 space-y-2">
                <span class="block text-[10px] font-mono text-[#DAA035] uppercase font-bold">AFSB outsourced payroll</span>
                <ul class="space-y-1 text-[11px] text-gray-300">
                  <li class="flex gap-1.5"><span class="text-emerald-400 shrink-0">&#10003;</span> Per-employee pricing</li>
                  <li class="flex gap-1.5"><span class="text-emerald-400 shrink-0">&#10003;</span> Rate changes applied automatically</li>
                  <li class="flex gap-1.5"><span class="text-emerald-400 shrink-0">&#10003;</span> Compliance risk on a specialist</li>
                  <li class="flex gap-1.5"><span class="text-emerald-400 shrink-0">&#10003;</span> Scales up and down with headcount</li>
                </ul>
              </div>
              <div class="p-3 bg-[#DAA035]/10 rounded-xl border border-[#DAA035]/25 text-center">
                <span class="text-[#DAA035] font-black text-lg">25&ndash;40%</span>
                <span class="block text-[10px] text-gray-500 font-mono uppercase tracking-wider">Typical cost saving vs in-house HR</span>
              </div>
            </div>
          </div>
          <p class="text-[10px] text-gray-500 font-mono text-center pt-4 border-t border-gray-800 mt-4">*Nearly half of employees consider leaving after 2 payroll errors</p>
        </div>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2 flex flex-col justify-center space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">IN-HOUSE VS OUTSOURCE</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#FEFFFF] font-extrabold tracking-tight">
          Should you run payroll in-house or outsource it?
        </h2>
        <div class="p-6 my-2 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#0A1628] text-[#FEFFFF] shadow-inner">
          <p class="text-base md:text-lg leading-relaxed font-semibold italic text-[#FEFFFF]">
            For most SMEs with fewer than 50 staff, outsourcing payroll is cheaper and safer than a dedicated hire, saving roughly 25 to 40% versus an in-house HR exec once CPF, benefits and software are counted. Outsourcing also moves the compliance risk to a specialist who tracks every rate change and deadline for you.
          </p>
        </div>
        <div class="space-y-4 text-sm sm:text-base leading-relaxed text-[#CBCFD8] font-sans">
          <p>Manual payroll looks free until it isn't. Wasted hours, compliance penalties, and payroll mistakes that erode staff trust all carry a real cost, and nearly half of employees consider leaving after just two payroll errors.</p>
          <p>Outsource and you get accurate monthly runs, automatic rate updates, and centrally tracked deadlines, without tying up your own team.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ SPLIT 5: Deadlines & penalties (warm FFFDF2, visual left) ════ -->
<section class="bg-[#FFFDF2] text-[#000F22] py-20 border-b border-amber-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-stretch">

      <!-- Visual: deadline & penalty panel -->
      <div class="lg:col-span-5 order-2 lg:order-1 h-full">
        <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 sm:p-8 shadow-xl h-full flex flex-col justify-between">
          <div>
            <div class="flex items-center gap-2 border-b border-gray-800 pb-3 mb-6 font-mono">
              <span class="w-2 h-2 rounded-full bg-amber-500 animate-ping shrink-0"></span>
              <span class="text-xs text-[#DAA035] uppercase font-bold tracking-wider">Payroll Deadlines</span>
            </div>
            <div class="space-y-3 font-sans">
              {[
                { label: 'Salary payment', deadline: 'Within 7 days of pay cycle end', law: 'Employment Act', severity: 'amber' },
                { label: 'CPF submission', deadline: 'Monthly, by last day of following month', law: 'CPF Act', severity: 'amber' },
                { label: 'Late CPF penalty', deadline: '1.5%/month + up to S$5,000 fine', law: 'CPF Act', severity: 'red' },
                { label: 'IR8A filing', deadline: 'Annual — by start of year', law: 'IRAS', severity: 'amber' },
                { label: 'IR21 clearance', deadline: 'Before leaver departs Singapore', law: 'IRAS', severity: 'red' },
              ].map((row) => (
                <div class={`p-3 rounded-xl border ${row.severity === 'red' ? 'bg-red-950/20 border-red-900/30' : 'bg-[#020B16] border-gray-800'}`}>
                  <div class="flex items-center justify-between mb-0.5">
                    <span class="text-xs font-bold text-white">{row.label}</span>
                    <span class={`text-[9px] font-mono font-bold uppercase border px-1.5 py-0.5 rounded ${row.severity === 'red' ? 'text-red-400 border-red-500/30 bg-red-500/10' : 'text-amber-400 border-amber-500/30 bg-amber-500/10'}`}>{row.law}</span>
                  </div>
                  <span class={`text-[11px] leading-snug ${row.severity === 'red' ? 'text-red-300' : 'text-gray-400'}`}>{row.deadline}</span>
                </div>
              ))}
