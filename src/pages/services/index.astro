---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Accounting Services for Singapore Small Businesses | AFSB';
const description = 'All accounting services for Singapore SMEs: bookkeeping, financial statements, payroll and management reporting. Fixed monthly fees, no hidden add-ons.';

const schemaJsonLd = `<script type="application/ld+json">
{"@context":"https://schema.org","@graph":[{"@type":"Service","@id":"https://accountantforsmallbusiness.com/services/#service","name":"Accounting Services for Singapore Small Businesses","provider":{"@id":"https://accountantforsmallbusiness.com/#org"},"areaServed":{"@type":"Country","name":"Singapore"},"description":"Complete accounting, bookkeeping, payroll and financial reporting services for Singapore small businesses and SMEs. Fixed monthly fees. Remote delivery via Xero and QuickBooks Online.","hasOfferCatalog":{"@type":"OfferCatalog","name":"Accounting services","itemListElement":[{"@type":"Offer","itemOffered":{"@type":"Service","name":"Bookkeeping","url":"https://accountantforsmallbusiness.com/bookkeeping-services-singapore/"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Financial statements","url":"https://accountantforsmallbusiness.com/financial-statements-singapore/"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Payroll and CPF","url":"https://accountantforsmallbusiness.com/payroll-services-singapore/"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Outsourced accounting","url":"https://accountantforsmallbusiness.com/outsource-accounting-services-singapore/"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Management reporting"}}]}},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What accounting services do Singapore small businesses need?","acceptedAnswer":{"@type":"Answer","text":"Most Singapore SMEs need bookkeeping, SFRS-compliant financial statements, payroll with CPF, and monthly management reports. One fixed monthly fee from AFSB covers all of these."}},{"@type":"Question","name":"How much do accounting services cost in Singapore?","acceptedAnswer":{"@type":"Answer","text":"From S$90 per month for basic bookkeeping to S$450+ for a full managed service including payroll. Exact fee based on your transaction volume, confirmed on a free call."}},{"@type":"Question","name":"Does an accountant need to be based in Singapore?","acceptedAnswer":{"@type":"Answer","text":"No. Remote accountants can fully comply with SFRS, ACRA and IRAS requirements using cloud accounting software like Xero or QuickBooks Online."}},{"@type":"Question","name":"What is not included in your accounting services?","acceptedAnswer":{"@type":"Answer","text":"We do not file GST, corporate tax or incorporate companies. Those are handled by your licensed Singapore tax agent or filing agent. We keep your books ready so they can file accurately."}}]},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://accountantforsmallbusiness.com/"},{"@type":"ListItem","position":2,"name":"Services","item":"https://accountantforsmallbusiness.com/services/"}]}]}
<\/script>`;

const services = [
  {
    n: '01', title: 'Accounting & Bookkeeping', slug: 'accounting-services-singapore',
    desc: 'Full monthly accounting service: bookkeeping, reconciliation, SFRS financial statements, AP/AR and management reports in one fixed fee.',
    features: ['Monthly bookkeeping', 'Bank reconciliation', 'SFRS financial statements', 'Management reports', 'AP/AR tracking'],
    from: 'S$90/mo', color: 'amber',
  },
  {
    n: '02', title: 'Bookkeeping Services', slug: 'bookkeeping-services-singapore',
    desc: 'Day-to-day transaction recording, bank reconciliation and clean monthly books on Xero or QuickBooks. Priced on your real transaction volume.',
    features: ['Transaction recording', 'Bank reconciliation', 'Credit-card matching', 'AP/AR tracking', 'Monthly summary'],
    from: 'S$90/mo', color: 'sky',
  },
  {
    n: '03', title: 'Outsourced Accounting', slug: 'outsource-accounting-services-singapore',
    desc: 'Complete finance function delivered remotely. Replace an in-house accountant at a fraction of the cost, with a qualified Financial Controller.',
    features: ['Full accounting function', 'Named FC assigned', 'SFRS compliant', 'Xero or QuickBooks', 'Scales with you'],
    from: 'S$200/mo', color: 'emerald',
  },
  {
    n: '04', title: 'Payroll & CPF', slug: 'payroll-services-singapore',
    desc: 'Monthly payroll with CPF and SDL submissions, itemised payslips, IR8A filing and IR21 clearance. Per-employee pricing that scales with your headcount.',
    features: ['Salary computation', 'CPF & SDL submission', 'Itemised payslips', 'Annual IR8A', 'IR21 for leavers'],
    from: 'S$8/emp', color: 'purple',
  },
  {
    n: '05', title: 'Financial Statements', slug: 'financial-statements-singapore',
    desc: 'SFRS-compliant unaudited financial statements prepared from your books, ready for ACRA, IRAS and your AGM. Includes Director\'s Statement.',
    features: ['SFRS-compliant', 'Income statement', 'Balance sheet', 'Cash flow', "Director's Statement"],
    from: 'Annual', color: 'teal',
  },
];

const colorMap: Record<string, string> = {
  amber: 'border-amber-500/30 bg-amber-500/5 hover:border-amber-500/50',
  sky: 'border-sky-500/30 bg-sky-500/5 hover:border-sky-500/50',
  emerald: 'border-emerald-500/30 bg-emerald-950/20 hover:border-emerald-500/50',
  purple: 'border-purple-500/30 bg-purple-500/5 hover:border-purple-500/50',
  teal: 'border-teal-500/30 bg-teal-500/5 hover:border-teal-500/50',
};

const faqs = [
  { q: 'What accounting services do Singapore small businesses need?', a: 'Most Singapore SMEs need bookkeeping, SFRS-compliant financial statements, payroll with CPF, and monthly management reports. One fixed monthly fee from AFSB covers all of these.' },
  { q: 'How much do accounting services cost in Singapore?', a: 'From S$90 per month for basic bookkeeping to S$450+ for a full managed service including payroll. Exact fee based on your transaction volume, confirmed on a free call.' },
  { q: 'Does an accountant need to be based in Singapore?', a: 'No. Remote accountants can fully comply with SFRS, ACRA and IRAS requirements using cloud accounting software like Xero or QuickBooks Online.' },
  { q: 'Do you file GST and corporate tax?', a: 'No. We handle accounting: bookkeeping, financial statements, payroll and management reporting. GST and corporate tax filing are done by your licensed Singapore tax agent.' },
  { q: 'How do I switch from my current accountant?', a: 'We manage the handover: collect your records, set up Xero or QuickBooks, and pick up your monthly cycle with no gap in compliance.' },
  { q: 'What is the Singapore small company audit exemption?', a: 'Your company is audit-exempt if it meets 2 of 3 criteria for 2 consecutive years: revenue under S$10M, assets under S$10M, 50 or fewer employees. Audit-exempt companies prepare unaudited statements instead.' },
];
---

<BaseLayout {title} {description} schemaJsonLd={schemaJsonLd}>

<!-- ════ HERO ════ -->
<section class="relative overflow-hidden bg-gradient-to-b from-[#000F22] to-[#0A1628] pt-20 pb-16 border-b border-gray-900 text-center">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(220,163,60,0.03)_0%,transparent_70%)] pointer-events-none"></div>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 space-y-6">
    <nav class="flex items-center justify-center gap-2 text-xs text-gray-500 font-mono mb-2">
      <a href="/" class="hover:text-[#DAA035] transition-colors">Home</a>
      <span>/</span>
      <span class="text-[#DAA035]">Services</span>
    </nav>
    <span class="inline-block py-1.5 px-3 rounded-full bg-[#DAA035]/15 border border-[#DAA035]/30 text-[#DAA035] text-xs font-mono uppercase tracking-widest">
      Fixed monthly fees &bull; Remote delivery &bull; Singapore SMEs
    </span>
    <h1 class="text-4xl sm:text-5xl font-serif text-[#FEFFFF] font-bold tracking-tight leading-tight">
      Accounting Services for Singapore Small Businesses
    </h1>
    <p class="text-sm sm:text-base text-[#CBCFD8] max-w-2xl mx-auto leading-relaxed">
      Five core services. One dedicated Financial Controller. One fixed monthly fee. Everything a Singapore SME needs to keep clean books, stay compliant, and make informed decisions.
    </p>
    <div class="flex flex-wrap justify-center gap-4 pt-2">
      <a href="/contact/" class="bg-[#DCA33C] hover:bg-[#C8912F] text-[#000F22] font-semibold px-8 py-3.5 rounded-lg text-sm transition-all hover:scale-[1.01]">
        Get a fixed quote
      </a>
      <a href="/pricing/" class="border border-[#DAA035] text-[#DAA035] hover:bg-[#DAA035] hover:text-[#000F22] font-semibold px-8 py-3.5 rounded-lg text-sm transition-all">
        See pricing
      </a>
    </div>
  </div>
</section>

<!-- ════ SERVICES GRID ════ -->
<section class="bg-[#000F22] py-20 border-b border-gray-950 relative overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] rounded-full" style="background: radial-gradient(ellipse at center, rgba(220,163,60,0.05) 0%, transparent 65%);"></div>
  </div>
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block mb-3">Five core services</span>
      <h2 class="text-3xl sm:text-4xl font-sans text-white font-extrabold tracking-tight">Everything your books need, in one place</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {services.map((svc) => (
        <a href={`/${svc.slug}/`} class={`block bg-[#0A1628] border rounded-2xl p-7 transition-all duration-200 hover:-translate-y-1 group ${colorMap[svc.color]}`}>
          <div class="flex items-center justify-between mb-5">
            <span class="text-[10px] font-mono text-gray-500 font-bold">{svc.n}</span>
            <span class="text-xs font-mono font-black text-[#DAA035]">{svc.from}</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-2 group-hover:text-[#DAA035] transition-colors">{svc.title}</h3>
          <p class="text-xs text-gray-400 leading-relaxed mb-5">{svc.desc}</p>
          <ul class="space-y-1.5 mb-5">
            {svc.features.map((f) => (
              <li class="flex items-center gap-2 text-xs text-[#CBCFD8]">
                <svg class="w-3.5 h-3.5 text-[#DAA035] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <span class="text-xs font-mono font-bold text-[#DAA035] group-hover:underline">Learn more &rarr;</span>
        </a>
      ))}

      <!-- ── CTA card (6th slot) ── -->
      <div class="relative bg-gradient-to-br from-[#DCA33C] to-[#C8912F] rounded-2xl p-7 flex flex-col justify-between overflow-hidden" style="box-shadow: 0 8px 32px rgba(220,163,60,0.25);">
        <!-- Subtle pattern -->
        <div class="absolute inset-0 opacity-10">
          <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
            <defs><pattern id="cta-dots" width="24" height="24" patternUnits="userSpaceOnUse"><circle cx="12" cy="12" r="1.5" fill="#000F22"/></pattern></defs>
            <rect width="100%" height="100%" fill="url(#cta-dots)"/>
          </svg>
        </div>

        <div class="relative z-10">
          <!-- Eyebrow -->
          <div class="flex items-center justify-between mb-6">
            <span class="text-[10px] font-mono font-bold text-[#000F22]/60 uppercase tracking-widest">Free consultation</span>
            <div class="w-8 h-8 rounded-full bg-[#000F22]/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-[#000F22]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </div>

          <h3 class="text-2xl font-extrabold text-[#000F22] leading-tight mb-3">
            Not sure which service you need?
          </h3>
          <p class="text-sm text-[#000F22]/70 leading-relaxed mb-6">
            Tell us about your business in one short call. We'll tell you exactly what you need, quote a fixed monthly fee, and start within a week.
          </p>

          <!-- Trust points -->
          <ul class="space-y-2 mb-8">
            {['No obligation', 'Fixed price in writing', 'Up and running in 1 week', 'S$0 transition cost'].map((item) => (
              <li class="flex items-center gap-2.5 text-xs font-semibold text-[#000F22]/80">
                <svg class="w-4 h-4 text-[#000F22] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA buttons -->
        <div class="relative z-10 space-y-2.5">
          <a
            href="/contact/"
            class="block w-full text-center bg-[#000F22] hover:bg-[#0A1628] text-[#DCA33C] font-bold py-3.5 rounded-xl text-sm transition-all hover:shadow-xl"
          >
            Book a free consultation
          </a>
          <a
            href="/pricing/"
            class="block w-full text-center bg-[#000F22]/10 hover:bg-[#000F22]/20 text-[#000F22] font-semibold py-3 rounded-xl text-xs transition-all"
          >
            See pricing first &rarr;
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ════ WHY ONE PROVIDER (light) ════ -->
<section class="bg-[#F8FAFC] py-20 border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-6">
        <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">WHY AFSB</span>
        <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">Why choose one accountant for everything?</h2>
        <div class="p-6 border-l-[3px] border-[#DAA035] rounded-r-lg bg-[#F2F4F7] shadow-sm">
          <p class="text-base leading-relaxed font-semibold italic text-[#000F22]">Because when one qualified person handles your books, payroll and financial statements, nothing gets lost between providers. Mehdi Javed is the single point of contact from your first call to every month-end close.</p>
        </div>
        <div class="space-y-3">
          {[
            { title: 'Named Financial Controller', desc: 'You always know exactly who keeps your books.' },
            { title: 'Transaction-based pricing', desc: 'Your fee tracks your real activity. No locked tiers.' },
            { title: 'Remote, lower overhead', desc: 'No Singapore office costs passed on to you.' },
            { title: 'SFRS & CPF compliant', desc: 'Every filing meets Singapore standards.' },
          ].map((item) => (
            <div class="flex items-start gap-3 p-3 bg-white rounded-xl border border-gray-200 shadow-sm">
              <span class="w-5 h-5 rounded-full bg-[#DAA035]/15 text-[#DAA035] text-xs font-bold flex items-center justify-center shrink-0 mt-0.5 border border-[#DAA035]/25">&#10003;</span>
              <div>
                <span class="font-semibold text-[#000F22] text-sm">{item.title}</span>
                <span class="text-gray-600 text-xs block">{item.desc}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
      <!-- Stats -->
      <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-8 space-y-4">
        <h3 class="text-sm font-mono text-[#DAA035] uppercase tracking-wider font-bold border-b border-gray-800 pb-3">At a glance</h3>
        {[
          { v: '28% Faster', l: 'Month-end financial close', w: '72%', g: 'from-[#DCA33C] to-[#DAA035]' },
          { v: '10% Less', l: 'Operating overhead cost', w: '90%', g: 'from-emerald-600 to-emerald-400' },
          { v: '15+ Years', l: 'Multi-entity SME experience', w: '100%', g: 'from-blue-500 to-cyan-400' },
          { v: 'S$0', l: 'Singapore office overhead', w: '5%', g: 'from-gray-500 to-gray-400' },
        ].map((s) => (
          <div class="bg-[#000F22]/50 p-4 rounded-xl border border-gray-900">
            <span class="block text-xl font-black text-[#DAA035] tracking-tight">{s.v}</span>
            <span class="block text-[11px] uppercase tracking-wider text-[#FEFFFF] font-mono mt-1">{s.l}</span>
            <div class="w-full bg-gray-950 h-1 rounded-full mt-2 overflow-hidden">
              <div class={`bg-gradient-to-r ${s.g} h-full rounded-full`} style={`width:${s.w}`}></div>
            </div>
          </div>
        ))}
        <a href="/about/" class="block text-center text-xs font-mono text-[#DAA035] hover:underline pt-2">Meet Mehdi Javed &rarr;</a>
      </div>
    </div>
  </div>
</section>

<!-- ════ SCOPE CLARITY (dark) ════ -->
<section class="bg-[#061224] py-20 border-b border-gray-950">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 space-y-3">
      <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">CLEAR SCOPE</span>
      <h2 class="text-3xl sm:text-4xl font-sans text-white font-extrabold tracking-tight">What we do, and what we leave to specialists</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div class="bg-[#0A1628] border border-emerald-900/40 rounded-2xl p-6 space-y-3">
        <h3 class="text-xs font-mono text-[#DAA035] uppercase tracking-wider font-bold">AFSB handles</h3>
        {['Bookkeeping and bank reconciliation', 'SFRS-compliant financial statements', 'Monthly management reports', 'Payroll with CPF and payslips', 'Accounts payable and receivable'].map((i) => (
          <div class="flex items-center gap-2.5 text-xs text-[#CBCFD8]">
            <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            {i}
          </div>
        ))}
      </div>
      <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-6 space-y-3">
        <h3 class="text-xs font-mono text-gray-500 uppercase tracking-wider font-bold">Handled by licensed specialists</h3>
        {['GST filing (your licensed tax agent)', 'Corporate income tax (your tax agent)', 'Company incorporation (a filing agent)', 'Statutory audit (ACRA public accountant)'].map((i) => (
          <div class="flex items-center gap-2.5 text-xs text-gray-500">
            <svg class="w-4 h-4 text-gray-700 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4"/></svg>
            {i}
          </div>
        ))}
        <p class="text-[11px] text-gray-600 pt-2 border-t border-gray-800 leading-relaxed">We keep your books clean so every specialist can do their part accurately and on time.</p>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHO WE SERVE (light) ════ -->
<section class="bg-[#EBF3FC] py-20 border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 space-y-3">
      <span class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold block">WHO WE SERVE</span>
      <h2 class="text-3xl sm:text-4xl font-sans text-[#000F22] font-extrabold tracking-tight">Built for Singapore SMEs and sole proprietors</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {[
        { title: 'Sole proprietors', desc: 'Clean books and year-end statements without the cost of an in-house hire.' },
        { title: 'Pte Ltd companies', desc: 'SFRS-compliant financial statements, payroll and management reports from a dedicated FC.' },
        { title: 'E-commerce sellers', desc: 'Multi-currency reconciliation on Shopify, Shopee, Lazada and Stripe.' },
        { title: 'Agencies and studios', desc: 'Project-level P&L, retainer billing and clean books ready for your tax agent.' },
        { title: 'Startups', desc: 'Investor-ready books, SFRS statements and fast financial closes from day one.' },
        { title: 'SMEs with staff', desc: 'Full payroll with CPF, IR8A and accounts payable and receivable tracked monthly.' },
      ].map((item) => (
        <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm space-y-2">
          <h3 class="text-sm font-extrabold text-[#000F22]">{item.title}</h3>
          <p class="text-xs text-gray-600 leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ FAQ (AEO / GEO) ════ -->
<section class="bg-[#000F22] py-16 border-b border-gray-950">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl font-serif text-white font-semibold">Frequently Asked Questions</h2>
    </div>
    <div class="space-y-4">
      {faqs.map((faq) => (
        <details class="bg-[#0A1628] border border-gray-900 rounded-lg p-5 group">
          <summary class="w-full flex items-center justify-between text-left font-sans text-sm sm:text-base font-semibold text-white cursor-pointer list-none select-none">
            <span>{faq.q}</span>
            <svg class="w-5 h-5 text-gray-500 group-open:text-[#DAA035] transition-colors shrink-0 ml-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="mt-4 pt-4 border-t border-gray-800 text-xs sm:text-sm text-[#CBCFD8] leading-relaxed">{faq.a}</div>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- ════ CLOSING CTA ════ -->
<section class="bg-[#FFFDF2] py-20 text-center">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-6">
    <h3 class="text-3xl sm:text-4xl font-sans text-amber-950 font-extrabold tracking-tight">Ready to get your books in order?</h3>
    <p class="text-sm sm:text-base leading-relaxed text-gray-700 max-w-xl mx-auto font-medium">
      Get a fixed monthly quote built around your actual transaction volume. One call, one fixed price, no obligation.
    </p>
    <a href="/contact/" class="inline-block bg-[#DCA33C] hover:bg-[#C8912F] text-[#000F22] font-mono text-xs font-bold uppercase tracking-widest px-8 py-4 rounded-xl shadow-lg transition-all">
      Get a free quote &nbsp;&rarr;
    </a>
  </div>
</section>

</BaseLayout>
