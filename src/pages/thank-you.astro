---
import BaseLayout from '../layouts/BaseLayout.astro';
// noindex page - only shown after form submission
---

<BaseLayout
  title="Request Received | Accountant for Small Business Singapore"
  description="Thank you for your enquiry. We'll be in touch within one business day with your fixed quote."
>
  <!-- noindex this page -->
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <section class="relative bg-[#000F22] min-h-screen flex items-center overflow-hidden">
    <!-- Animated background -->
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full" style="background: radial-gradient(circle, rgba(220,163,60,0.06) 0%, transparent 70%); animation: pulse-glow 4s ease-in-out infinite;"></div>
      <div class="absolute bottom-1/4 right-1/4 w-64 h-64 rounded-full" style="background: radial-gradient(circle, rgba(220,163,60,0.04) 0%, transparent 70%); animation: pulse-glow 6s ease-in-out infinite 2s;"></div>
      <svg class="absolute inset-0 w-full h-full opacity-[0.03]" xmlns="http://www.w3.org/2000/svg">
        <defs><pattern id="grid-ty" width="60" height="60" patternUnits="userSpaceOnUse"><path d="M 60 0 L 0 0 0 60" fill="none" stroke="#DAA035" stroke-width="0.5"/></pattern></defs>
        <rect width="100%" height="100%" fill="url(#grid-ty)"/>
      </svg>
    </div>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-24 relative z-10 text-center">

      <!-- Success icon with ring animation -->
      <div class="relative inline-flex items-center justify-center mb-10">
        <div class="absolute w-32 h-32 rounded-full border-2 border-[#DAA035]/20 animate-ping" style="animation-duration: 2s;"></div>
        <div class="absolute w-24 h-24 rounded-full border border-[#DAA035]/30"></div>
        <div class="w-20 h-20 rounded-full bg-[#DAA035]/15 border border-[#DAA035]/40 flex items-center justify-center">
          <svg class="w-10 h-10 text-[#DAA035]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
      </div>

      <h1 class="text-4xl sm:text-5xl font-serif text-[#FEFFFF] font-bold tracking-tight mb-4">
        Request received!
      </h1>
      <p class="text-base sm:text-lg text-[#CBCFD8] max-w-xl mx-auto leading-relaxed mb-10">
        Mehdi will review your details and come back with a clear fixed monthly quote within one business day. No obligation.
      </p>

      <!-- What happens next -->
      <div class="bg-[#0A1628] border border-gray-800 rounded-2xl p-7 text-left mb-10 max-w-xl mx-auto">
        <h2 class="text-xs font-mono text-[#DAA035] uppercase tracking-widest font-bold mb-5">What happens next</h2>
        <div class="space-y-4">
          {[
            { n: '1', title: 'We review your details', desc: 'Mehdi checks your transaction volume and service needs.' },
            { n: '2', title: 'Your fixed quote is prepared', desc: 'A clear monthly figure, in writing, no surprises.' },
            { n: '3', title: "You decide, zero pressure", desc: 'Accept, decline or ask questions. No payment collected.' },
          ].map((step) => (
            <div class="flex items-start gap-4">
              <span class="w-7 h-7 rounded-full bg-[#DAA035]/10 text-[#DAA035] border border-[#DAA035]/25 font-mono text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">{step.n}</span>
              <div>
                <span class="block text-sm font-bold text-white">{step.title}</span>
                <span class="block text-xs text-gray-500 mt-0.5">{step.desc}</span>
              </div>
            </div>
          ))}
        </div>
        <div class="mt-5 pt-5 border-t border-gray-800 flex items-center gap-3">
          <svg class="w-4 h-4 text-[#DAA035] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="text-xs text-[#CBCFD8]">Expected response: within 1 business day, Mon-Fri Singapore hours (GMT+8)</span>
        </div>
      </div>

      <!-- Explore while you wait -->
      <p class="text-xs text-gray-500 font-mono uppercase tracking-wider mb-5">Explore while you wait</p>
      <div class="flex flex-wrap justify-center gap-3">
        {[
          { label: 'Our Services', href: '/accounting-services-singapore/' },
          { label: 'Transparent Pricing', href: '/pricing/' },
          { label: 'About Mehdi', href: '/about/' },
          { label: 'SME Blog', href: '/blog/' },
        ].map((link) => (
          <a href={link.href} class="px-4 py-2 bg-[#0A1628] border border-gray-800 hover:border-[#DAA035]/40 text-[#CBCFD8] hover:text-[#DAA035] text-xs font-medium rounded-lg transition-all">
            {link.label}
          </a>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>
